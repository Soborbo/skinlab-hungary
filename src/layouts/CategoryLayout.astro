                <span class="px-3 py-1.5 rounded-lg inline-flex items-start gap-1.5 border border-gray-200 text-gray-700 bg-white">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" style={`color: ${accentDark}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  <span class="leading-tight">
                    <span class="font-medium text-gray-900">{badge.title}</span>
                    {badge.subtitle && (
                      <span class="block text-xs text-gray-500 mt-0.5">{badge.subtitle}</span>
