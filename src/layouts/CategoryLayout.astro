---
import BaseLayout from './BaseLayout.astro';
import { SITE, CONTACT, CATEGORY_COLORS } from '../lib/constants';
import OptimizedPicture from '../components/images/OptimizedPicture.astro';
import { Image } from 'astro:assets';
import { hasImage, getImageAlt, getOgImagePath } from '@/lib/resolve-image';
import { config } from '../config/siteConfig';
import { collectionPageSchema, breadcrumbSchema as buildBreadcrumb, faqSchema as buildFaqSchema } from '../config/schema';
import QuickAddButton from '../components/cart/QuickAddButton.astro';
import CategoryConsultationCard from '../components/cta/CategoryConsultationCard.astro';
import FounderConsult from '../components/cta/FounderConsult.astro';
import { getLocaleFromUrl, withTrailingSlash, type Locale } from '../i18n/ui';
import { getInstallmentInfo } from '@/lib/installment';

const pageLocale = getLocaleFromUrl(Astro.url) as Locale;

interface ComparisonProduct {
  name: string;
  tag?: string;
  tagColor?: string;
  highlighted?: boolean;
  link?: string;
  specs: Record<string, string>;
}

interface ChoiceWhen {
  title: string;
  description: string;
}

interface Choice {
  name: string;
  subtitle: string;
  tagline?: string;
  image: string;
  imageAlt?: string;
  intro: string;
  pillars?: string[];
  whenTitle?: string;
  when?: ChoiceWhen[];
  notes?: string[];
  closing?: string;
  link: string;
  ctaLabel?: string;
}

interface Expert {
  name: string;
  role: string;
  image: string;
  imageAlt?: string;
  quote?: string;
}

interface TrustBadge {
  title: string;
  subtitle?: string;
}

interface Props {
  category: {
    name: string;
    nameShort: string;
    slug: string;
    description: string;
    heroDescription?: string;
    badge?: string;
    color?: string;
  };
  products?: any[];
  faq?: { question: string; answer: string }[];
  benefits?: { icon: string; title: string; description: string }[];
  /**
   * Opt-in: a benefits-szekció jobb oldali képe (a "Kép helye" placeholder helyett).
   * Astro:assets ImageMetadata (import a src/assets-ből) vagy kész URL string.
   */
  benefitsImage?: ImageMetadata;
  benefitsImageAlt?: string;
  comparison?: {
    features: string[];
    products: ComparisonProduct[];
  };
  choices?: Choice[];
  choicesHeading?: string;
  choicesSubheading?: string;
  choicesIntro?: string;
  choicesClosing?: string;
  /**
   * Opt-in: hero jobb oldal lead-capture kártya (founder/expert).
   * Ha jelen van, a placeholder helyett a CategoryConsultationCard renderelődik.
   * Forrás: docs/CATEGORY-PAGE-HANDBOOK.md §3
   */
  expert?: Expert;
  /**
   * Opt-in: specifikus trust badge-ek (cím + alcím SLA-val).
   * Ha undefined, a jelenlegi 4 vague badge marad (backwards-compatible).
   * Forrás: docs/CATEGORY-PAGE-HANDBOOK.md §6.2
   */
  trustBadges?: TrustBadge[];
  /**
   * Opt-in: lead-capture kártya CTA href.
   * Default: /konzultacio?cat={category.slug}
   */
  consultationCtaHref?: string;
  /**
   * Opt-in: social proof sor a lead-capture kártya alján.
   */
  consultationSocialProof?: string;
  /**
   * Opt-in: egysoros "chooser" a decision-fold hero bal oszlopában.
   * Pl. [{ label: 'Kezdő szalon?', target: 'ATHENA' }, ...]
   * Gyors "melyik nekem" orientáció görgetés nélkül.
   * Forrás: docs/CATEGORY-PAGE-HANDBOOK.md §3 (decision-first fold)
   */
  heroChooser?: { label: string; target: string }[];
  /**
   * Opt-in: a benefits-szekció címe.
   * Default: 'Mire figyelj a választásnál?' — döntés-támogató keret (NEM "miért
   * válaszd a kategóriát", mert a látogató már a kategórián belül van).
   * A korábbi `Miért érdemes {nameShort}t választani?` automatikus cím
   * nyelvtanilag hibás accusative-ot gyártott (pl. "diódalézerekt"), ezért
   * explicit, felülírható címet használunk.
   */
  benefitsHeading?: string;
}

const {
  category,
  products = [],
  faq = [],
  benefits = [],
  benefitsImage,
  benefitsImageAlt,
  comparison,
  choices = [],
  choicesHeading,
  choicesSubheading,
  choicesIntro,
  choicesClosing,
  expert,
  trustBadges,
  consultationCtaHref,
  consultationSocialProof,
  heroChooser,
  benefitsHeading,
} = Astro.props;

// Termékek ár szerint növekvő sorrendben (legolcsóbb elöl, legdrágább hátul);
// ár nélküli ("Kérjen ajánlatot") termékek a lista végére kerülnek.
// Ez vonatkozik a hero döntő-kártyákra, a termékrácsra és a schema-listára is.
products.sort((a, b) => (a.data.price ?? Infinity) - (b.data.price ?? Infinity));

const resolvedBenefitsHeading = benefitsHeading || 'Mire figyelj a választásnál?';

const resolvedCtaHref = withTrailingSlash(consultationCtaHref || `/konzultacio?cat=${category.slug}`);

// Fold-mód a terméklétszám alapján (lásd docs/CATEGORY-PAGE-HANDBOOK.md §3):
//  - 1 termék  → 'single'  : a fold MAGA a termék (kép-jobb landing), nincs grid
//  - 2 termék  → 'duo'     : a két termék EGYMÁS MELLETT, nagy képes kártyaként
//                  (kevés elemnél a fotó ad el, nem a gyors lista-scan)
//  - 3-4 termék → 'decision': a hero jobb oszlopa a termékeket kompakt,
//                  egymás-alatti döntő-kártyaként mutatja (scan-barát lista)
//  - 0 vagy 5+  → 'classic' : eredeti viselkedés (founder/placeholder + grid)
const productCount = products.length;
const heroMode: 'single' | 'duo' | 'decision' | 'classic' =
  productCount === 1 ? 'single'
  : productCount === 2 ? 'duo'
  : (productCount >= 3 && productCount <= 4 ? 'decision' : 'classic');
const heroProduct = heroMode === 'single' ? products[0] : null;
// A különálló terméknégyzet-grid csak classic módban kell — single/decision
// módban a fold már megmutatja a termékeket, a duplikáció zavaró lenne.
const showStandaloneGrid = heroMode === 'classic';
// Founder (visszahívás) szekció a hero alatt minden gép-kategória oldalon.
// Alapértelmezett: Horváth László (alapító) - oldalanként felülírható az `expert` proppal.
const defaultExpert: Expert = {
  name: 'Horváth László',
  role: 'Skinlab alapító · technikai szakértő',
  image: '/about/horvath-laszlo-skinlab-alapito.jpg',
  imageAlt: 'Horváth László, Skinlab alapító',
};
const resolvedExpert: Expert = expert ?? defaultExpert;
const showFounderSection = heroMode !== 'classic';

const huFmt = new Intl.NumberFormat('hu-HU');
// Teaser havi részlet: a közös installment-logikára kötve (50% előleg + ársávos
// futamidő). 100 000 Ft alatt null → nem jelenik meg "havi ~" a kártyán.
// A leghosszabb elérhető futamidő = legkisebb havi összeg.
const monthlyTeaser = (price?: number | null): number | null => {
  const info = getInstallmentInfo(price);
  if (!info.available) return null;
  const term = info.months[info.months.length - 1];
  return info.monthly[term];
};
const productHref = (p: any) => withTrailingSlash(`/${p.data.categorySlug}/${p.data.slug || p.id}`);
const defaultTrustBadges: TrustBadge[] = [
  { title: '2 év garancia' },
  { title: 'Ingyenes betanítás' },
  { title: 'Magyar szerviz' },
  { title: 'Részletfizetés' },
];
const resolvedTrustBadges: TrustBadge[] = trustBadges && trustBadges.length > 0 ? trustBadges : defaultTrustBadges;

const hasChoices = choices.length > 0;
const showChoicesSection = hasChoices || (comparison && comparison.products.length > 0);

// SVG icon paths for benefit icons (replaces emojis)
const benefitIcons: Record<string, string> = {
  // Trend / growth
  'trend-up': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />`,
  // Users / people
  'users': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />`,
  // Lightning / zap
  'zap': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
  // Target / crosshair
  'target': `<circle cx="12" cy="12" r="10" stroke-width="2" fill="none" /><circle cx="12" cy="12" r="6" stroke-width="2" fill="none" /><circle cx="12" cy="12" r="2" stroke-width="2" fill="none" />`,
  // Clock / timer
  'clock': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  // Money / coins
  'coins': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  // Package / box
  'package': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />`,
  // Check circle / verified
  'check-circle': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  // Refresh / sync
  'refresh': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />`,
  // Sparkles / magic
  'sparkles': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />`,
  // Microscope / research
  'microscope': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />`,
  // Rainbow / palette (colors)
  'palette': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />`,
  // Diamond / gem
  'gem': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3L2 9l10 12L22 9l-10-6z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2 9h20M12 3v6" />`,
  // Flame / fire
  'flame': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z" />`,
  // Muscle / strong
  'muscle': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />`,
  // Star / sparkle
  'star': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />`,
  // Battery / power
  'battery': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h14a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V9a2 2 0 012-2zm18 4v2" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11v2m3-2v2m3-2v2" />`,
  // Smartphone / mobile
  'smartphone': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />`,
  // Cog / settings
  'cog': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`,
  // Pencil / edit
  'pencil': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />`,
  // Volume off / mute
  'mute': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2" />`,
  // Wrench / tool
  'wrench': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`,
  // Trophy / award
  'trophy': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />`,
  // Snowflake / cold (hidegplazma)
  'snowflake': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2v20M2 12h20M4.93 4.93l14.14 14.14M19.07 4.93L4.93 19.07" />`,
  // Shield / protection
  'shield': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016A11.955 11.955 0 0112 2.944z" />`,
};

// Schema: CollectionPage + Breadcrumb entity graph
const pageUrl = SITE.url + withTrailingSlash(`/${category.slug}`);
const productUrls = products.map((p) => SITE.url + withTrailingSlash(`/${category.slug}/${p.data.slug || p.id}`));
const categorySchema = collectionPageSchema(config, pageUrl, category.name, productUrls);
// Push breadcrumb into the @graph
categorySchema['@graph'].push(
  buildBreadcrumb(pageUrl, [
    { name: 'Főoldal', url: SITE.url },
    { name: category.nameShort },
  ])
);
// Push FAQPage into the @graph if FAQs are provided (SEO-only, no visual change)
if (faq.length > 0) {
  categorySchema['@graph'].push(buildFaqSchema(pageUrl, faq));
}

// Resolve category color from the centralized palette
const catColor = (category.color && category.color in CATEGORY_COLORS)
  ? CATEGORY_COLORS[category.color as keyof typeof CATEGORY_COLORS]
  : CATEGORY_COLORS.diodalezerek;
const accentColor = catColor.accent;
const accentDark = catColor.accentDark;

// OG image - use the first product's main image if available
const firstProductImage = products.length > 0 ? products[0].data.image : '';
const ogImage = (firstProductImage && getOgImagePath(firstProductImage)) || '/og-image.jpg';
---

<BaseLayout
  title={category.name}
  description={category.description}
  image={ogImage}
  schema={categorySchema}
>
  <div>

    <!-- Breadcrumb -->
    <nav class="bg-white border-b" aria-label="Breadcrumb">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
        <ol class="flex items-center gap-2 text-sm">
          <li>
            <a href="/" class="text-gray-500 hover:text-primary-600">Főoldal</a>
          </li>
          <li class="text-gray-400">›</li>
          <li class="text-gray-900 font-medium">{category.nameShort}</li>
        </ol>
      </div>
    </nav>

    <!-- Category Hero -->
    <section class="py-12 lg:py-16 relative overflow-hidden" style={`background: linear-gradient(135deg, ${catColor.accentLight} 0%, white 70%)`}>
      <!-- Subtle decorative accent -->
      <div class="absolute top-0 left-0 w-full h-[2px]" style={`background: linear-gradient(90deg, ${accentColor}, transparent 60%)`} aria-hidden="true"></div>
      <div class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full blur-3xl opacity-20" style={`background-color: ${accentColor}`} aria-hidden="true"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid lg:grid-cols-2 gap-10 items-center">
          <!-- Hero bal oszlop (szöveg). Mobilon a termék/kép fölé kerül, ezért
               single/decision módban a szöveg order-2 (alulra), desktopon marad
               az eredeti elrendezés. -->
          <div class={
            heroMode === 'single' ? 'order-2 lg:order-2'
            : (heroMode === 'decision' || heroMode === 'duo') ? 'order-2 lg:order-1'
            : ''
          }>
            {category.badge && (
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-sm mb-4 border" style={`background-color: ${catColor.accentLight}; border-color: ${accentColor}; color: ${accentDark}`}>
                {category.badge}
              </div>
            )}
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-4">{category.name}</h1>
            <div class="w-12 h-[2px] rounded-full mb-4" style={`background-color: ${accentColor}`}></div>
            <p class="text-lg lg:text-xl text-gray-600 mb-6">
              {category.heroDescription || category.description}
            </p>

            {/* Egysoros chooser - csak decision módban, ha kapott adatot */}
            {(heroMode === 'decision' || heroMode === 'duo') && heroChooser && heroChooser.length > 0 && (
              <div class="flex flex-wrap gap-x-4 gap-y-1.5 mb-6 text-sm">
                {heroChooser.map((c) => (
                  <span class="inline-flex items-center gap-1.5 text-gray-700">
                    <span class="text-gray-500">{c.label}</span>
                    <svg class="w-3.5 h-3.5 flex-shrink-0" style={`color: ${accentDark}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                    <span class="font-semibold" style={`color: ${accentDark}`}>{c.target}</span>
                  </span>
                ))}
              </div>
            )}

            {/* Single módban a termék ajánlat-blokk (ár + havi + CTA) */}
            {heroMode === 'single' && heroProduct && (
              <div class="mb-6">
                <div class="text-sm font-semibold uppercase tracking-wide mb-1" style={`color: ${accentDark}`}>{heroProduct.data.name}</div>
                {heroProduct.data.price ? (
                  <div class="flex items-baseline gap-3 mb-4">
                    <span class="text-3xl font-bold text-gray-900">{huFmt.format(heroProduct.data.price)} Ft</span>
