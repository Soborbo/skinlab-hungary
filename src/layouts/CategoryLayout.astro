---
import BaseLayout from './BaseLayout.astro';
import { SITE, CONTACT } from '../lib/constants';
import OptimizedPicture from '../components/images/OptimizedPicture.astro';
import { hasImage, getImageAlt } from '@/lib/resolve-image';

interface ComparisonProduct {
  name: string;
  tag?: string;
  tagColor?: string;
  highlighted?: boolean;
  link?: string;
  specs: Record<string, string>;
}

interface Props {
  category: {
    name: string;
    nameShort: string;
    slug: string;
    description: string;
    heroDescription?: string;
    badge?: string;
    color?: string;
  };
  products?: any[];
  faq?: { question: string; answer: string }[];
  benefits?: { icon: string; title: string; description: string }[];
  comparison?: {
    features: string[];
    products: ComparisonProduct[];
  };
}

const { category, products = [], faq = [], benefits = [], comparison } = Astro.props;

// SVG icon paths for benefit icons (replaces emojis)
const benefitIcons: Record<string, string> = {
  // Trend / growth
  'trend-up': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />`,
  // Users / people
  'users': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />`,
  // Lightning / zap
  'zap': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
  // Target / crosshair
  'target': `<circle cx="12" cy="12" r="10" stroke-width="2" fill="none" /><circle cx="12" cy="12" r="6" stroke-width="2" fill="none" /><circle cx="12" cy="12" r="2" stroke-width="2" fill="none" />`,
  // Clock / timer
  'clock': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  // Money / coins
  'coins': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  // Package / box
  'package': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />`,
  // Check circle / verified
  'check-circle': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  // Refresh / sync
  'refresh': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />`,
  // Sparkles / magic
  'sparkles': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />`,
  // Microscope / research
  'microscope': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />`,
  // Rainbow / palette (colors)
  'palette': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />`,
  // Diamond / gem
  'gem': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3L2 9l10 12L22 9l-10-6z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2 9h20M12 3v6" />`,
  // Flame / fire
  'flame': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z" />`,
  // Muscle / strong
  'muscle': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />`,
  // Star / sparkle
  'star': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />`,
  // Battery / power
  'battery': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h14a2 2 0 012 2v6a2 2 0 01-2 2H4a2 2 0 01-2-2V9a2 2 0 012-2zm18 4v2" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11v2m3-2v2m3-2v2" />`,
  // Smartphone / mobile
  'smartphone': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />`,
  // Cog / settings
  'cog': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`,
  // Pencil / edit
  'pencil': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />`,
  // Volume off / mute
  'mute': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2" />`,
  // Wrench / tool
  'wrench': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`,
  // Trophy / award
  'trophy': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />`,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Főoldal", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": category.nameShort }
  ]
};

const colorClasses: Record<string, { gradient: string; badge: string }> = {
  blue: { gradient: 'from-blue-600 to-indigo-700', badge: 'bg-blue-500' },
  purple: { gradient: 'from-purple-600 to-pink-700', badge: 'bg-purple-500' },
  cyan: { gradient: 'from-cyan-600 to-blue-700', badge: 'bg-cyan-500' },
  amber: { gradient: 'from-amber-500 to-orange-600', badge: 'bg-amber-500' },
  green: { gradient: 'from-green-600 to-emerald-700', badge: 'bg-green-500' },
  rose: { gradient: 'from-rose-500 to-pink-600', badge: 'bg-rose-500' },
  teal: { gradient: 'from-teal-600 to-cyan-700', badge: 'bg-teal-500' },
  slate: { gradient: 'from-slate-600 to-gray-700', badge: 'bg-slate-500' },
  orange: { gradient: 'from-orange-500 to-red-600', badge: 'bg-orange-500' },
  indigo: { gradient: 'from-indigo-600 to-purple-700', badge: 'bg-indigo-500' },
  pink: { gradient: 'from-pink-500 to-rose-600', badge: 'bg-pink-500' },
  violet: { gradient: 'from-violet-600 to-purple-700', badge: 'bg-violet-500' },
  gray: { gradient: 'from-gray-500 to-slate-600', badge: 'bg-gray-500' },
};

const colors = colorClasses[category.color || 'blue'];
---

<BaseLayout
  title={category.name}
  description={category.description}
  schema={breadcrumbSchema}
>
  <div id="main-content">

    <!-- Breadcrumb -->
    <nav class="bg-white border-b" aria-label="Breadcrumb">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
        <ol class="flex items-center gap-2 text-sm">
          <li>
            <a href="/" class="text-gray-500 hover:text-primary-600">Főoldal</a>
          </li>
          <li class="text-gray-400">›</li>
          <li class="text-gray-900 font-medium">{category.nameShort}</li>
        </ol>
      </div>
    </nav>

    <!-- Category Hero -->
    <section class={`bg-gradient-to-r ${colors.gradient} py-12 lg:py-16 relative overflow-hidden`}>
      <!-- Background decoration -->
      <div class="absolute top-0 right-0 w-1/3 h-full bg-white/5" aria-hidden="true"></div>
      <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-white/10 rounded-full blur-3xl" aria-hidden="true"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid lg:grid-cols-2 gap-10 items-center">
          <div class="text-white">
            {category.badge && (
              <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur px-3 py-1 rounded-full text-sm mb-4">
                {category.badge}
              </div>
            )}
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4">{category.name}</h1>
            <p class="text-lg lg:text-xl text-white/90 mb-6">
              {category.heroDescription || category.description}
            </p>
            <div class="flex flex-wrap gap-3 text-sm">
              <span class="bg-white/20 backdrop-blur px-3 py-1.5 rounded-lg flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                2 év garancia
              </span>
              <span class="bg-white/20 backdrop-blur px-3 py-1.5 rounded-lg flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Ingyenes betanítás
              </span>
              <span class="bg-white/20 backdrop-blur px-3 py-1.5 rounded-lg flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Magyar szerviz
              </span>
              <span class="bg-white/20 backdrop-blur px-3 py-1.5 rounded-lg flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Részletfizetés
              </span>
            </div>
          </div>
          <div class="hidden lg:block">
            <div class="bg-white/10 backdrop-blur rounded-2xl aspect-video flex items-center justify-center">
              <div class="text-center p-8">
                <div class="w-16 h-16 mx-auto mb-3 rounded-2xl bg-white/20 flex items-center justify-center">
                  <svg class="w-8 h-8 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
                <p class="text-white/60 font-medium text-sm">Kategória kép / Videó</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Products Grid -->
    <section class="bg-gray-50 py-12 lg:py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Filter bar (placeholder) -->
        <div class="bg-white rounded-xl p-4 mb-8 shadow-sm border border-gray-100 flex flex-wrap items-center gap-4">
          <span class="text-gray-500 text-sm">Rendezés:</span>
          <select class="border border-gray-200 rounded-lg px-4 py-2 text-sm focus:border-primary-500 focus:outline-none">
            <option>Kiemelt</option>
            <option>Ár: Alacsony → Magas</option>
            <option>Ár: Magas → Alacsony</option>
          </select>
          <div class="flex-1"></div>
          <span class="text-gray-500 text-sm">{products.length} termék</span>
        </div>

        {products.length === 0 ? (
          <!-- Empty state -->
          <div class="text-center py-16">
            <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-gray-200 flex items-center justify-center">
              <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <h2 class="text-xl font-semibold text-gray-900 mb-2">Termékek hamarosan</h2>
            <p class="text-gray-600 mb-8">Ezen a kategórián dolgozunk. Kérj konzultációt, és személyesen bemutatjuk kínálatunkat.</p>
            <a
              href="/kapcsolat"
              class="inline-flex items-center px-6 py-3 bg-primary-600 text-white font-semibold rounded-xl hover:bg-primary-700"
            >
              Konzultáció kérése
            </a>
          </div>
        ) : (
          <!-- Products -->
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {products.map((product, index) => (
              <a
                href={`/${product.data.categorySlug}/${product.data.slug || product.id}`}
                class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 relative"
              >
                <!-- Badges -->
                <div class="absolute top-4 left-4 z-10 flex flex-col gap-2">
                  {product.data.featured && (
                    <span class="bg-red-500 text-white text-xs font-bold px-3 py-1 rounded-full">BESTSELLER</span>
                  )}
                  {product.data.hasVariants && (
                    <span class="bg-purple-500 text-white text-xs font-bold px-3 py-1 rounded-full">
                      {product.data.variants.length} szín
                    </span>
                  )}
                  {product.data.availability === 'in_stock' && (
                    <span class="bg-green-500 text-white text-xs font-bold px-3 py-1 rounded-full flex items-center gap-1">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                      Raktáron
                    </span>
                  )}
                  {product.data.availability === 'preorder' && (
                    <span class="bg-amber-500 text-white text-xs font-bold px-3 py-1 rounded-full">
                      Előrendelhető
                    </span>
                  )}
                </div>

                <!-- Image -->
                <div class="aspect-square bg-gradient-to-br from-gray-100 to-gray-200 relative overflow-hidden">
                  {hasImage(product.data.image) ? (
                    <OptimizedPicture
                      src={product.data.image}
                      alt={getImageAlt(product.data.image, product.data.name)}
                      widths={[320, 480, 640]}
                      sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading={index < 6 ? 'eager' : 'lazy'}
                    />
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center">
                      <div class="w-16 h-16 rounded-xl bg-white/80 flex items-center justify-center">
                        <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                      </div>
                    </div>
                  )}
                  <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors"></div>
                </div>

                <!-- Content -->
                <div class="p-6">
                  <h3 class="text-xl font-bold text-gray-900 mb-1 group-hover:text-primary-600 transition-colors">
                    {product.data.name}
                  </h3>
                  <p class="text-gray-600 text-sm mb-4 line-clamp-2">
                    {product.data.shortDescription || product.data.description?.slice(0, 100) + '...'}
                  </p>

                  <div class="flex items-end justify-between">
                    <div>
                      {product.data.price ? (
                        <>
                          <div class="text-xl font-bold text-gray-900">
                            {new Intl.NumberFormat('hu-HU').format(product.data.price)} Ft
                          </div>
                          <div class="text-green-600 text-sm font-medium">
                            vagy havi ~{new Intl.NumberFormat('hu-HU').format(Math.round(product.data.price / 12))} Ft
                          </div>
                        </>
                      ) : (
                        <div class="text-lg font-semibold text-primary-600">Kérjen ajánlatot</div>
                      )}
                    </div>
                    <div class="w-12 h-12 bg-primary-600 text-white rounded-xl flex items-center justify-center group-hover:bg-primary-700 transition-colors">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- Comparison Table (optional) -->
    {comparison && comparison.products.length > 0 && (
      <section class="bg-white py-12 lg:py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-10">
            <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-3">Melyiket válaszd?</h2>
            <p class="text-gray-600">Hasonlítsd össze a modelleket egy pillantással</p>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full min-w-[700px]">
              <thead>
                <tr class="border-b-2 border-gray-200">
                  <th class="text-left py-4 px-4 font-semibold text-gray-500 w-40">Jellemző</th>
                  {comparison.products.map((product) => (
                    <th class={`py-4 px-4 text-center ${product.highlighted ? 'bg-primary-50 rounded-t-xl' : ''}`}>
                      <div class={`font-bold ${product.highlighted ? 'text-primary-600' : 'text-gray-900'}`}>{product.name}</div>
                      {product.tag && (
                        <div class={`text-sm ${
                          product.tagColor === 'red' ? 'text-red-500' :
                          product.tagColor === 'orange' ? 'text-orange-500' :
                          product.tagColor === 'purple' ? 'text-purple-600' :
                          product.tagColor === 'blue' ? 'text-blue-600' :
                          'text-gray-500'
                        }`}>{product.tag}</div>
                      )}
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {comparison.features.map((feature) => (
                  <tr>
                    <td class="py-4 px-4 text-gray-600">{feature}</td>
                    {comparison.products.map((product) => (
                      <td class={`py-4 px-4 text-center ${product.highlighted ? 'bg-primary-50' : ''} ${
                        product.highlighted && product.specs[feature] ? 'font-semibold text-primary-600' : ''
                      }`}>
                        {product.specs[feature] === '✓' ? (
                          <span class="text-green-500">✓</span>
                        ) : product.specs[feature] === '✗' ? (
                          <span class="text-gray-400">✗</span>
                        ) : (
                          product.specs[feature] || '-'
                        )}
                      </td>
                    ))}
                  </tr>
                ))}
                <tr>
                  <td class="py-4 px-4"></td>
                  {comparison.products.map((product) => (
                    <td class={`py-4 px-4 text-center ${product.highlighted ? 'bg-primary-50 rounded-b-xl' : ''}`}>
                      {product.link ? (
                        <a
                          href={product.link}
                          class={`inline-block font-semibold text-sm px-4 py-2 rounded-lg transition-colors ${
                            product.highlighted
                              ? 'bg-primary-600 text-white hover:bg-primary-700'
                              : 'text-primary-600 hover:underline'
                          }`}
                        >
                          Részletek →
                        </a>
                      ) : (
                        <span class="text-primary-600 font-semibold text-sm hover:underline cursor-pointer">Részletek →</span>
                      )}
                    </td>
                  ))}
                </tr>
              </tbody>
            </table>
          </div>

          <div class="text-center mt-8">
            <p class="text-gray-500 mb-4">Nem tudod eldönteni? Segítünk!</p>
            <a
              href="/kapcsolat"
              class="inline-flex items-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold px-6 py-3 rounded-xl transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              Kérj személyes tanácsadást
            </a>
          </div>
        </div>
      </section>
    )}

    <!-- Benefits section (optional) -->
    {benefits.length > 0 && (
      <section class="bg-white py-12 lg:py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="grid lg:grid-cols-2 gap-12 items-center">
            <div>
              <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-6">
                Miért érdemes {category.nameShort.toLowerCase()}t választani?
              </h2>
              <div class="space-y-5">
                {benefits.map((benefit) => (
                  <div class="flex gap-4">
                    <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center flex-shrink-0">
                      {benefitIcons[benefit.icon] ? (
                        <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={benefitIcons[benefit.icon]} />
                      ) : (
                        <span class="text-2xl">{benefit.icon}</span>
                      )}
                    </div>
                    <div>
                      <h3 class="font-bold text-gray-900 mb-1">{benefit.title}</h3>
                      <p class="text-gray-600 text-sm">{benefit.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <div class="bg-gray-100 rounded-2xl aspect-square flex items-center justify-center">
              <p class="text-gray-400">Kép helye</p>
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- FAQ section (optional) -->
    {faq.length > 0 && (
      <section class="bg-gray-50 py-12 lg:py-16">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-10">
            <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-3">
              Gyakori kérdések
            </h2>
          </div>

          <div class="space-y-4">
            {faq.map((item, index) => (
              <details class="bg-white border border-gray-200 rounded-xl overflow-hidden group" open={index === 0}>
                <summary class="p-5 cursor-pointer flex items-center justify-between hover:bg-gray-50 font-semibold text-gray-900">
                  {item.question}
                  <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <div class="p-5 bg-gray-50 border-t text-gray-600" set:html={item.answer} />
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class={`bg-gradient-to-r ${colors.gradient} py-12 lg:py-16`}>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
        <h2 class="text-2xl lg:text-3xl font-bold mb-4">
          Nem tudod melyiket válaszd?
        </h2>
        <p class="text-lg text-white/90 mb-8">
          Kérj ingyenes konzultációt, és segítünk kiválasztani a szalonodnak megfelelő készüléket!
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/kapcsolat"
            class="bg-white text-gray-900 font-bold py-3 lg:py-4 px-6 lg:px-8 rounded-xl text-lg hover:bg-gray-100 transition-colors inline-flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Ingyenes bemutatót kérek
          </a>
          <a
            href={CONTACT.phoneTel}
            class="bg-white/20 backdrop-blur text-white font-bold py-3 lg:py-4 px-6 lg:px-8 rounded-xl text-lg hover:bg-white/30 transition-colors border-2 border-white/30 inline-flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {CONTACT.phoneDisplay}
          </a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
