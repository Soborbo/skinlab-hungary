                      <span class="text-green-600 font-medium">vagy havi ~{huFmt.format(monthlyTeaser(heroProduct.data.price)!)} Ft</span>
                    )}
                  </div>
                ) : (
                  <div class="text-xl font-semibold mb-4" style={`color: ${accentDark}`}>Kérjen ajánlatot</div>
                )}
                <div class="flex flex-col sm:flex-row gap-3">
                  <a href={productHref(heroProduct)} class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl font-semibold text-white shadow-sm hover:shadow-md transition-all" style={`background-color: ${accentDark}`}>
                    Részletek megtekintése
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                  </a>
                </div>
              </div>
