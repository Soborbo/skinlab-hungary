                  </span>
                </span>
              ))}
            </div>
          </div>

          <!-- Hero jobb oszlop (termék/kép). Mobilon ez kerül legfelülre
               (order-1), hogy egyből terméket lásson a látogató. -->
          <div class={
            heroMode === 'single' ? 'order-1 lg:order-1'
            : (heroMode === 'decision' || heroMode === 'duo') ? 'order-1 lg:order-2'
            : ''
          }>
            {heroMode === 'single' && heroProduct ? (
              <!-- SINGLE: nagy termékfotó -->
              <div class="relative aspect-square rounded-3xl overflow-hidden flex items-center justify-center p-8 lg:p-12" style={`background: linear-gradient(135deg, ${catColor.accentLight} 0%, white 70%)`}>
                <div class="absolute -top-10 -right-10 w-48 h-48 rounded-full blur-3xl opacity-30" style={`background-color: ${accentColor}`} aria-hidden="true"></div>
                {hasImage(heroProduct.data.image) ? (
                  <OptimizedPicture
                    src={heroProduct.data.image}
                    alt={getImageAlt(heroProduct.data.image, heroProduct.data.name)}
                    widths={[480, 640, 800]}
                    sizes="(min-width: 1024px) 45vw, 90vw"
                    class="relative z-10 w-full h-full object-contain"
                    loading="eager"
                  />
                ) : (
                  <div class="relative z-10 w-20 h-20 rounded-2xl bg-white/70 flex items-center justify-center">
                    <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  </div>
                )}
              </div>
            ) : heroMode === 'duo' ? (
              <!-- DUO: két termék EGYMÁS MELLETT, nagy képpel (több látszik a képből) -->
              <div class="grid grid-cols-2 gap-3 sm:gap-4">
                {products.map((p) => (
                  <a
                    href={productHref(p)}
                    class="prod-card group flex flex-col bg-white rounded-2xl p-3"
                    style={`--card-accent: ${accentColor}; --card-accent-dark: ${accentDark}`}
                  >
                    <div class="aspect-square rounded-xl overflow-hidden flex items-center justify-center mb-3" style={`background-color: ${catColor.accentLight}`}>
                      {hasImage(p.data.image) ? (
                        <OptimizedPicture
                          src={p.data.image}
                          alt={getImageAlt(p.data.image, p.data.name)}
                          widths={[320, 480, 640]}
                          sizes="(min-width: 1024px) 22vw, 45vw"
                          class="w-full h-full object-contain p-3 group-hover:scale-105 transition-transform duration-500"
                          loading="eager"
                        />
                      ) : (
                        <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                      )}
                    </div>
                    <div class="font-bold text-gray-900 group-hover:text-primary-600 transition-colors line-clamp-2">{p.data.name}</div>
                    {p.data.price ? (
                      <div class="mt-1">
                        <div class="font-bold text-gray-900">{huFmt.format(p.data.price)} Ft</div>
                        {monthlyTeaser(p.data.price) && (
                          <span class="text-green-600 text-xs font-medium">havi ~{huFmt.format(monthlyTeaser(p.data.price)!)} Ft</span>
                        )}
                      </div>
                    ) : (
                      <div class="mt-1 text-sm font-semibold" style={`color: ${accentDark}`}>Kérjen ajánlatot</div>
                    )}
                    <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold" style={`color: ${accentDark}`}>
                      Részletek
                      <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </span>
                  </a>
                ))}
              </div>
            ) : heroMode === 'decision' ? (
              <!-- DECISION: a tényleges termékek kompakt döntő-kártyaként -->
              <div class="space-y-3">
                {products.map((p) => (
                  <a
                    href={productHref(p)}
                    class="prod-card group flex items-center gap-4 bg-white rounded-2xl p-3"
                    style={`--card-accent: ${accentColor}; --card-accent-dark: ${accentDark}`}
                  >
                    <div class="w-20 h-20 lg:w-24 lg:h-24 flex-shrink-0 rounded-xl overflow-hidden flex items-center justify-center" style={`background-color: ${catColor.accentLight}`}>
                      {hasImage(p.data.image) ? (
                        <OptimizedPicture
                          src={p.data.image}
                          alt={getImageAlt(p.data.image, p.data.name)}
                          widths={[96, 192]}
                          sizes="96px"
                          class="w-full h-full object-contain p-1.5 group-hover:scale-105 transition-transform"
                          loading="eager"
                        />
                      ) : (
                        <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                      )}
                    </div>
                    <div class="min-w-0 flex-1">
                      <div class="font-bold text-gray-900 group-hover:text-primary-600 transition-colors truncate">{p.data.name}</div>
                      {p.data.shortDescription && (
                        <p class="text-gray-500 text-sm line-clamp-1">{p.data.shortDescription}</p>
                      )}
                      {p.data.price ? (
                        <div class="mt-1 flex items-baseline gap-2">
                          <span class="font-bold text-gray-900">{huFmt.format(p.data.price)} Ft</span>
                          {monthlyTeaser(p.data.price) && (
                            <span class="text-green-600 text-xs font-medium">havi ~{huFmt.format(monthlyTeaser(p.data.price)!)} Ft</span>
                          )}
                        </div>
                      ) : (
                        <div class="mt-1 text-sm font-semibold" style={`color: ${accentDark}`}>Kérjen ajánlatot</div>
                      )}
                    </div>
                    <svg class="w-5 h-5 text-gray-300 group-hover:text-primary-600 flex-shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  </a>
                ))}
              </div>
            ) : (
              <!-- CLASSIC: eredeti viselkedés (founder-kártya vagy placeholder) -->
              <div class="hidden lg:block">
                {expert ? (
                  <CategoryConsultationCard
                    expert={expert}
                    ctaHref={resolvedCtaHref}
                    socialProof={consultationSocialProof}
                    accentColor={accentColor}
                    accentDark={accentDark}
                    accentLight={catColor.accentLight}
                  />
                ) : (
                  <div class="bg-white/10 backdrop-blur rounded-2xl aspect-video flex items-center justify-center">
                    <div class="text-center p-8">
                      <div class="w-16 h-16 mx-auto mb-3 rounded-2xl bg-white/20 flex items-center justify-center">
                        <svg class="w-8 h-8 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                      </div>
                      <p class="text-white/60 font-medium text-sm">Kategória kép / Videó</p>
                    </div>
                  </div>
                )}
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    {/* Founder "Kérjen ingyenes konzultációt" szekció - kép-bal / szöveg-jobb,
        kiszervezve a FounderConsult komponensbe (a termékoldal is ezt használja). */}
    {showFounderSection && (
      <FounderConsult expert={resolvedExpert} ctaHref={resolvedCtaHref} eventPrefix="category" />
    )}

    <!-- Products Grid (csak classic módban; single/decision a hero-ban mutatja) -->
    {showStandaloneGrid && (
    <section class="bg-gray-50 py-12 lg:py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        {/* Filter bar - kommentbe rakva, mert kevés termék van kategóriánként. Visszahelyezhető, ha bővül a katalógus.
        <div class="bg-white rounded-xl p-4 mb-8 shadow-sm border border-gray-100 flex flex-wrap items-center gap-4">
          <span class="text-gray-500 text-sm">Rendezés:</span>
          <select class="border border-gray-200 rounded-lg px-4 py-2 text-sm focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500">
            <option>Kiemelt</option>
            <option>Ár: Alacsony → Magas</option>
            <option>Ár: Magas → Alacsony</option>
          </select>
          <div class="flex-1"></div>
          <span class="text-gray-500 text-sm">{products.length} termék</span>
        </div>
        */}

        {products.length === 0 ? (
          <!-- Empty state -->
          <div class="text-center py-16">
            <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-gray-200 flex items-center justify-center">
              <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <h2 class="text-xl font-semibold text-gray-900 mb-2">Termékek hamarosan</h2>
            <p class="text-gray-600 mb-8">Ezen a kategórián dolgozunk. Kérj konzultációt, és személyesen bemutatjuk kínálatunkat.</p>
            <a
              href="/konzultacio/"
              class="inline-flex items-center px-6 py-3 bg-primary-700 text-white font-semibold rounded-xl hover:bg-primary-800"
            >
              Konzultáció kérése
            </a>
          </div>
        ) : (
          <!-- Products -->
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {products.map((product, index) => (
              <div
                class="prod-card group bg-white rounded-2xl overflow-hidden relative flex flex-col"
                style={`--card-accent: ${accentColor}; --card-accent-dark: ${accentDark}`}
              >
                <!-- Badges -->
                <div class="absolute top-4 left-4 z-10 flex flex-col gap-2">
                  {product.data.hasVariants && (
                    <span class="bg-purple-500 text-white text-xs font-bold px-3 py-1 rounded-full">
                      {product.data.variants.length} szín
                    </span>
                  )}
                </div>

                <a
                  href={productHref(product)}
                  class="flex flex-col flex-1"
                >
                  <!-- Image -->
                  <div class="aspect-square bg-white relative overflow-hidden">
                    {hasImage(product.data.image) ? (
                      <OptimizedPicture
                        src={product.data.image}
                        alt={getImageAlt(product.data.image, product.data.name)}
                        widths={[320, 480, 640]}
                        sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
                        class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-500"
                        loading={index < 6 ? 'eager' : 'lazy'}
                      />
                    ) : (
                      <div class="absolute inset-0 flex items-center justify-center">
                        <div class="w-16 h-16 rounded-xl bg-white/80 flex items-center justify-center">
                          <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                          </svg>
                        </div>
                      </div>
                    )}
                    <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors"></div>
                  </div>

                  <!-- Content -->
                  <div class="p-6 flex flex-col flex-1">
                    <h3 class="text-xl font-bold text-gray-900 mb-1 group-hover:text-primary-600 transition-colors">
                      {product.data.name}
                    </h3>
                    <p class="text-gray-600 text-sm mb-4 line-clamp-2">
                      {product.data.shortDescription || product.data.description?.slice(0, 100) + '...'}
                    </p>

                    <div class="mt-auto">
                      {product.data.price ? (
                        <>
                          <div class="text-xl font-bold text-gray-900">
                            {new Intl.NumberFormat('hu-HU').format(product.data.price)} Ft
                          </div>
                          {monthlyTeaser(product.data.price) && (
                            <div class="text-green-600 text-sm font-medium">
                              vagy havi ~{huFmt.format(monthlyTeaser(product.data.price)!)} Ft
                            </div>
                          )}
                        </>
                      ) : (
                        <div class="text-lg font-semibold text-primary-600">Kérjen ajánlatot</div>
                      )}
                    </div>
                  </div>
                </a>

                <!-- Kosárba gomb -->
                <div class="px-6 pb-6">
                  <QuickAddButton
                    locale={pageLocale}
                    slug={product.data.slug || product.id}
                    sku={product.data.sku}
                    name={product.data.name}
                    categorySlug={product.data.categorySlug}
                    image={product.data.image}
                    price={product.data.price}
                    class="w-full"
                  />
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
    )}

    <!-- "Melyiket válaszd?" - rich choices + comparison table (optional) -->
    {showChoicesSection && (
      <section class="bg-white py-12 lg:py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-10">
            <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-3">{choicesHeading || 'Melyiket válaszd?'}</h2>
            <p class="text-gray-600">{choicesSubheading || 'Hasonlítsd össze a modelleket egy pillantással'}</p>
            {choicesIntro && (
              <p class="text-gray-700 max-w-3xl mx-auto mt-6 text-base lg:text-lg leading-relaxed">{choicesIntro}</p>
            )}
          </div>

          {hasChoices && (
            <div class="space-y-16 lg:space-y-24 mb-16 lg:mb-20">
              {choices.map((choice, idx) => (
                <article class={`grid lg:grid-cols-2 gap-8 lg:gap-12 items-center ${idx % 2 === 1 ? 'lg:[&>.choice-image]:order-2' : ''}`}>
                  <div class="choice-image">
                    <div class="relative aspect-square rounded-3xl overflow-hidden flex items-center justify-center p-6 lg:p-10" style={`background: linear-gradient(135deg, ${catColor.accentLight} 0%, white 70%)`}>
                      <div class="absolute -top-10 -right-10 w-48 h-48 rounded-full blur-3xl opacity-30" style={`background-color: ${accentColor}`} aria-hidden="true"></div>
                      <OptimizedPicture
                        src={choice.image}
                        alt={choice.imageAlt || `${choice.name} diódalézer`}
                        widths={[480, 640, 800]}
                        sizes="(min-width: 1024px) 40vw, 90vw"
                        class="relative z-10 w-full h-full object-contain"
                        loading="lazy"
                      />
                    </div>
                  </div>
                  <div class="choice-content">
                    <h3 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-2">
                      <span style={`color: ${accentDark}`}>{choice.name}</span>
                      <span class="text-gray-500 font-semibold text-2xl lg:text-3xl"> - {choice.subtitle}</span>
                    </h3>
                    {choice.tagline && (
                      <p class="italic text-lg text-gray-600 mb-5 border-l-2 pl-4" style={`border-color: ${accentColor}`}>„{choice.tagline}"</p>
                    )}
                    <p class="text-gray-700 leading-relaxed mb-5">{choice.intro}</p>

                    {choice.pillars && choice.pillars.length > 0 && (
                      <ul class="space-y-2 mb-6">
                        {choice.pillars.map((pillar) => (
                          <li class="flex items-start gap-2 text-gray-700">
                            <svg class="w-5 h-5 mt-0.5 flex-shrink-0" style={`color: ${accentDark}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                            </svg>
                            <span>{pillar}</span>
                          </li>
                        ))}
                      </ul>
                    )}

                    {choice.when && choice.when.length > 0 && (
                      <div class="mb-6">
                        {choice.whenTitle && (
                          <h4 class="text-lg font-bold text-gray-900 mb-3">{choice.whenTitle}</h4>
                        )}
                        <ol class="space-y-3">
                          {choice.when.map((item, i) => (
                            <li class="flex gap-3">
                              <span class="flex-shrink-0 w-7 h-7 rounded-full flex items-center justify-center text-sm font-bold text-white" style={`background-color: ${accentDark}`}>{i + 1}</span>
                              <div>
                                <div class="font-semibold text-gray-900">{item.title}</div>
                                <div class="text-gray-600 text-sm leading-relaxed">{item.description}</div>
                              </div>
                            </li>
                          ))}
                        </ol>
                      </div>
                    )}

                    {choice.notes && choice.notes.length > 0 && (
                      <div class="space-y-3 mb-6 text-gray-700 leading-relaxed">
                        {choice.notes.map((note) => (
                          <p>{note}</p>
                        ))}
                      </div>
                    )}

                    {choice.closing && (
                      <p class="text-gray-900 font-semibold italic mb-6">{choice.closing}</p>
                    )}

                    <a
                      href={withTrailingSlash(choice.link)}
                      class="inline-flex items-center gap-2 font-semibold px-5 py-3 rounded-xl text-white shadow-sm hover:shadow-md transition-all"
                      style={`background-color: ${accentDark}`}
                    >
                      {choice.ctaLabel || `${choice.name} részletei`}
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                      </svg>
                    </a>
                  </div>
                </article>
              ))}
            </div>
          )}

          {choicesClosing && (
            <div class="max-w-3xl mx-auto text-center mb-12 lg:mb-16">
              <p class="text-lg text-gray-700 leading-relaxed">{choicesClosing}</p>
            </div>
          )}
        </div>

        {comparison && comparison.products.length > 0 && (
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          {hasChoices && (
            <div class="text-center mb-8">
              <h3 class="text-xl lg:text-2xl font-bold text-gray-900 mb-2">Műszaki összehasonlítás</h3>
              <p class="text-gray-600">Egy pillantás alatt a fő paraméterek</p>
            </div>
          )}
          <div class="overflow-x-auto">
            <table class="w-full min-w-[700px]">
              <thead>
                <tr class="border-b-2 border-gray-200">
                  <th class="text-left py-4 px-4 font-semibold text-gray-500 w-40">Jellemző</th>
                  {comparison.products.map((product) => (
                    <th class={`py-4 px-4 text-center ${product.highlighted ? 'bg-primary-50 rounded-t-xl' : ''}`}>
                      <div class={`font-bold ${product.highlighted ? 'text-primary-600' : 'text-gray-900'}`}>{product.name}</div>
                      {product.tag && (
                        <div class={`text-sm ${
                          product.tagColor === 'red' ? 'text-red-500' :
                          product.tagColor === 'orange' ? 'text-orange-500' :
                          product.tagColor === 'purple' ? 'text-purple-600' :
                          product.tagColor === 'blue' ? 'text-blue-600' :
                          'text-gray-500'
                        }`}>{product.tag}</div>
                      )}
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {comparison.features.map((feature) => (
                  <tr>
                    <td class="py-4 px-4 text-gray-600">{feature}</td>
                    {comparison.products.map((product) => (
                      <td class={`py-4 px-4 text-center ${product.highlighted ? 'bg-primary-50' : ''} ${
                        product.highlighted && product.specs[feature] ? 'font-semibold text-primary-600' : ''
                      }`}>
                        {product.specs[feature] === '✓' ? (
                          <span class="text-green-500">✓</span>
                        ) : product.specs[feature] === '✗' ? (
                          <span class="text-gray-400">✗</span>
                        ) : (
                          product.specs[feature] || '-'
                        )}
                      </td>
                    ))}
                  </tr>
                ))}
                <tr>
                  <td class="py-4 px-4"></td>
                  {comparison.products.map((product) => (
                    <td class={`py-4 px-4 text-center ${product.highlighted ? 'bg-primary-50 rounded-b-xl' : ''}`}>
                      {product.link ? (
                        <a
                          href={withTrailingSlash(product.link)}
                          class={`inline-block font-semibold text-sm px-4 py-2 rounded-lg transition-colors ${
                            product.highlighted
                              ? 'bg-primary-600 text-white hover:bg-primary-700'
                              : 'text-primary-600 hover:underline'
                          }`}
                        >
                          Részletek →
                        </a>
                      ) : (
                        <span class="text-primary-600 font-semibold text-sm hover:underline cursor-pointer">Részletek →</span>
                      )}
                    </td>
                  ))}
                </tr>
              </tbody>
            </table>
          </div>

          <div class="text-center mt-8">
            <p class="text-gray-500 mb-4">Nem tudod eldönteni? Segítünk!</p>
            <a
              href="/konzultacio/"
              class="inline-flex items-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold px-6 py-3 rounded-xl transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
              </svg>
              Kérj személyes tanácsadást
            </a>
          </div>
        </div>
        )}
      </section>
    )}

    <!-- Benefits section (optional) -->
    {benefits.length > 0 && (
      <section class="bg-white py-12 lg:py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="grid lg:grid-cols-2 gap-12 items-center">
            <div>
              <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-6">
                {resolvedBenefitsHeading}
              </h2>
              <div class="space-y-5">
                {benefits.map((benefit) => (
                  <div class="flex gap-4">
                    <div class="w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center flex-shrink-0">
                      {benefitIcons[benefit.icon] ? (
                        <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={benefitIcons[benefit.icon]} />
                      ) : (
                        <span class="text-2xl">{benefit.icon}</span>
                      )}
                    </div>
                    <div>
                      <h3 class="font-bold text-gray-900 mb-1">{benefit.title}</h3>
                      <p class="text-gray-600 text-sm">{benefit.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            {benefitsImage ? (
              <div class="relative rounded-2xl aspect-square overflow-hidden shadow-sm">
                <Image
                  src={benefitsImage}
                  alt={benefitsImageAlt || `${category.nameShort} használat közben`}
                  widths={[480, 640, 800]}
                  sizes="(min-width: 1024px) 45vw, 90vw"
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="bg-gray-100 rounded-2xl aspect-square flex items-center justify-center">
                <p class="text-gray-400">Kép helye</p>
              </div>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- FAQ section (optional) -->
    {faq.length > 0 && (
      <section class="bg-gray-50 py-12 lg:py-16">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="text-center mb-10">
            <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-3">
              Gyakori kérdések
            </h2>
          </div>

          <div class="space-y-4">
            {faq.map((item, index) => (
              <details class="bg-white border border-gray-200 rounded-xl overflow-hidden group" open={index === 0}>
                <summary class="p-5 cursor-pointer flex items-center justify-between hover:bg-gray-50 font-semibold text-gray-900">
                  {item.question}
                  <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <div class="p-5 bg-gray-50 border-t text-gray-600" set:html={item.answer} />
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* Záró CTA - csak akkor, ha NINCS founder-szekció (classic mód).
        Decision/single módban a founder-szekció már tartalmazza ugyanezt a "kérj konzultációt" üzenetet, ne duplikáljuk. */}
    {!showFounderSection && (
    <section class="py-12 lg:py-16 relative overflow-hidden" style={`background: linear-gradient(135deg, ${catColor.accentLight} 0%, white 50%, ${catColor.accentLight} 100%)`}>
      <div class="absolute top-0 left-0 right-0 h-[2px]" style={`background: linear-gradient(90deg, transparent, ${accentColor}, transparent)`} aria-hidden="true"></div>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-4">
          Nem tudod melyiket válaszd?
        </h2>
        <p class="text-lg text-gray-600 mb-8">
          Kérj ingyenes konzultációt, és segítünk kiválasztani a szalonodnak megfelelő készüléket!
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/konzultacio/"
            class="font-bold py-3 lg:py-4 px-6 lg:px-8 rounded-xl text-lg transition-all inline-flex items-center justify-center gap-2 text-white shadow-lg hover:shadow-xl bg-primary-700 hover:bg-primary-800"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Ingyenes bemutatót kérek
          </a>
          <a
            href={CONTACT.phoneTel}
            class="font-bold py-3 lg:py-4 px-6 lg:px-8 rounded-xl text-lg transition-all border-2 inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50"
            style={`border-color: ${accentColor}; color: ${accentDark}`}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {CONTACT.phoneDisplay}
          </a>
        </div>
      </div>
    </section>
    )}

  </div>

  <!-- E-commerce: view_item_list data -->
  {products.length > 0 && (
    <script
      is:inline
      define:vars={{
        trackListId: category.slug,
        trackListName: category.nameShort,
        trackItems: products.map((p: any, i: number) => ({
          item_id: p.data.sku || p.id,
          item_name: p.data.name,
          item_category: category.slug,
          price: p.data.salePrice || p.data.price || 0,
          index: i,
        })),
      }}
    >
      window.__trackCategoryData = { listId: trackListId, listName: trackListName, items: trackItems };
    </script>
  )}

  <script>
    import { trackViewItemList, trackSelectItem } from '@/lib/tracking';

    function fireCategoryTracking() {
      const data = (window as any).__trackCategoryData;
      if (!data) return;

      trackViewItemList(data.listId, data.listName, data.items);

      // Track product card clicks
      document.querySelectorAll<HTMLAnchorElement>('[data-tracked-form] a, .grid a[href*="/"]').forEach((link, i) => {
        if (link.dataset.trackBound) return;
        link.dataset.trackBound = '1';
        const item = data.items[i];
        if (!item) return;
        link.addEventListener('click', () => {
          trackSelectItem(data.listId, data.listName, item);
        });
      });

      delete (window as any).__trackCategoryData;
    }

    document.addEventListener('astro:page-load', fireCategoryTracking);
    if (document.readyState !== 'loading') fireCategoryTracking();
  </script>
</BaseLayout>

<style>
  /* Termékkártya-kiemelés: accent-keret + színezett árnyék, hover-emelés és
     finom, eltolt ütemű lebegés — hogy a kártyák elemelkedjenek és a szemet
     odahúzzák. A lebegés `translate`-et, a hover `scale`-t használ (külön CSS
     tulajdonságok), így nem írják felül egymást. */
  .prod-card {
    border: 2px solid var(--card-accent, #e5e7eb);
    box-shadow: 0 6px 18px -8px var(--card-accent, rgba(0, 0, 0, 0.15));
    transition: box-shadow 0.35s ease, border-color 0.35s ease, scale 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    animation: prod-float 4.5s ease-in-out infinite;
    will-change: translate;
  }

  .prod-card:nth-child(2) { animation-delay: 0.6s; }
  .prod-card:nth-child(3) { animation-delay: 1.2s; }
  .prod-card:nth-child(4) { animation-delay: 1.8s; }

  .prod-card:hover {
    scale: 1.03;
    border-color: var(--card-accent-dark, #9ca3af);
    box-shadow: 0 24px 48px -12px var(--card-accent, rgba(0, 0, 0, 0.25));
  }

  @keyframes prod-float {
    0%, 100% { translate: 0 0; }
    50% { translate: 0 -5px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .prod-card {
      animation: none;
    }
    .prod-card:hover {
      scale: 1;
    }
  }
</style>
