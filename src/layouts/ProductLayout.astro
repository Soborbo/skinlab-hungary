---
/**
 * ProductLayout - Unified product page layout
 *
 * Section order:
 * Breadcrumb → Hero → Stats → ROI → VideoDescription → CTA(light) →
 * FeatureRows → CTA(accent) → Training → Testimonials → Expert →
 * TechSpecs → FunctionCards → FAQ → BuyerChecklist →
 * WhatsIncluded → Warranty → CTA(primary) → Related
 *
 * All sections are standalone components - zero inline HTML.
 * i18n-aware: uses loadProductContent for locale-specific content,
 * t() for UI chrome, getLocalizedUrl for links.
 */

import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/product/Breadcrumb.astro';
import ProductHero from '../components/product/ProductHero.astro';
import ProductGallerySection from '../components/product/ProductGallerySection.astro';
import FounderConsult from '../components/cta/FounderConsult.astro';
import ROICalculator from '../components/product/ROICalculator.astro';
import VideoDescription from '../components/product/VideoDescription.astro';
import ProductCTA from '../components/product/ProductCTA.astro';
import FeatureRows from '../components/product/FeatureRows.astro';
import TrainingCard from '../components/product/TrainingCard.astro';
import Testimonials from '../components/product/Testimonials.astro';
import ExpertQuote from '../components/product/ExpertQuote.astro';
import TechSpecs from '../components/product/TechSpecs.astro';
import FunctionCards from '../components/product/FunctionCards.astro';
import WhatsIncluded from '../components/product/WhatsIncluded.astro';
import BuyerChecklist from '../components/product/BuyerChecklist.astro';
import ProductFAQ from '../components/product/ProductFAQ.astro';
import WarrantyService from '../components/product/WarrantyService.astro';
import RelatedProducts from '../components/product/RelatedProducts.astro';
import VariantDetails from '../components/product/VariantDetails.astro';
import USPStrip from '../components/product/USPStrip.astro';
import InstallmentCalculator from '../components/product/InstallmentCalculator.astro';
import { INSTALLMENT_MIN } from '@/lib/installment';
// Schema components
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
import FAQSchema from '../components/schema/FAQSchema.astro';
import { SITE, CATEGORIES } from '../lib/constants';
import { getLocaleFromUrl, t, getLocalizedUrl } from '@/i18n';
import { loadProductContent } from '@/lib/load-product-content';
import { getOgImagePath } from '@/lib/resolve-image';
import type { ProductContentFAQItem } from '@/lib/types/product-content';

interface Variant {
  sku: string;
  name: string;
  value: string;
  price: number | null;
  image?: string;
  images?: string[];
  description?: string;
  specs?: Record<string, string>;
}

interface Stat {
  value: string;
  unit?: string;
  label: string;
  icon?: string;
}

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  product: {
    name: string;
    sku: string;
    slug: string;
    categorySlug: string;
    description: string;
    shortDescription: string;
    price: number | null;
    salePrice?: number | null;
    image: string;
    gallery: string[];
    extraImages?: string[];
    canonicalSlug?: string;
    youtubeVideos?: string[];
    availability: 'in_stock' | 'preorder' | 'out_of_stock';
    hasVariants: boolean;
    variants: Variant[];
    featured?: boolean;
    metaTitle?: string;
    metaDescription?: string;
    stats?: Stat[];
    faq?: FAQItem[];
    whatsIncluded?: string[];
    specs?: Record<string, string>;
  };
}

const { product } = Astro.props;

// Determine locale from URL
const locale = getLocaleFromUrl(Astro.url);

// Load localized product content (cascades: product JSON → category JSON → undefined)
const { content } = loadProductContent(locale, product.slug, product.categorySlug);

// Resolve content with fallbacks to collection data
const displayName = content.name || product.name;
const displayShortDesc = content.shortDescription || product.shortDescription;
const displayDesc = content.description || product.description;
const resolvedFaq = (content.faq || product.faq || []) as ProductContentFAQItem[];
const resolvedWhatsIncluded = content.whatsIncluded || product.whatsIncluded || [];
const resolvedSpecs = content.specs || product.specs || {} as Record<string, string>;
const resolvedTestimonials = content.testimonials || [];
const resolvedExpertQuote = content.expertQuote;
const resolvedFunctionCards = content.functionCards || [];

// Find category info
const category = CATEGORIES.find(c => c.slug === product.categorySlug);
const categoryName = category?.nameShort || product.categorySlug;

// Page URL (trailing slash to match the served/canonical URL).
// NB: the slash is concatenated, not placed inside the template literal — a
// `}/` immediately before a closing backtick trips the Astro compiler's
// frontmatter tokenizer (it misreads the `/` as a regex start).
const pageUrl = SITE.url + getLocalizedUrl(locale, `/${product.categorySlug}/${product.slug}`) + '/';

// Canonical override: spin-off/duplicate products (e.g. a limited-edition colour
// that is also a variant of the canonical product) point to the canonical slug.
const canonicalOverride = product.canonicalSlug
  ? `${SITE.url}${getLocalizedUrl(locale, `/${product.categorySlug}/${product.canonicalSlug}`)}`
  : undefined;

// Breadcrumb items for schema
const breadcrumbItems = [
  { name: t(locale, 'breadcrumb.home'), url: SITE.url + '/' },
  { name: categoryName, url: SITE.url + getLocalizedUrl(locale, `/${product.categorySlug}`) + '/' },
  { name: displayName }
];

// Extract first YouTube video URL
const firstVideoUrl = product.youtubeVideos?.[0] || '';


// Installment calculator: HU only, and only above the installment minimum
const showInstallment = locale === 'hu' && !!product.price && product.price > INSTALLMENT_MIN;

// FAQ questions for schema (if available)
const faqQuestions = resolvedFaq.map(item => ({
  question: item.question,
  answer: item.answer
}));

// Build variant image sets (only if variants have per-variant images)
const variantImageSets = product.hasVariants && product.variants.some(v => v.images && v.images.length > 0)
  ? product.variants
      .filter(v => v.images && v.images.length > 0)
      .map(v => ({ value: v.value, images: v.images! }))
  : undefined;

// OG image - use the product's main image
const ogImage = getOgImagePath(product.image) || '/og-image.jpg';

// Aggregate rating + reviews from testimonials → rich snippets (schema.org)
const ratedTestimonials = (resolvedTestimonials as any[]).filter((tm) => typeof tm.rating === 'number' && tm.rating > 0);
const toIsoDate = (d?: string): string | null => {
  const m = String(d || '').match(/(\d{4})\.\s*(\d{1,2})\.\s*(\d{1,2})/);
  return m ? `${m[1]}-${m[2].padStart(2, '0')}-${m[3].padStart(2, '0')}` : null;
};
const stripHtml = (str?: string) => String(str || '').replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim();
const aggregateRating = ratedTestimonials.length > 0 ? {
  "@type": "AggregateRating",
  "ratingValue": (ratedTestimonials.reduce((sum, tm) => sum + tm.rating, 0) / ratedTestimonials.length).toFixed(1),
  "reviewCount": String(ratedTestimonials.length),
  "bestRating": "5",
  "worstRating": "1",
} : null;
const reviewSchema = ratedTestimonials.map((tm) => {
  const iso = toIsoDate(tm.date);
  return {
    "@type": "Review",
    "author": { "@type": "Person", "name": tm.name },
    ...(iso ? { "datePublished": iso } : {}),
    "reviewRating": { "@type": "Rating", "ratingValue": String(tm.rating), "bestRating": "5", "worstRating": "1" },
    "reviewBody": stripHtml(tm.text),
  };
});

// Offer price validity end of next year.
const priceValidUntil = `${new Date().getFullYear() + 1}-12-31`;

// Product schema
const productSchema = product.price ? {
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": `${pageUrl}#product`,
  "name": displayName,
  "description": displayShortDesc || displayDesc?.slice(0, 200),
  "sku": product.sku,
  "brand": { "@type": "Brand", "name": "Skinlab" },
  "image": [new URL(ogImage, SITE.url).href],
  "offers": {
    "@type": "Offer",
    "url": pageUrl,
    "priceCurrency": "HUF",
    "price": String(product.salePrice || product.price),
    "priceValidUntil": priceValidUntil,
    "availability": product.availability === 'in_stock'
      ? "https://schema.org/InStock"
      : product.availability === 'preorder'
        ? "https://schema.org/PreOrder"
        : "https://schema.org/OutOfStock",
    "seller": { "@type": "Organization", "@id": `${SITE.url}#organization`, "name": "Skinlab Hungary" },
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 14,
      "returnMethod": "https://schema.org/ReturnByMail"
    },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingRate": {
        "@type": "MonetaryAmount",
        "value": "0",
        "currency": "HUF"
      },
      "shippingDestination": {
        "@type": "DefinedRegion",
        "addressCountry": "HU"
      },
      "deliveryTime": {
        "@type": "ShippingDeliveryTime",
        "handlingTime": {
          "@type": "QuantitativeValue",
          "minValue": 1,
          "maxValue": 3,
          "unitCode": "DAY"
        },
        "transitTime": {
          "@type": "QuantitativeValue",
          "minValue": 10,
          "maxValue": 20,
          "unitCode": "DAY"
        }
      }
    }
  },
  ...(aggregateRating ? { "aggregateRating": aggregateRating, "review": reviewSchema } : {})
} : null;
---

<BaseLayout
  title={content.metaTitle || product.metaTitle || displayName}
  description={content.metaDescription || product.metaDescription || displayShortDesc || displayDesc?.slice(0, 160)}
  image={ogImage}
  schema={productSchema}
  canonicalOverride={canonicalOverride}
>
  <!-- E-commerce: view_item data for tracking -->
  <div id="track-view-item"
    data-item-id={product.sku}
    data-item-name={displayName}
    data-item-category={product.categorySlug}
    data-item-price={String(product.salePrice || product.price || 0)}
    style="display:none"
  ></div>
  <!-- Schema.org Structured Data -->
  <BreadcrumbSchema items={breadcrumbItems} currentUrl={pageUrl} />
  {faqQuestions.length > 0 && <FAQSchema url={pageUrl} questions={faqQuestions} />}

  <div>

    <!-- 0. BREADCRUMB -->
    <Breadcrumb
      locale={locale}
      categorySlug={product.categorySlug}
      categoryName={categoryName}
      productName={displayName}
    />

    <!-- 1. HERO SECTION -->
    <ProductHero
      locale={locale}
      slug={product.slug}
      name={displayName}
      sku={product.sku}
      shortDescription={displayShortDesc}
      description={displayDesc}
      price={product.price}
      salePrice={product.salePrice}
      image={product.image}
      gallery={product.gallery}
      availability={product.availability}
      hasVariants={product.hasVariants}
      variants={product.variants}
      featured={product.featured}
      categorySlug={product.categorySlug}
      variantImageSets={variantImageSets}
    />

    <!-- 1.1. USP STRIP (brand-wide trust promises, above the fold) -->
    <USPStrip />

    <!-- 1.5. VARIANT DETAILS (description + comparison table) -->
    {product.hasVariants && product.variants.length > 0 && (
      <VariantDetails
        locale={locale}
        variants={product.variants}
        productName={displayName}
      />
    )}

    <!-- 3. ROI CALCULATOR -->
    <ROICalculator
      locale={locale}
      productPrice={product.price}
      productName={displayName}
      defaultTreatmentPrice={content.roi?.defaultTreatmentPrice}
    />

    <!-- 3.5. INSTALLMENT CALCULATOR (HU, above installment minimum) -->
    {showInstallment && product.price && (
      <InstallmentCalculator price={product.price} productName={displayName} />
    )}

    <!-- 3.7. FOUNDER CONSULT (személyes segítség - tanácsadói hang) -->
    <FounderConsult
      ctaHref="/konzultacio"
      eventPrefix="product"
      heading={{ pre: 'Nem biztos, hogy', highlight: 'ez a megfelelő gép', post: 'az Ön szalonjának?' }}
    />

    <!-- 4. VIDEO + DESCRIPTION -->
    {content.videoDescription && (
      <VideoDescription
        locale={locale}
        videoUrl={firstVideoUrl}
        productName={displayName}
        content={content.videoDescription}
      />
    )}

    <!-- 5. CTA: after video -->
    <ProductCTA
      locale={locale}
      productName={displayName}
      variant="light"
      headline={content.cta?.afterVideo?.text}
      buttonLabel={content.cta?.afterVideo?.buttonLabel}
      phoneLabel={content.cta?.afterVideo?.phoneLabel}
      showPhone={true}
    />

    <!-- 5.5. GALLERY SECTION (secondary product images, deeper in the page) -->
    {product.extraImages && product.extraImages.length > 0 && (
      <ProductGallerySection
        images={product.extraImages}
        productName={displayName}
        headline="Galéria"
      />
    )}

    <!-- 6. FEATURE ROWS -->
    {content.featureRows && (
      <FeatureRows
        locale={locale}
        content={content.featureRows}
      />
    )}

    <!-- 7. CTA: after features (showroom invite + per-product gallery) -->
    {content.featureRows && (
      <ProductCTA
        locale={locale}
        productName={displayName}
        variant="accent"
        headline={content.cta?.afterFeatures?.headline}
        subtitle={content.cta?.afterFeatures?.subtitle}
        buttonLabel={content.cta?.afterFeatures?.buttonLabel}
        showPhone={true}
        productSlug={locale === 'hu' ? product.slug : undefined}
      />
    )}

    <!-- 8. TRAINING SECTION -->
    {content.training && (
      <TrainingCard
        locale={locale}
        content={content.training}
      />
    )}

    <!-- 9. TESTIMONIALS -->
    {resolvedTestimonials.length > 0 && (
      <Testimonials
        locale={locale}
        testimonials={resolvedTestimonials}
        productName={displayName}
      />
    )}

    <!-- 10. EXPERT QUOTE -->
    {resolvedExpertQuote && (
      <ExpertQuote
        locale={locale}
        quote={resolvedExpertQuote.quote}
        author={resolvedExpertQuote.author}
        role={resolvedExpertQuote.role}
        image={resolvedExpertQuote.image}
      />
    )}

    <!-- 11. TECH SPECS -->
    {Object.keys(resolvedSpecs).length > 0 && (
      <TechSpecs
        locale={locale}
        specs={resolvedSpecs}
        productName={displayName}
      />
    )}

    <!-- 12. FUNCTION CARDS -->
    {resolvedFunctionCards.length > 0 && (
      <FunctionCards
        locale={locale}
        functions={resolvedFunctionCards}
      />
    )}

    <!-- 13. FAQ -->
    {resolvedFaq.length > 0 && (
      <ProductFAQ
        locale={locale}
        faq={resolvedFaq}
        productName={displayName}
      />
    )}

    <!-- 13.5 BUYER CHECKLIST -->
    {content.buyerChecklist && content.buyerChecklist.items.length > 0 && (
      <BuyerChecklist
        locale={locale}
        headline={content.buyerChecklist.headline}
        subtitle={content.buyerChecklist.subtitle}
        items={content.buyerChecklist.items}
      />
    )}

    <!-- 14. WHATS INCLUDED -->
    {resolvedWhatsIncluded.length > 0 && (
      <WhatsIncluded
        locale={locale}
        items={resolvedWhatsIncluded}
        productName={displayName}
      />
    )}

    <!-- 15. WARRANTY -->
    <WarrantyService locale={locale} productName={displayName} />

    <!-- 16. CTA SECTION -->
    <ProductCTA
      locale={locale}
      productName={displayName}
      variant="primary"
      headline={content.cta?.final?.headline}
      subtitle={content.cta?.final?.subtitle}
      buttonLabel={content.cta?.final?.buttonLabel}
      showPhone={true}
    />

    <!-- 17. RELATED PRODUCTS -->
    <RelatedProducts
      locale={locale}
      currentSlug={product.slug}
      categorySlug={product.categorySlug}
    />

  </div>

  <script>
    import { trackViewItem } from '@/lib/tracking';

    function fireViewItem() {
      const el = document.getElementById('track-view-item');
      if (!el) return;
      trackViewItem({
        item_id: el.dataset.itemId || '',
        item_name: el.dataset.itemName || '',
        item_category: el.dataset.itemCategory || '',
        price: parseFloat(el.dataset.itemPrice || '0'),
        currency: 'HUF',
      });
    }

    document.addEventListener('astro:page-load', fireViewItem);
    if (document.readyState !== 'loading') fireViewItem();
  </script>
</BaseLayout>
