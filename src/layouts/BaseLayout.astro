---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import TopCtaBar from '../components/layout/TopCtaBar.astro';
import MobileStickyCta from '../components/layout/MobileStickyCta.astro';
import DesktopContactWidget from '../components/layout/DesktopContactWidget.astro';
// WhatsAppButton removed — will be added to bottom CTA later
import { LCPTracker } from '../components/images';
import Tracking from '../components/tracking/Tracking.astro';
import TrackingNoscript from '../components/tracking/TrackingNoscript.astro';
import { SITE, COMPANY, CONTACT, LOCATIONS, SOCIAL, SEO_DEFAULTS } from '../lib/constants';
import {
  locales,
  localeConfig,
  defaultLocale,
  getLocaleFromUrl,
  getLocalizedPath,
  getLocalizedUrl,
  getHtmlLang,
} from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  schema?: object | object[] | null;
  hideDesktopWidget?: boolean;
  /** URL of the LCP hero image to preload (page-specific) */
  preloadImage?: string;
  /** MIME type for preload (auto-detected from extension if omitted) */
  preloadImageType?: string;
  /** Defer GTM loading by N milliseconds (0 = no GTM) */
  deferGtmMs?: number;
}

const {
  title = SEO_DEFAULTS.defaultTitle,
  description = SEO_DEFAULTS.defaultDescription,
  image = '/og-image.jpg',
  noIndex = false,
  schema,
  hideDesktopWidget = false,
  preloadImage,
  preloadImageType,
  deferGtmMs = 0,
} = Astro.props;

// Auto-detect preload image MIME type from extension
function getImageMimeType(url: string): string {
  if (url.endsWith('.avif')) return 'image/avif';
  if (url.endsWith('.webp')) return 'image/webp';
  if (url.endsWith('.png')) return 'image/png';
  return 'image/jpeg';
}
const resolvedPreloadType = preloadImage
  ? (preloadImageType || getImageMimeType(preloadImage))
  : undefined;

// Get current locale from URL
const currentLocale = getLocaleFromUrl(Astro.url);
const currentPath = Astro.url.pathname;
const htmlLang = getHtmlLang(currentLocale);

// Generate canonical URL - absolute URL for SEO
// Using SITE.url as base for all languages (path-based routing)
const localizedPath = getLocalizedUrl(currentLocale, currentPath);
const canonicalURL = `${SITE.url}${localizedPath}`;
const fullTitle = title === SEO_DEFAULTS.defaultTitle ? title : `${title} | Skinlab Hungary`;

// Generate hreflang links for all locales - absolute URLs for SEO
const hreflangLinks = locales.map((locale) => ({
  locale,
  hreflang: localeConfig[locale].hreflang,
  href: `${SITE.url}${getLocalizedUrl(locale, currentPath)}`,
}));

// Helper to render schema(s)
const schemas = schema ? (Array.isArray(schema) ? schema : [schema]).filter(Boolean) : [];
---

<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Hreflang tags for international SEO -->
  {hreflangLinks.map(({ hreflang, href }) => (
    <link rel="alternate" hreflang={hreflang} href={href} />
  ))}
  <link rel="alternate" hreflang="x-default" href={`${SITE.url}${getLocalizedUrl(defaultLocale, currentPath)}`} />
  <link rel="help" type="text/plain" href="/llm.txt" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, SITE.url)} />
  <meta property="og:locale" content={localeConfig[currentLocale].hreflang.replace('-', '_')} />
  <meta property="og:site_name" content="Skinlab Hungary" />
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, SITE.url)} />
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  
  <!-- Fonts: self-hosted, preload critical subsets -->
  <link rel="preload" href="/fonts/inter-latin-ext.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/playfair-latin-ext.woff2" as="font" type="font/woff2" crossorigin />

  <!-- LCP image preload (page-specific) -->
  {preloadImage && (
    <link rel="preload" href={preloadImage} as="image" type={resolvedPreloadType} fetchpriority="high" />
  )}
  
  <!-- Schema.org — page-specific schemas passed via schema prop -->
  {schemas.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
  
  <!-- Tracking: GTM + Consent Mode v2 -->
  <Tracking gtmId="GTM-NW7DKC2D" />

  <!-- Additional head content from pages -->
  <slot name="head" />

  <!-- Generator -->
  <meta name="generator" content={Astro.generator} />
</head>
<body class="min-h-screen flex flex-col bg-gray-50 text-gray-900 antialiased">
  <TrackingNoscript gtmId="GTM-NW7DKC2D" />
  <Header />
  <main id="main-content" class="flex-1">
    <slot />
  </main>
  <Footer />
  <MobileStickyCta />
  {!hideDesktopWidget && <DesktopContactWidget />}
<LCPTracker />
<slot name="body-end" />
</body>
</html>

