---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import MobileStickyCta from '../components/layout/MobileStickyCta.astro';
import DesktopContactWidget from '../components/layout/DesktopContactWidget.astro';
import CartDrawer from '../components/cart/CartDrawer.astro';
import { LCPTracker } from '../components/images';
import Tracking from '../components/tracking/Tracking.astro';
import TrackingNoscript from '../components/tracking/TrackingNoscript.astro';
import { SITE, SEO_DEFAULTS } from '../lib/constants';
import {
  locales,
  localeConfig,
  defaultLocale,
  getLocaleFromUrl,
  getLocalizedUrl,
  getHtmlLang,
  type Locale,
} from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  schema?: object | object[] | null;
  hideDesktopWidget?: boolean;
  /** URL of the LCP hero image to preload (desktop / default) */
  preloadImage?: string;
  /** URL of the LCP hero image to preload on mobile viewports (< 640px) */
  preloadImageMobile?: string;
  /** MIME type for preload (auto-detected from extension if omitted) */
  preloadImageType?: string;
  /**
   * Restrict which locales render `<link rel="alternate" hreflang>` for this
   * page. Useful when content only exists in some languages (e.g. blog posts).
   * Defaults to all locales.
   */
  availableLocales?: Locale[];
  /** Defer GTM loading by N milliseconds (0 = load immediately) */
  deferGtmMs?: number;
}

const {
  title = SEO_DEFAULTS.defaultTitle,
  description = SEO_DEFAULTS.defaultDescription,
  image = '/og-image.jpg',
  noIndex = false,
  schema,
  hideDesktopWidget = false,
  preloadImage,
  preloadImageMobile,
  preloadImageType,
  availableLocales,
  deferGtmMs = 0,
} = Astro.props;

// Auto-detect preload image MIME type from extension
function getImageMimeType(url: string): string {
  if (url.endsWith('.avif')) return 'image/avif';
  if (url.endsWith('.webp')) return 'image/webp';
  if (url.endsWith('.png')) return 'image/png';
  return 'image/jpeg';
}
const resolvedPreloadType = preloadImage
  ? (preloadImageType || getImageMimeType(preloadImage))
  : undefined;

// Get current locale from URL
const currentLocale = getLocaleFromUrl(Astro.url);
// Normalize path: strip trailing slash (except root) so canonical/hreflang are consistent
const rawPath = Astro.url.pathname;
const currentPath = rawPath !== '/' ? rawPath.replace(/\/+$/, '') : '/';
const htmlLang = getHtmlLang(currentLocale);

// Generate canonical URL - absolute URL for SEO.
// trailingSlash: 'always' — emit a trailing slash so canonical/hreflang match
// the URL the server actually serves (Cloudflare normalizes to a trailing
// slash; without this the canonical pointed at a 307-redirecting URL).
// NB: concatenate the slash (not `${p}/` in a template literal) — a `}/` just
// before a closing backtick trips the Astro compiler's frontmatter tokenizer.
const withTrailingSlash = (p: string) => (p.endsWith('/') ? p : p + '/');
const localizedPath = withTrailingSlash(getLocalizedUrl(currentLocale, currentPath));
const canonicalURL = `${SITE.url}${localizedPath}`;
// Avoid a doubled brand ("… | Skinlab Hungary | Skinlab Hungary") when a page
// (e.g. a localized homepage) already includes the brand in its own title.
const fullTitle = (title === SEO_DEFAULTS.defaultTitle || title.includes('Skinlab Hungary'))
  ? title
  : `${title} | Skinlab Hungary`;

// Generate hreflang links - restricted to availableLocales if the page sets one.
const localesToAnnounce = (availableLocales && availableLocales.length > 0)
  ? locales.filter((l) => availableLocales.includes(l))
  : locales;
const hreflangLinks = localesToAnnounce.map((locale) => ({
  locale,
  hreflang: localeConfig[locale].hreflang,
  href: `${SITE.url}${withTrailingSlash(getLocalizedUrl(locale, currentPath))}`,
}));

// Helper to render schema(s)
const schemas = schema ? (Array.isArray(schema) ? schema : [schema]).filter(Boolean) : [];
---

<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Hreflang tags for international SEO -->
  {hreflangLinks.map(({ hreflang, href }) => (
    <link rel="alternate" hreflang={hreflang} href={href} />
  ))}
  <link rel="alternate" hreflang="x-default" href={`${SITE.url}${withTrailingSlash(getLocalizedUrl(defaultLocale, currentPath))}`} />
  <link rel="help" type="text/plain" href="/llm.txt" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, SITE.url)} />
  <meta property="og:locale" content={localeConfig[currentLocale].dateLocale.replace('-', '_')} />
  {localesToAnnounce.filter((l) => l !== currentLocale).map((l) => (
    <meta property="og:locale:alternate" content={localeConfig[l].dateLocale.replace('-', '_')} />
  ))}
  <meta property="og:site_name" content="Skinlab Hungary" />
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, SITE.url)} />
  
  {/* Favicon: SVG for modern browsers, .ico fallback for older crawlers/UAs.
      TODO: add a designed 180x180 public/apple-touch-icon.png and re-add an
      apple-touch-icon link (the previous one was removed because it 404'd). */}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
  
  <!-- Fonts: self-hosted, preload the primary `latin` subsets (these render the
       bulk of visible above-the-fold text). The heavier `latin-ext` subset
       (HU ő/ű etc.) is left to load on demand via @font-face + font-display:swap
       so it doesn't compete with the LCP hero image on slow connections. -->
  <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/playfair-latin.woff2" as="font" type="font/woff2" crossorigin />

  <!-- LCP image preload (page-specific). If a mobile variant is provided,
       split the preload via `media` queries so each viewport fetches the
       version it will actually paint. -->
  {preloadImage && !preloadImageMobile && (
    <link rel="preload" href={preloadImage} as="image" type={resolvedPreloadType} fetchpriority="high" />
  )}
  {preloadImage && preloadImageMobile && (
    <>
      <link rel="preload" href={preloadImageMobile} as="image" type={getImageMimeType(preloadImageMobile)} media="(max-width: 639px)" fetchpriority="high" />
      <link rel="preload" href={preloadImage} as="image" type={resolvedPreloadType} media="(min-width: 640px)" fetchpriority="high" />
    </>
  )}
  
  <!-- Schema.org - page-specific schemas passed via schema prop -->
  {schemas.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
  
  <!-- Global JS error logger - every uncaught error logs with a code prefix -->
  <script is:inline>
    (function () {
      // Debug gate: the [CODE] console output appears only for developers or
      // opted-in users (localhost, ?debug=1, or localStorage 'sl-debug'='1').
      // Normal visitors never see it; server-side (Worker) logs are unaffected.
      var DEBUG = (function () {
        try {
          if (/^(localhost|127\.0\.0\.1|\[::1\])$/.test(location.hostname)) return true;
          if (/[?&](debug|sl-debug)=1\b/.test(location.search)) {
            try { localStorage.setItem('sl-debug', '1'); } catch (e) {}
            return true;
          }
          return localStorage.getItem('sl-debug') === '1';
        } catch (e) { return false; }
      })();
      window.__slDebug = DEBUG;
      function pickCode(err) {
        if (!err) return 'JS-UNHANDLED-001';
        var name = (err && err.name) || '';
        if (name === 'TypeError') return 'JS-TYPE-001';
        if (name === 'ReferenceError') return 'JS-REF-001';
        if (name === 'RangeError') return 'JS-RANGE-001';
        if (name === 'SyntaxError') return 'JS-SYNTAX-001';
        return 'JS-UNHANDLED-001';
      }
      window.addEventListener('error', function (event) {
        if (!DEBUG) return;
        var code = pickCode(event.error);
        console.error('[' + code + ']', {
          message: event.message,
          source: event.filename,
          line: event.lineno,
          col: event.colno,
          error: event.error,
        });
      });
      window.addEventListener('unhandledrejection', function (event) {
        if (!DEBUG) return;
        var reason = event.reason;
        var code = (reason && reason.name) ? pickCode(reason) : 'JS-PROMISE-001';
        console.error('[' + code + '] unhandled promise rejection:', reason);
      });
    })();
  </script>

  <!-- Tracking: GTM + Consent Mode v2.
       deferGtmMs > 0 delays gtm.js fetch until user interaction or timeout. -->
  <Tracking gtmId="GTM-NW7DKC2D" deferMs={deferGtmMs} />

  <!-- Additional head content from pages -->
  <slot name="head" />

  <!-- Generator -->
  <meta name="generator" content={Astro.generator} />
</head>
<body class="min-h-screen flex flex-col bg-gray-50 text-gray-900 antialiased">
  <TrackingNoscript gtmId="GTM-NW7DKC2D" />
  <Header />
  <main id="main-content" class="flex-1">
    <slot />
  </main>
  <Footer />
  <MobileStickyCta />
  {!hideDesktopWidget && <DesktopContactWidget />}
  <CartDrawer />
<LCPTracker />
<slot name="body-end" />
</body>
</html>

