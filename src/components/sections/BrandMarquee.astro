---
/**
 * BrandMarquee - Displays brand logos in an infinite scrolling marquee
 * Uses the Logo component for optimized images with WebP + JPEG fallback
 */
import Logo from '../images/Logo.astro';
import { t, getLocaleFromUrl, type Locale } from '../../i18n/ui';

// Get locale from URL
const locale = getLocaleFromUrl(Astro.url) as Locale;

// Brand logos. `h` = rendered visual height in px — the per-brand knob that
// normalizes how large the wordmark *looks*. Pure wordmarks (brovi, MAST) need a
// smaller height; logos with an emblem or lots of internal whitespace
// (Dragonhawk, Farmona, Biotatum) need a larger height so the lettering matches.
// `maxW` caps width so a wide lockup can't overflow the fixed-width card.
const brands = [
  { name: 'MAST', logo: '@assets/brands/mast-logo.png', h: 28, maxW: 130 },
  { name: 'Dragonhawk', logo: '@assets/brands/dragonhawk-logo.png', h: 54, maxW: 140 },
  { name: 'WJX', logo: '@assets/brands/wjx-logo.png', h: 36, maxW: 130 },
  { name: "M'onduniq", logo: '@assets/brands/monduniq-logo.png', h: 40, maxW: 144 },
  { name: 'Biotatum', logo: '@assets/brands/biotatum-logo.png', h: 52, maxW: 140 },
  { name: 'Biopen', logo: '@assets/brands/biopen-logo.png', h: 38, maxW: 130 },
  { name: 'Farmona', logo: '@assets/brands/farmona-logo.png', h: 52, maxW: 130 },
  { name: 'Brovi', logo: '@assets/brands/brovi-logo.png', h: 30, maxW: 120 },
];
---

<section class="py-10 lg:py-12 bg-primary-100/50 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-8">
      <h2 class="text-xl lg:text-2xl font-bold text-gray-900 mb-2">
        {t(locale, 'brands.title')}
      </h2>
      <p class="text-gray-600 text-sm">
        {t(locale, 'brands.subtitle')}
      </p>
    </div>
  </div>

  <!-- Marquee Container -->
  <div class="relative">
    <!-- Fade edges -->
    <div class="absolute left-0 top-0 bottom-0 w-20 bg-gradient-to-r from-gray-50 to-transparent z-10 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute right-0 top-0 bottom-0 w-20 bg-gradient-to-l from-gray-50 to-transparent z-10 pointer-events-none" aria-hidden="true"></div>

    <!-- Marquee track - duplicate content 2x for seamless infinite loop.
         Padding-LR on .marquee-content (px-6 / lg:px-8) matches the in-content
         gap (gap-12 / lg:gap-16) so the seam between sets is invisible. -->
    <div class="marquee-track flex w-max">
      {[...Array(2)].map((_, setIndex) => (
        <div class="marquee-content flex items-center gap-12 lg:gap-16 px-6 lg:px-8" aria-hidden={setIndex > 0 ? "true" : undefined}>
          {brands.map((brand) => (
            <div class="flex-shrink-0 flex items-center justify-center w-44 h-20 px-4 bg-white rounded-xl shadow-sm border border-gray-100">
              <Logo
                src={brand.logo}
                alt={`${brand.name} logo`}
                width={160}
                class="w-auto object-contain"
                style={`height:${brand.h}px;max-width:${brand.maxW}px;aspect-ratio:auto`}
              />
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-track {
    animation: marquee 20s linear infinite;
  }

  .marquee-content {
    flex-shrink: 0;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Pause on hover for better UX */
  .marquee-track:hover {
    animation-play-state: paused;
  }

  /* Respect reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }

    .marquee-content:not(:first-child) {
      display: none;
    }
  }
</style>

<script is:inline>
  (function() {
    var track = document.querySelector('.marquee-track');
    if (!track) return;
    var startX = 0, currentOffset = 0, dragging = false;

    track.addEventListener('touchstart', function(e) {
      dragging = true;
      startX = e.touches[0].clientX;
      track.style.animationPlayState = 'paused';
      var transform = getComputedStyle(track).transform;
      if (transform && transform !== 'none') {
        var matrix = new DOMMatrix(transform);
        currentOffset = matrix.m41;
      }
    }, { passive: true });

    track.addEventListener('touchmove', function(e) {
      if (!dragging) return;
      var dx = e.touches[0].clientX - startX;
      track.style.animation = 'none';
      track.style.transform = 'translateX(' + (currentOffset + dx) + 'px)';
    }, { passive: true });

    track.addEventListener('touchend', function() {
      if (!dragging) return;
      dragging = false;
      track.style.animation = '';
      track.style.animationPlayState = '';
    }, { passive: true });
  })();
</script>
