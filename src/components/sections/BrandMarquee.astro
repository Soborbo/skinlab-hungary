---
/**
 * BrandMarquee - Displays brand logos in an infinite scrolling marquee
 * Uses the Logo component for optimized images with WebP + JPEG fallback
 */
import Logo from '../images/Logo.astro';
import { t, getLocaleFromUrl, type Locale } from '../../i18n/ui';

// Get locale from URL
const locale = getLocaleFromUrl(Astro.url) as Locale;

// Brand logos with their display settings (using manifest string paths)
const brands = [
  { name: 'Skinlab', logo: '@assets/brands/skinlab-logo.jpg', width: 80 },
  { name: 'MAST', logo: '@assets/brands/mast-logo.png', width: 120 },
  { name: 'Dragonhawk', logo: '@assets/brands/dragonhawk-logo.png', width: 140 },
  { name: 'WJX', logo: '@assets/brands/wjx-logo.png', width: 100 },
];
---

<section class="py-10 lg:py-12 bg-gray-50 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-8">
      <h2 class="text-xl lg:text-2xl font-bold text-gray-900 mb-2">
        {t(locale, 'brands.title')}
      </h2>
      <p class="text-gray-600 text-sm">
        {t(locale, 'brands.subtitle')}
      </p>
    </div>
  </div>

  <!-- Marquee Container -->
  <div class="relative">
    <!-- Fade edges -->
    <div class="absolute left-0 top-0 bottom-0 w-20 bg-gradient-to-r from-gray-50 to-transparent z-10 pointer-events-none" aria-hidden="true"></div>
    <div class="absolute right-0 top-0 bottom-0 w-20 bg-gradient-to-l from-gray-50 to-transparent z-10 pointer-events-none" aria-hidden="true"></div>

    <!-- Marquee track - duplicate content 4x for seamless infinite loop -->
    <div class="marquee-track flex">
      {[...Array(4)].map((_, setIndex) => (
        <div class:list={["marquee-content flex items-center gap-12 lg:gap-16 px-6", setIndex > 0 && "aria-hidden"]} aria-hidden={setIndex > 0 ? "true" : undefined}>
          {brands.map((brand) => (
            <div class="flex-shrink-0 flex items-center justify-center h-16 px-6 bg-white rounded-xl shadow-sm border border-gray-100">
              <Logo
                src={brand.logo}
                alt={`${brand.name} logo`}
                width={brand.width}
                class="h-10 w-auto object-contain"
              />
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-track {
    animation: marquee 20s linear infinite;
  }

  .marquee-content {
    flex-shrink: 0;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Pause on hover for better UX */
  .marquee-track:hover {
    animation-play-state: paused;
  }

  /* Respect reduced motion preference */
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }

    .marquee-content:not(:first-child) {
      display: none;
    }
  }
</style>

<script is:inline>
  (function() {
    var track = document.querySelector('.marquee-track');
    if (!track) return;
    var startX = 0, currentOffset = 0, dragging = false;

    track.addEventListener('touchstart', function(e) {
      dragging = true;
      startX = e.touches[0].clientX;
      track.style.animationPlayState = 'paused';
      var transform = getComputedStyle(track).transform;
      if (transform && transform !== 'none') {
        var matrix = new DOMMatrix(transform);
        currentOffset = matrix.m41;
      }
    }, { passive: true });

    track.addEventListener('touchmove', function(e) {
      if (!dragging) return;
      var dx = e.touches[0].clientX - startX;
      track.style.animation = 'none';
      track.style.transform = 'translateX(' + (currentOffset + dx) + 'px)';
    }, { passive: true });

    track.addEventListener('touchend', function() {
      if (!dragging) return;
      dragging = false;
      track.style.animation = '';
      track.style.animationPlayState = '';
    }, { passive: true });
  })();
</script>
