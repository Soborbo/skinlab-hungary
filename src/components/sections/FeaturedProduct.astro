---
import { getCollection } from 'astro:content';
import { ContentImage } from '../images';
import { hasImage, getImageAlt } from '@/lib/resolve-image';
import { t, getLocaleFromUrl, getLocalizedUrl, formatPrice as i18nFormatPrice, type Locale } from '../../i18n/ui';

// Get locale from URL
const locale = getLocaleFromUrl(Astro.url) as Locale;

// Localized contact link
const contactLink = getLocalizedUrl(locale, '/konzultacio');

// Fetch the featured product (HELIOS — flagship 1600W diódalézer)
const allProducts = await getCollection('products', ({ data }) => !data.draft);
const featuredProduct = allProducts.find(p => p.data.slug === 'helios');

const productImagePath = featuredProduct?.data.image || '';
const hasProductImage = productImagePath && hasImage(productImagePath);

const product = {
  name: featuredProduct?.data.name || 'HELIOS 1600W diódalézer',
  tagline: t(locale, 'featuredProduct.tagline'),
  badge: t(locale, 'featuredProduct.badge'),
  price: featuredProduct?.data.price ? i18nFormatPrice(featuredProduct.data.price, locale) : t(locale, 'product.priceOnRequest'),
  monthlyPrice: t(locale, 'featuredProduct.monthlyPrice'),
  specs: [
    { value: '4', labelKey: 'featuredProduct.wavelength' },
    { value: '1600W', labelKey: 'featuredProduct.power' },
    { value: '-16°C', labelKey: 'featuredProduct.cooling' },
    { value: t(locale, 'featuredProduct.warrantyValue'), labelKey: 'featuredProduct.warranty' },
  ],
  link: featuredProduct
    ? getLocalizedUrl(locale, `/${featuredProduct.data.categorySlug}/${featuredProduct.data.slug}`)
    : getLocalizedUrl(locale, '/diodalezerek/helios'),
};
---

<section class="bg-gradient-to-br from-primary-50 via-[#faf6f3] to-white py-16 lg:py-20 relative overflow-hidden">
  <!-- Subtle decorative accents -->
  <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-primary-100/40 blur-3xl" aria-hidden="true"></div>
  <div class="absolute -bottom-24 -left-24 w-80 h-80 rounded-full bg-cta-light/50 blur-3xl" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-12 items-center">
      <!-- Left: Product image -->
      <div class="bg-white rounded-2xl aspect-square flex items-center justify-center order-1 lg:order-1 overflow-hidden shadow-sm border border-primary-100/60">
        {hasProductImage ? (
          <ContentImage
            src={productImagePath}
            alt={getImageAlt(productImagePath, product.name)}
            class="w-full h-full object-contain p-4"
          />
        ) : (
          <div class="text-center p-8">
            <div class="w-20 h-20 mx-auto mb-4 rounded-2xl bg-primary-50 flex items-center justify-center">
              <svg class="w-10 h-10 text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <p class="text-gray-400 font-medium">HELIOS {t(locale, 'featuredProduct.productPlaceholder')}</p>
          </div>
        )}
      </div>

      <!-- Right: Product info -->
      <div class="text-gray-800 order-2 lg:order-2">
        <div class="inline-flex items-center gap-2 bg-cta-light text-cta-hover px-3 py-1 rounded-full text-sm font-medium mb-4">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          {product.badge}
        </div>

        <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold mb-3 text-gray-900">{product.name}</h2>
        <p class="text-lg lg:text-xl text-primary-600 mb-6">{product.tagline}</p>

        <div class="grid grid-cols-2 gap-3 mb-6">
          {product.specs.map((spec) => (
            <div class="bg-white rounded-xl p-3 lg:p-4 border border-gray-100 shadow-sm">
              <div class="text-xl lg:text-2xl font-bold text-gray-900">{spec.value}</div>
              <div class="text-gray-500 text-sm">{t(locale, spec.labelKey)}</div>
            </div>
          ))}
        </div>

        <div class="flex items-end gap-4 mb-6">
          <div>
            <div class="text-gray-500 text-sm">{t(locale, 'featuredProduct.grossPrice')}</div>
            <div class="text-3xl lg:text-4xl font-bold text-gray-900">{product.price}</div>
          </div>
          <div class="text-gray-500">
            {t(locale, 'featuredProduct.orMonthly')} {product.monthlyPrice}
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={contactLink}
            class="bg-cta hover:bg-cta-hover text-white font-bold py-3 lg:py-4 px-6 lg:px-8 rounded-xl text-center transition-colors shadow-lg"
          >
            {t(locale, 'featuredProduct.requestDemo')}
          </a>
          <a
            href={product.link}
            class="bg-white text-gray-800 font-bold py-3 lg:py-4 px-6 lg:px-8 rounded-xl text-center border-2 border-gray-200 hover:border-cta/40 hover:text-cta transition-colors"
          >
            {t(locale, 'featuredProduct.viewDetails')}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
