---
import { t, getLocaleFromUrl, type Locale } from '../../i18n/ui';

// Get locale from URL
const locale = getLocaleFromUrl(Astro.url) as Locale;

// Stats with translation keys
const stats = [
  { value: '150+', labelKey: 'stats.soldUnits' },
  { value: '2', labelKey: 'stats.warranty', suffixKey: 'stats.yearsSuffix' },
  { value: '2', labelKey: 'stats.deliveryTime', suffixKey: 'stats.weeksSuffix' },
  { value: '100%', labelKey: 'stats.legalImport' },
];
---

<section class="py-8 lg:py-10 bg-primary-600">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-12">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-3xl lg:text-4xl font-bold text-white mb-1">
            {stat.value}{stat.suffixKey ? ` ${t(locale, stat.suffixKey)}` : ''}
          </div>
          <div class="text-primary-100 font-medium text-sm">
            {t(locale, stat.labelKey)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
