---
import { t, getLocaleFromUrl, type Locale } from '../../i18n/ui';

const locale = getLocaleFromUrl(Astro.url) as Locale;

const steps = [
  { number: '1', titleKey: 'howItWorks.step1Title', descKey: 'howItWorks.step1Desc' },
  { number: '2', titleKey: 'howItWorks.step2Title', descKey: 'howItWorks.step2Desc' },
  { number: '3', titleKey: 'howItWorks.step3Title', descKey: 'howItWorks.step3Desc' },
  { number: '4', titleKey: 'howItWorks.step4Title', descKey: 'howItWorks.step4Desc' },
];
---

<section class="py-16 lg:py-20 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 lg:mb-14">
      <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-3">
        {t(locale, 'howItWorks.title')}
      </h2>
      <p class="text-gray-600">
        {t(locale, 'howItWorks.subtitle')}
      </p>
    </div>

    {/* Mobile: horizontally scrollable */}
    <div class="flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4 -mx-4 px-4 lg:hidden scrollbar-hide">
      {steps.map((step, index) => (
        <div class="snap-start flex-shrink-0 w-[75vw] sm:w-[45vw] bg-[#fbf8f6] rounded-2xl p-6 text-center border border-[#9b6b6b]/10">
          <div class="how-step-number w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 text-lg font-semibold text-white" style={`opacity: ${0.55 + index * 0.15}`}>
            {step.number}
          </div>
          <h3 class="font-bold text-gray-900 mb-2">{t(locale, step.titleKey)}</h3>
          <p class="text-[#645a59] text-sm leading-relaxed">{t(locale, step.descKey)}</p>
        </div>
      ))}
    </div>

    {/* Desktop: 4 columns with connecting line */}
    <div class="hidden lg:block relative">
      {/* Connecting line */}
      <div class="absolute top-7 left-[calc(12.5%+24px)] right-[calc(12.5%+24px)] h-px bg-gradient-to-r from-[#9b6b6b]/20 via-[#9b6b6b]/40 to-[#9b6b6b]/60" aria-hidden="true"></div>

      <div class="grid grid-cols-4 gap-6 relative z-10">
        {steps.map((step, index) => (
          <div class="text-center group">
            <div class="how-step-number w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-5 text-xl font-semibold text-white shadow-md transition-transform duration-300 group-hover:scale-110" style={`opacity: ${0.55 + index * 0.15}`}>
              {step.number}
            </div>
            <h3 class="font-bold text-gray-900 mb-2">{t(locale, step.titleKey)}</h3>
            <p class="text-[#645a59] text-sm leading-relaxed">{t(locale, step.descKey)}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .how-step-number {
    background-color: #9b6b6b;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
