---
import { CONTACT } from '../../lib/constants';
import { t, getLocaleFromUrl, getLocalizedUrl, type Locale } from '../../i18n/ui';

// Get locale from URL
const locale = getLocaleFromUrl(Astro.url) as Locale;

// Localized contact link
const contactLink = getLocalizedUrl(locale, '/konzultacio');
---

<section class="bg-gradient-to-br from-[#c4a0a0] via-[#9b6b6b] to-[#7a5252] py-16 lg:py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-white mb-4">
      {t(locale, 'finalCta.title')}
    </h2>
    <p class="text-lg lg:text-xl text-white/90 mb-8 max-w-2xl mx-auto">
      {t(locale, 'finalCta.subtitle')}
    </p>

    <div class="flex justify-center mb-8">
      <a
        href={contactLink}
        class="bg-white text-[#9b6b6b] font-bold py-3 lg:py-4 px-8 lg:px-10 rounded-xl text-lg hover:bg-gray-100 transition-all shadow-xl inline-flex items-center justify-center gap-2"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        {t(locale, 'finalCta.demoButton')}
      </a>
    </div>

    <div class="flex flex-wrap justify-center gap-6 lg:gap-8 text-white/90 text-sm mb-8">
      <span class="flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        {t(locale, 'finalCta.noObligation')}
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        {t(locale, 'finalCta.inPersonOrOnline')}
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        {t(locale, 'finalCta.roiCalculation')}
      </span>
    </div>

    <div class="pt-8 border-t border-white/20">
      <p class="text-white/70 text-sm mb-2">{t(locale, 'finalCta.orCallDirectly')}</p>
      <a href={CONTACT.phoneTel} class="text-white text-2xl lg:text-3xl font-bold hover:underline">
        {CONTACT.phoneDisplay}
      </a>
    </div>
  </div>
</section>
