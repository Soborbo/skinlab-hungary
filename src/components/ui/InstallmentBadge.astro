---
/**
 * InstallmentBadge - Compact installment payment info for product pages.
 * Rules live in @/lib/installment.ts (price tiers + bundle override).
 */
import { getInstallmentInfo } from '@/lib/installment';

interface Props {
  /** Product price in HUF */
  price?: number;
  /** Whether this is a bundle (all months available above min) */
  isBundle?: boolean;
  /** Compact (chip) vs expanded (card) layout */
  compact?: boolean;
  class?: string;
}

const { price = 0, isBundle = false, compact = false, class: className = '' } = Astro.props;

const info = getInstallmentInfo(price, isBundle);

const fmt = new Intl.NumberFormat('hu-HU');
const formatHuf = (n: number) => fmt.format(n);

const monthLabels: Record<3 | 6 | 12, string> = {
  3: '3 havi',
  6: '6 havi',
  12: '12 havi',
};
---

{info.available && (
  <div class:list={['installment-badge', className]}>
    {compact ? (
      <a
        href="/szallitas-fizetes#reszletfizetes"
        class="inline-flex items-center gap-2 px-3 py-1.5 bg-success-50 text-success-700 rounded-lg text-sm font-medium hover:bg-success-100 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>Kamatmentes részletfizetés</span>
      </a>
    ) : (
      <div class="bg-gradient-to-br from-primary-50 to-indigo-50 rounded-xl p-4 border border-primary-100">
        <div class="flex items-start gap-3 mb-3">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <h4 class="font-semibold text-gray-900">Kamatmentes részletfizetés</h4>
            <p class="text-sm text-gray-600">50% előleg + havi részletek</p>
          </div>
        </div>

        <div class="space-y-2 mb-3">
          <div class="flex items-center justify-between text-sm bg-white rounded-lg px-3 py-2">
            <span class="text-gray-600">Előleg (50%):</span>
            <span class="font-semibold text-gray-900">{formatHuf(info.downPayment)} Ft</span>
          </div>
          {info.months.map((m) => (
            <div class="flex items-center justify-between text-sm bg-white rounded-lg px-3 py-2">
              <span class="text-gray-600">{monthLabels[m]} részlet:</span>
              <span class="font-bold text-primary-600">~{formatHuf(info.monthly[m])} Ft/hó</span>
            </div>
          ))}
          {info.months.includes(12) && (
            <div class="flex items-center gap-2 text-sm pt-1">
              <span class="px-2 py-0.5 bg-primary-600 text-white text-xs font-bold rounded">12 hó</span>
              <span class="text-gray-600">{isBundle ? 'csomag esetén elérhető' : '3 M Ft felett elérhető'}</span>
            </div>
          )}
        </div>

        <a
          href="/szallitas-fizetes#reszletfizetes"
          class="inline-flex items-center text-sm text-primary-600 font-medium hover:text-primary-700"
        >
          Részletek megtekintése
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    )}
  </div>
)}
