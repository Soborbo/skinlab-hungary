---
import { CONTACT } from '../../lib/constants';
---

<div
  id="mobile-sticky-cta"
  class="fixed bottom-0 left-0 right-0 lg:hidden bg-white border-t border-gray-200 shadow-lg z-40 safe-area-pb"
  style="transform: translateY(115%); opacity: 0; transition: transform 0.7s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.45s ease-out;"
>
  <div class="grid grid-cols-2 gap-2 p-3">
    <a
      href={CONTACT.phoneTel}
      class="cta-item flex items-center justify-center gap-2 bg-green-500 hover:bg-green-600 text-white font-semibold py-3 rounded-lg transition-colors"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
      </svg>
      Hívás
    </a>
    <a
      href="/konzultacio/"
      class="cta-item flex items-center justify-center gap-2 bg-primary-700 hover:bg-primary-800 text-white font-semibold py-3 rounded-lg transition-colors"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
      </svg>
      Konzultáció
    </a>
  </div>
</div>

<style>
  .safe-area-pb {
    padding-bottom: max(0.75rem, env(safe-area-inset-bottom));
  }

  /* Each button rises + fades in with a gentle stagger after the bar springs up. */
  #mobile-sticky-cta .cta-item {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease, transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  #mobile-sticky-cta.is-visible .cta-item {
    opacity: 1;
    transform: translateY(0);
  }
  #mobile-sticky-cta.is-visible .cta-item:nth-child(1) {
    transition-delay: 0.18s;
  }
  #mobile-sticky-cta.is-visible .cta-item:nth-child(2) {
    transition-delay: 0.30s;
  }

  @media (prefers-reduced-motion: reduce) {
    #mobile-sticky-cta,
    #mobile-sticky-cta .cta-item {
      transition: none !important;
    }
  }
</style>

<script is:inline>
  (function () {
    var el = document.getElementById('mobile-sticky-cta');
    if (!el) return;
    var shown = false;
    function reveal() {
      if (shown) return;
      shown = true;
      el.style.transform = 'translateY(0)';
      el.style.opacity = '1';
      // next frame so the child stagger plays after the bar has settled in
      requestAnimationFrame(function () { el.classList.add('is-visible'); });
      window.removeEventListener('scroll', onScroll);
    }
    function onScroll() {
      if (window.scrollY > 120) reveal();
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    // Graceful fallback: glide in shortly after load even without a scroll.
    setTimeout(reveal, 1800);
  })();
</script>
