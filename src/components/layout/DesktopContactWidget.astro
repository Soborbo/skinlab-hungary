---
import { CONTACT } from '../../lib/constants';
---

<div
  id="desktop-contact-widget"
  class="hidden lg:block fixed bottom-6 right-6 z-40"
  style="transform: translateX(calc(100% + 2rem)); transition: transform 0.5s ease-out;"
>
  <!-- Collapsed: just the avatar bubble -->
  <button
    id="reopen-contact-widget"
    class="hidden ml-auto w-[56px] h-[56px] rounded-full overflow-hidden ring-[3px] ring-primary-600 shadow-lg hover:scale-105 transition-transform cursor-pointer"
    aria-label="Kapcsolat megnyitása"
  >
    <img
      src="/images/misc/horvath-laszlo-beuszo.jpg"
      alt="Horváth László"
      class="w-full h-full object-cover"
    />
  </button>

  <!-- Expanded card -->
  <div id="contact-card" class="contact-card relative overflow-hidden rounded-2xl shadow-2xl w-[440px]">
    <!-- Gradient background -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary-700 via-primary-600 to-primary-800"></div>

    <!-- Shimmer overlay -->
    <div class="shimmer-overlay absolute inset-0 opacity-0" style="background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.15) 45%, rgba(255,255,255,0.3) 50%, rgba(255,255,255,0.15) 55%, transparent 60%); background-size: 200% 100%;"></div>

    <!-- Close button -->
    <button
      id="close-contact-widget"
      class="absolute top-2.5 right-2.5 text-white/50 hover:text-white transition-colors p-1 z-10"
      aria-label="Bezárás"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Content -->
    <div class="relative z-[1] flex items-center gap-4 p-4">
      <!-- Round photo -->
      <img
        src="/images/misc/horvath-laszlo-beuszo.jpg"
        alt="Horváth László"
        class="w-[72px] h-[72px] rounded-full object-cover ring-[3px] ring-white/30 flex-shrink-0"
        loading="lazy"
      />

      <div class="flex-1 min-w-0">
        <p class="font-bold text-white text-[15px] leading-tight">Horváth László</p>
        <p class="text-xs text-white/60 mt-0.5 mb-2">Technikai szakértő</p>
        <p class="text-[13px] text-white/85 leading-snug">
          Kérdése van? Hívjon bizalommal, szívesen segítünk!
        </p>
      </div>
    </div>

    <!-- CTA button -->
    <div class="relative z-[1] px-4 pb-4 -mt-0.5">
      <a
        href={CONTACT.phoneTel}
        class="flex items-center justify-center gap-2 bg-green-500 hover:bg-green-400 text-white font-semibold py-2.5 rounded-xl transition-colors text-sm w-full shadow-lg shadow-green-500/25"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        {CONTACT.phoneDisplay}
      </a>
    </div>
  </div>
</div>

<style>
  @keyframes shimmer {
    0% { background-position: 200% 0; opacity: 1; }
    100% { background-position: -200% 0; opacity: 1; }
  }
  .shimmer-active {
    animation: shimmer 1.2s ease-in-out;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const widget = document.getElementById('desktop-contact-widget');
    const card = document.getElementById('contact-card');
    const closeBtn = document.getElementById('close-contact-widget');
    const reopenBtn = document.getElementById('reopen-contact-widget');
    if (!widget || !card || !reopenBtn) return;

    const STORAGE_KEY = 'contact-widget-dismissed';

    function showCard() {
      card.style.display = '';
      reopenBtn.classList.add('hidden');
      widget.style.transform = 'translateX(0)';
    }

    function collapseToAvatar() {
      // Slide out, then swap to avatar
      widget.style.transform = 'translateX(calc(100% + 2rem))';
      setTimeout(() => {
        card.style.display = 'none';
        reopenBtn.classList.remove('hidden');
        widget.style.transform = 'translateX(0)';
      }, 500);
    }

    // If previously dismissed, show avatar directly
    if (sessionStorage.getItem(STORAGE_KEY)) {
      card.style.display = 'none';
      reopenBtn.classList.remove('hidden');
      widget.style.transform = 'translateX(0)';
      return;
    }

    // Initial appearance after 8s
    setTimeout(() => {
      widget.style.transform = 'translateX(0)';

      // Shimmer effect 2s after appearance
      setTimeout(() => {
        const shimmer = widget.querySelector('.shimmer-overlay');
        if (shimmer) shimmer.classList.add('shimmer-active');
      }, 2000);
    }, 8000);

    closeBtn?.addEventListener('click', () => {
      sessionStorage.setItem(STORAGE_KEY, '1');
      collapseToAvatar();
    });

    reopenBtn.addEventListener('click', () => {
      showCard();
    });
  });
</script>
