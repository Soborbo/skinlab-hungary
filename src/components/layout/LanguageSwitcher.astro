---
/**
 * LanguageSwitcher Component
 *
 * Displays a dropdown for switching between available languages.
 * Uses country flag images (flagcdn.com) for cross-platform support.
 */
import { locales, localeConfig, getLocaleFromUrl, getLocalizedUrl } from '../../i18n/ui';

interface Props {
  variant?: 'dropdown' | 'list' | 'compact';
  class?: string;
}

const { variant = 'dropdown', class: className = '' } = Astro.props;

const currentLocale = getLocaleFromUrl(Astro.url);
const currentPath = Astro.url.pathname;
const currentConfig = localeConfig[currentLocale];

function flagSrc(countryCode: string) {
  return `/flags/${countryCode}.webp`;
}
---

{variant === 'dropdown' && (
  <div class:list={['language-switcher relative', className]} data-language-switcher>
    <button
      type="button"
      class="inline-flex items-center justify-center w-9 h-9 rounded-lg hover:bg-black/5 transition-colors overflow-hidden"
      aria-label="Nyelv váltása"
      aria-expanded="false"
      aria-haspopup="true"
      data-language-toggle
    >
      <img
        src={flagSrc(currentConfig.flag)}
        alt={currentConfig.nativeName}
        width="24"
        height="18"
        class="rounded-[3px] object-cover"
        loading="eager"
      />
    </button>

    <div
      class="absolute right-0 z-50 mt-2 min-w-[156px] origin-top-right rounded-xl bg-white shadow-lg ring-1 ring-black/10 focus:outline-none hidden"
      role="menu"
      aria-orientation="vertical"
      data-language-menu
    >
      <div class="py-2 grid grid-cols-3 gap-1 px-2">
        {locales.map((locale) => {
          const config = localeConfig[locale];
          const href = getLocalizedUrl(locale, currentPath);
          const isActive = locale === currentLocale;

          return (
            <a
              href={href}
              hreflang={config.hreflang}
              title={config.nativeName}
              class:list={[
                'inline-flex items-center justify-center w-10 h-10 rounded-lg transition-colors',
                isActive
                  ? 'bg-primary-50 ring-2 ring-primary-400'
                  : 'hover:bg-gray-50',
              ]}
              role="menuitem"
              aria-label={config.nativeName}
            >
              <img
                src={flagSrc(config.flag)}
                alt={config.nativeName}
                width="24"
                height="18"
                class="rounded-[3px] object-cover"
                loading="lazy"
              />
            </a>
          );
        })}
      </div>
    </div>
  </div>
)}

{variant === 'list' && (
  <div class:list={['language-switcher-list', className]}>
    <ul class="flex flex-wrap gap-2">
      {locales.map((locale) => {
        const config = localeConfig[locale];
        const href = getLocalizedUrl(locale, currentPath);
        const isActive = locale === currentLocale;

        return (
          <li>
            <a
              href={href}
              hreflang={config.hreflang}
              class:list={[
                'inline-flex items-center gap-2 px-3 py-1.5 text-sm rounded-full transition-colors',
                isActive
                  ? 'bg-primary-100 text-primary-700 font-medium'
                  : 'bg-gray-100 text-gray-600 hover:bg-gray-200',
              ]}
            >
              <img
                src={flagSrc(config.flag)}
                alt=""
                width="20"
                height="15"
                class="rounded-[2px] object-cover"
                loading="lazy"
              />
              <span>{config.nativeName}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </div>
)}

{variant === 'compact' && (
  <div class:list={['language-switcher-compact flex items-center flex-wrap gap-1', className]}>
    {locales.map((locale) => {
      const config = localeConfig[locale];
      const href = getLocalizedUrl(locale, currentPath);
      const isActive = locale === currentLocale;

      return (
        <a
          href={href}
          hreflang={config.hreflang}
          title={config.nativeName}
          class:list={[
            'inline-flex items-center justify-center w-9 h-9 rounded-xl transition-all',
            isActive
              ? 'bg-white/80 ring-2 ring-[#9b6b6b]/40 shadow-sm'
              : 'hover:bg-white/40',
          ]}
          aria-label={config.nativeName}
          aria-current={isActive ? 'true' : undefined}
        >
          <img
            src={flagSrc(config.flag)}
            alt={config.nativeName}
            width="22"
            height="16"
            class="rounded-[3px] object-cover"
            loading="lazy"
          />
        </a>
      );
    })}
  </div>
)}

<script>
  document.querySelectorAll('[data-language-switcher]').forEach((switcher) => {
    const toggle = switcher.querySelector('[data-language-toggle]');
    const menu = switcher.querySelector('[data-language-menu]');

    if (!toggle || !menu) return;

    const closeMenu = () => {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    };

    const openMenu = () => {
      menu.classList.remove('hidden');
      toggle.setAttribute('aria-expanded', 'true');
    };

    const toggleMenu = () => {
      if (menu.classList.contains('hidden')) {
        openMenu();
      } else {
        closeMenu();
      }
    };

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleMenu();
    });

    document.addEventListener('click', (e) => {
      if (!switcher.contains(e.target as Node)) {
        closeMenu();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeMenu();
      }
    });
  });
</script>
