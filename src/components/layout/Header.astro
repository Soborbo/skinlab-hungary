---
import { getCollection } from 'astro:content';
import { CONTACT, NAV_ITEMS, MEGA_MENU, CATEGORY_COLORS } from '../../lib/constants';
import { Logo, FifthImage } from '../images';
import LanguageSwitcher from './LanguageSwitcher.astro';
import SearchOverlay from '../search/SearchOverlay.astro';
import { hasImage } from '@/lib/resolve-image';
import { t, getLocaleFromUrl, getLocalizedUrl, type Locale } from '../../i18n/ui';

const locale = getLocaleFromUrl(Astro.url) as Locale;
const contactLink = getLocalizedUrl(locale, '/konzultacio');
const skinlabLogo = '@assets/logo.png';

// Get first product image per category slug for megamenu
const allProducts = await getCollection('products', ({ data }) => !data.draft);
const megaMenuImages: Record<string, string | null> = {};
for (const column of MEGA_MENU.columns) {
  for (const item of column.items) {
    const slug = item.href.replace(/^\//, '');
    const categoryProducts = allProducts.filter(p => p.data.categorySlug === slug);
    for (const product of categoryProducts) {
      if (product.data.image && hasImage(product.data.image)) {
        megaMenuImages[slug] = product.data.image;
        break;
      }
    }
    if (!megaMenuImages[slug]) {
      megaMenuImages[slug] = null;
    }
  }
}
---

<a href="#main-content" class="skip-to-content">
  {t(locale, 'header.skipToContent')}
</a>

<header class="sticky top-0 z-50 shadow-lg">
  <div class="hidden md:block h-[30px]" style="background: linear-gradient(to right, #e9d5d6, #ecd8d7);"></div>
  <div class="bg-[#f9f4f1]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14 lg:h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center shrink-0">
        <Logo
          src={skinlabLogo}
          alt="Skinlab Hungary - laser&beauty equipment"
          width={120}
          height={48}
          class="h-9 lg:h-10 w-auto"
          priority={true}
        />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1">
        {NAV_ITEMS.map((item) => (
          item.hasMegaMenu ? (
            <div class="relative" data-mega-menu-trigger>
              <button
                type="button"
                class="inline-flex items-center gap-1 px-4 py-2 text-sm font-medium text-[#645a59] hover:text-[#9b6b6b] rounded-lg hover:bg-black/5 transition-colors"
                aria-expanded="false"
                aria-haspopup="true"
              >
                {t(locale, item.labelKey)}
                <svg class="w-4 h-4 transition-transform duration-200" data-chevron fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
            </div>
          ) : (
            <a
              href={item.href}
              class="px-4 py-2 text-sm font-medium text-[#645a59] hover:text-[#9b6b6b] rounded-lg hover:bg-black/5 transition-colors"
            >
              {t(locale, item.labelKey)}
            </a>
          )
        ))}
      </nav>

      <!-- Right side: Language + Phone + CTA -->
      <div class="flex items-center gap-2 lg:gap-3">
        <!-- Language Switcher (desktop) -->
        <div class="hidden lg:block">
          <LanguageSwitcher variant="dropdown" class="[&_button]:text-[#645a59] [&_button]:hover:text-[#9b6b6b] [&_button]:hover:bg-black/5" />
        </div>

        <!-- Search -->
        <SearchOverlay />

        <!-- Phone (desktop only) -->
        <a
          href={CONTACT.phoneTel}
          class="hidden md:flex items-center gap-2 px-4 py-2 bg-black/5 text-[#645a59] font-semibold rounded-lg hover:bg-black/10 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span>{CONTACT.phoneDisplay}</span>
        </a>

        <!-- CTA Button -->
        <a
          href={contactLink}
          class="inline-flex items-center px-4 lg:px-5 py-2 lg:py-2.5 bg-white text-primary-700 font-semibold text-sm rounded-lg hover:bg-primary-50 transition-colors shadow-sm"
        >
          <span class="hidden sm:inline">{t(locale, 'header.freeConsultation')}</span>
          <span class="sm:hidden">{t(locale, 'cta.button')}</span>
        </a>

        <!-- Mobile menu button -->
        <button
          type="button"
          class="lg:hidden inline-flex items-center justify-center p-2 rounded-lg text-[#645a59] hover:text-[#9b6b6b] hover:bg-black/5"
          aria-label={t(locale, 'header.openMenu')}
          data-mobile-menu-toggle
        >
          <svg class="w-6 h-6" data-menu-icon fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="w-6 h-6 hidden" data-close-icon fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mega Menu Dropdown -->
  <div
    class="hidden absolute left-0 right-0 bg-white border-b border-gray-200 shadow-xl"
    data-mega-menu
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-4 gap-8">
        {MEGA_MENU.columns.map((column) => (
          <div>
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">
              {t(locale, column.titleKey)}
            </h3>
            <ul class="space-y-1">
              {column.items.map((item) => {
                const slug = item.href.replace(/^\//, '');
                const itemImage = megaMenuImages[slug];
                const catColors = (slug in CATEGORY_COLORS) ? CATEGORY_COLORS[slug as keyof typeof CATEGORY_COLORS] : null;
                return (
                <li>
                  <a
                    href={getLocalizedUrl(locale, item.href)}
                    class="group flex items-start gap-3 p-3 -mx-3 rounded-lg hover:bg-gray-50 transition-colors border-l-2"
                    style={catColors ? `border-color: ${catColors.accent}; --mega-item-color: ${catColors.accent}` : 'border-color: transparent'}
                  >
                    {/* Category thumbnail */}
                    <div class="w-12 h-12 rounded-lg overflow-hidden bg-gray-100 shrink-0">
                      {itemImage ? (
                        <FifthImage
                          src={itemImage}
                          alt={t(locale, item.labelKey)}
                          class="w-full h-full object-cover"
                        />
                      ) : (
                        <div class="w-full h-full flex items-center justify-center">
                          <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                          </svg>
                        </div>
                      )}
                    </div>
                    <div class="flex-1">
                      <div class="flex items-center gap-2">
                        <span
                          class="text-sm font-medium transition-colors"
                          style={catColors ? `color: ${catColors.accentDark}` : ''}
                        >
                          {t(locale, item.labelKey)}
                        </span>
                        {item.badgeKey && (
                          <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium bg-primary-100 text-primary-700 rounded-full">
                            {t(locale, item.badgeKey)}
                          </span>
                        )}
                        <span class="text-xs text-gray-400">
                          ({item.count})
                        </span>
                      </div>
                      <p class="mt-0.5 text-xs text-gray-500">
                        {t(locale, item.descriptionKey)}
                      </p>
                    </div>
                    <svg class="w-4 h-4 text-gray-300 group-hover:text-primary-500 mt-0.5 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </li>
                );
              })}
            </ul>
          </div>
        ))}
      </div>

      <!-- Bottom CTA -->
      <div class="mt-8 pt-6 border-t border-gray-100 flex items-center justify-between">
        <p class="text-sm text-gray-500">
          {t(locale, 'header.megaMenuFooter')}
        </p>
        <a
          href={getLocalizedUrl(locale, MEGA_MENU.cta.href)}
          class="inline-flex items-center gap-2 text-sm font-medium text-primary-600 hover:text-primary-700"
        >
          {t(locale, MEGA_MENU.cta.labelKey)}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div class="hidden lg:hidden" data-mobile-menu>
    <div class="px-4 pt-2 pb-4 bg-white border-t border-gray-100 max-h-[calc(100vh-4rem)] overflow-y-auto">

      <!-- Mega menu items for mobile -->
      {MEGA_MENU.columns.map((column) => (
        <div class="py-2" data-mobile-accordion>
          <button
            type="button"
            class="w-full flex items-center justify-between px-4 py-3 text-base font-medium text-gray-700 hover:bg-gray-50 rounded-lg"
            data-accordion-trigger
          >
            <span>{t(locale, column.titleKey)}</span>
            <svg class="w-5 h-5 text-gray-400 transition-transform duration-200" data-accordion-icon fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div class="hidden pl-4" data-accordion-content>
            {column.items.map((item) => {
              const slug = item.href.replace(/^\//, '');
              const itemImage = megaMenuImages[slug];
              return (
              <a
                href={getLocalizedUrl(locale, item.href)}
                class="flex items-center gap-3 px-4 py-3 text-sm text-gray-600 hover:text-primary-600 hover:bg-gray-50 rounded-lg"
              >
                {/* Category thumbnail */}
                <div class="w-9 h-9 rounded-md overflow-hidden bg-gray-100 shrink-0">
                  {itemImage ? (
                    <FifthImage
                      src={itemImage}
                      alt={t(locale, item.labelKey)}
                      class="w-full h-full object-cover"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center">
                      <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                    </div>
                  )}
                </div>
                <span class="flex-1 flex items-center gap-2">
                  {t(locale, item.labelKey)}
                  {item.badgeKey && (
                    <span class="inline-flex items-center px-1.5 py-0.5 text-xs font-medium bg-primary-100 text-primary-700 rounded">
                      {t(locale, item.badgeKey)}
                    </span>
                  )}
                </span>
                <span class="text-xs text-gray-400">{item.count}</span>
              </a>
              );
            })}
          </div>
        </div>
      ))}

      <!-- Other nav items -->
      <div class="mt-2 pt-2 border-t border-gray-100 space-y-1">
        {NAV_ITEMS.filter(item => !item.hasMegaMenu).map((item) => (
          <a
            href={getLocalizedUrl(locale, item.href)}
            class="block px-4 py-3 text-base font-medium text-gray-600 hover:text-primary-600 hover:bg-gray-50 rounded-lg"
          >
            {t(locale, item.labelKey)}
          </a>
        ))}
      </div>

      <!-- Phone -->
      <div class="mt-4 pt-4 border-t border-gray-100">
        <a
          href={CONTACT.phoneTel}
          class="flex items-center gap-3 px-4 py-3 text-base font-medium text-success-600 bg-success-50 rounded-lg"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          {CONTACT.phoneDisplay}
        </a>
      </div>

      <!-- Language Switcher (mobile) -->
      <div class="mt-4 pt-4 border-t border-gray-100">
        <p class="px-4 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">{t(locale, 'header.languageLabel')}</p>
        <LanguageSwitcher variant="compact" class="px-4" />
      </div>
    </div>
  </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const mobileToggle = document.querySelector('[data-mobile-menu-toggle]');
  const mobileMenu = document.querySelector('[data-mobile-menu]');
  const menuIcon = document.querySelector('[data-menu-icon]');
  const closeIcon = document.querySelector('[data-close-icon]');

  mobileToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  // Mobile accordion
  document.querySelectorAll('[data-accordion-trigger]').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const accordion = trigger.closest('[data-mobile-accordion]');
      const content = accordion?.querySelector('[data-accordion-content]');
      const icon = accordion?.querySelector('[data-accordion-icon]');

      content?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });

  // Desktop mega menu
  const megaMenuTrigger = document.querySelector('[data-mega-menu-trigger]');
  const megaMenu = document.querySelector('[data-mega-menu]');
  const chevron = document.querySelector('[data-chevron]');
  let megaMenuTimeout: ReturnType<typeof setTimeout>;

  function showMegaMenu() {
    clearTimeout(megaMenuTimeout);
    megaMenu?.classList.remove('hidden');
    chevron?.classList.add('rotate-180');
    megaMenuTrigger?.querySelector('button')?.setAttribute('aria-expanded', 'true');
  }

  function hideMegaMenu() {
    megaMenuTimeout = setTimeout(() => {
      megaMenu?.classList.add('hidden');
      chevron?.classList.remove('rotate-180');
      megaMenuTrigger?.querySelector('button')?.setAttribute('aria-expanded', 'false');
    }, 150);
  }

  megaMenuTrigger?.addEventListener('mouseenter', showMegaMenu);
  megaMenuTrigger?.addEventListener('mouseleave', hideMegaMenu);
  megaMenu?.addEventListener('mouseenter', showMegaMenu);
  megaMenu?.addEventListener('mouseleave', hideMegaMenu);

  // Keyboard accessibility
  megaMenuTrigger?.querySelector('button')?.addEventListener('click', () => {
    const isOpen = !megaMenu?.classList.contains('hidden');
    if (isOpen) {
      hideMegaMenu();
    } else {
      showMegaMenu();
    }
  });

  // Close on escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      hideMegaMenu();
      mobileMenu?.classList.add('hidden');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    }
  });
</script>
