---
/**
 * FounderConsult - warm, consultative "kérjen visszahívást / tanácsadást" section.
 *
 * Brand-pink portrait panel (image-left) + scenario chips + low-pressure CTA on
 * the right. Mirrors the visitor's uncertainty instead of pushing a product.
 * Used on category pages (CategoryLayout) and product pages (ProductLayout).
 */
import { CONTACT } from '../../lib/constants';

interface Expert {
  name: string;
  role: string;
  image: string;
  imageAlt?: string;
}

interface HeadingParts {
  /** Text before the highlighted word(s). */
  pre: string;
  /** Highlighted word(s) with the hand-drawn underline. */
  highlight: string;
  /** Text after the highlight. */
  post: string;
}

interface Props {
  expert?: Expert;
  /** CTA target (consultation/callback request). */
  ctaHref?: string;
  /** Heading parts; defaults to the category "melyik gép való Önnek?" framing. */
  heading?: HeadingParts;
  /** data-event prefix for click tracking (e.g. "category", "product"). */
  eventPrefix?: string;
  /** Optional outer section background classes. */
  sectionClass?: string;
}

const defaultExpert: Expert = {
  name: 'Horváth László',
  role: 'Skinlab alapító, technikai szakértő',
  image: '/about/horvath-laszlo-skinlab-alapito.jpg',
  imageAlt: 'Horváth László, Skinlab alapító',
};

const {
  expert = defaultExpert,
  ctaHref = '/konzultacio',
  heading = { pre: 'Nem tudod,', highlight: 'melyik gép', post: 'való neked?' },
  eventPrefix = 'founder',
  sectionClass = 'bg-white py-12 lg:py-20',
} = Astro.props;

const scenarios = [
  { d: 'M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', t: 'Nem tudod, melyiket válaszd' },
  { d: 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z', t: 'Pontos infót kérsz a gépekről' },
  { d: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z', t: 'Megbeszélnéd a vásárlás részleteit' },
  { d: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z', t: 'Csak egy jó tanácsra van szükséged' },
];
---

<section class={sectionClass}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="founder-card group/card relative grid lg:grid-cols-[minmax(0,42%)_1fr] overflow-hidden rounded-[2rem] border border-gray-100 bg-white shadow-xl shadow-primary-500/10">

      <!-- BAL: portré panel (brand pink) -->
      <div class="relative flex flex-col items-center justify-center min-h-[360px] lg:min-h-[460px] p-8 overflow-hidden bg-gradient-to-br from-primary-600 via-primary-500 to-primary-700">
        <div class="absolute -top-12 -left-12 w-48 h-48 rounded-full bg-white/10 blur-2xl" aria-hidden="true"></div>
        <div class="absolute -bottom-10 -right-10 w-44 h-44 rounded-full bg-primary-900/30 blur-2xl" aria-hidden="true"></div>
        <!-- óriás idézőjel -->
        <svg class="absolute top-5 left-6 w-20 h-20 text-white/15" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M7.17 6A5.17 5.17 0 002 11.17V18h6.83v-6.83H5.5A1.67 1.67 0 017.17 9.5V6zm9 0A5.17 5.17 0 0011 11.17V18h6.83v-6.83H14.5A1.67 1.67 0 0116.17 9.5V6z"/></svg>

        <div class="relative">
          <img
            src={expert.image}
            alt={expert.imageAlt || `${expert.name}, ${expert.role}`}
            class="w-48 h-60 lg:w-56 lg:h-72 object-cover object-top rounded-2xl ring-4 ring-white/80 shadow-2xl rotate-[-3deg] transition-transform duration-500 group-hover/card:rotate-0 group-hover/card:scale-[1.02]"
            loading="lazy"
          />
        </div>

        <div class="relative mt-7 text-center">
          <div class="font-bold text-white text-lg leading-tight">{expert.name}</div>
          <div class="text-white/80 text-sm">{expert.role}</div>
        </div>
      </div>

      <!-- JOBB: szöveg -->
      <div class="relative p-6 sm:p-9 lg:p-12 flex flex-col justify-center">
        <span class="inline-flex items-center gap-2 self-start px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wide mb-4 bg-primary-50 text-primary-700">
          <span class="w-1.5 h-1.5 rounded-full bg-primary-500 animate-pulse"></span>
          Személyes segítség
        </span>

        <h2 class="text-2xl lg:text-[2rem] font-bold text-gray-900 leading-tight mb-5">
          {heading.pre}
          <span class="relative whitespace-nowrap text-primary-600">{heading.highlight}<svg class="absolute -bottom-1.5 left-0 w-full text-primary-300" height="7" viewBox="0 0 100 7" preserveAspectRatio="none" aria-hidden="true"><path d="M1 5 Q 25 1 50 4 T 99 3" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/></svg></span>
          {heading.post}
        </h2>

        <!-- scenario chips -->
        <div class="grid sm:grid-cols-2 gap-2.5 mb-6">
          {scenarios.map((item) => (
            <div class="flex items-center gap-2.5 rounded-xl border border-gray-100 bg-gray-50/70 px-3 py-2.5 transition-all hover:border-primary-200 hover:bg-primary-50/60 hover:-translate-y-0.5">
              <svg class="w-5 h-5 flex-shrink-0 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.d}/></svg>
              <span class="text-sm text-gray-700 leading-snug">{item.t}</span>
            </div>
          ))}
        </div>

        <p class="text-gray-600 mb-6">
          Bármelyik is igaz rád – <strong class="text-gray-900">szeretettel segítünk.</strong> Hívj minket, vagy kérj ingyenes konzultációt, és felvesszük veled a kapcsolatot.
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={ctaHref}
            class="cta-shine group/cta relative overflow-hidden inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl font-semibold text-white shadow-md shadow-primary-700/20 transition-all hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0 bg-primary-700 hover:bg-primary-800"
            data-event={`${eventPrefix}-callback-cta-click`}
          >
            Kérj ingyenes konzultációt
            <svg class="w-4 h-4 transition-transform group-hover/cta:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a
            href={CONTACT.phoneTel}
            class="inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-xl font-semibold border-2 border-gray-200 text-gray-800 bg-white transition-all hover:border-primary-300 hover:text-primary-600 hover:-translate-y-0.5 active:translate-y-0"
            data-event={`${eventPrefix}-callback-phone-click`}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Hívj fel: {CONTACT.phoneDisplay}
          </a>
        </div>

        <p class="text-xs text-gray-400 mt-4 flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Általában 1 munkanapon belül visszahívjuk.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-shine::after {
    content: ""; position: absolute; top: 0; left: -150%; width: 60%; height: 100%;
    background: linear-gradient(105deg, transparent, rgba(255,255,255,0.35), transparent);
    transform: skewX(-20deg); pointer-events: none;
  }
  .cta-shine:hover::after { animation: ctaShine 0.9s ease; }
  @keyframes ctaShine { from { left: -150%; } to { left: 160%; } }
  @media (prefers-reduced-motion: reduce) {
    .cta-shine:hover::after { animation: none; }
  }
</style>
