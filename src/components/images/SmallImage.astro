---
/**
 * SmallImage - SMALL pattern (40vw)
 * Use: Split 40/60 layouts where text is dominant, image is smaller
 * Pattern: 40vw desktop, 100vw mobile
 */
import OptimizedPicture from './OptimizedPicture.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  class?: string;
}

const { src, alt, class: className } = Astro.props;

const widths = [320, 480, 640, 960, 1280];
const sizes = '(min-width: 1024px) 40vw, 100vw';
---

<OptimizedPicture
  src={src}
  alt={alt}
  widths={widths}
  sizes={sizes}
  class={className}
  loading="lazy"
  decoding="async"
/>
