---
/**
 * CardImage - THIRD pattern for card grids
 * Use: 3-column grids, treatment cards, feature cards
 * Pattern: 33vw desktop, 50vw tablet, 100vw mobile
 */
import OptimizedPicture from './OptimizedPicture.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  class?: string;
}

const { src, alt, class: className } = Astro.props;

const widths = [320, 480, 640, 960, 1280];
const sizes = '(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw';
---

<OptimizedPicture
  src={src}
  alt={alt}
  widths={widths}
  sizes={sizes}
  class={className}
  loading="lazy"
  decoding="async"
/>
