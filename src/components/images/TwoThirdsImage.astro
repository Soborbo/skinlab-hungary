---
/**
 * TwoThirdsImage - TWO_THIRDS pattern (66vw)
 * Use: Split 66/33 layouts where image takes the larger side
 * Pattern: 66vw desktop, 100vw mobile
 */
import OptimizedPicture from './OptimizedPicture.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  class?: string;
  priority?: boolean;
}

const { src, alt, class: className, priority = false } = Astro.props;

const widths = [320, 480, 640, 960, 1280, 1600, 2048];
const sizes = '(min-width: 1024px) 66vw, 100vw';
---

<OptimizedPicture
  src={src}
  alt={alt}
  widths={widths}
  sizes={sizes}
  class={className}
  loading={priority ? 'eager' : 'lazy'}
  fetchpriority={priority ? 'high' : undefined}
  decoding={priority ? undefined : 'async'}
/>
