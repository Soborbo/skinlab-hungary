---
/**
 * QuarterImage - QUARTER pattern (25vw)
 * Use: 4-column grids, team member photos
 * Pattern: 25vw desktop, 50vw tablet, 100vw mobile
 */
import OptimizedPicture from './OptimizedPicture.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  class?: string;
}

const { src, alt, class: className } = Astro.props;

const widths = [240, 480, 640, 960];
const sizes = '(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw';
---

<OptimizedPicture
  src={src}
  alt={alt}
  widths={widths}
  sizes={sizes}
  class={className}
  loading="lazy"
  decoding="async"
/>
