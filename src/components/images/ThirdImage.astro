---
/**
 * ThirdImage - THIRD pattern for 3-column grids
 * Use: 3-column grids, treatment cards, feature cards, testimonials
 * Pattern: 33vw desktop, 50vw tablet, 100vw mobile
 */
import OptimizedPicture from './OptimizedPicture.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  class?: string;
  priority?: boolean;
}

const { src, alt, class: className, priority = false } = Astro.props;

const widths = [320, 480, 640, 960, 1280];
const sizes = '(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw';
---

<OptimizedPicture
  src={src}
  alt={alt}
  widths={widths}
  sizes={sizes}
  class={className}
  loading={priority ? 'eager' : 'lazy'}
  fetchpriority={priority ? 'high' : undefined}
  decoding={priority ? undefined : 'async'}
/>
