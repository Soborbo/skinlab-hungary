---
/**
 * Logo - FIXED pattern for logos (header, footer, partner logos)
 * Use: Brand logos, partner logos, any fixed-size logo
 * Pattern: 1x + 2x density using pre-generated images
 */
import type { ImageMetadata } from 'astro';
import { normalizeImagePath, getImageEntry } from '@/lib/resolve-image';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  width: number;
  height?: number;
  class?: string;
  priority?: boolean;
}

const { src, alt, width, height, class: className, priority = false } = Astro.props;

// Resolve manifest entry
let manifestKey = '';
if (typeof src === 'string') {
  manifestKey = normalizeImagePath(src);
} else {
  const imgSrc = ((src as any).fsPath || (src as any).src || '').replace(/\\/g, '/');
  const match = imgSrc.match(/src\/assets\/(.+)$/);
  if (match) manifestKey = `@assets/${match[1]}`;
}

const entry = manifestKey ? getImageEntry(manifestKey) : null;
const finalHeight = height || width;

function findClosest(widths: number[], target: number): number {
  return widths.reduce((prev, curr) =>
    Math.abs(curr - target) < Math.abs(prev - target) ? curr : prev
  , widths[0]);
}

const basePath = entry?.basePath;
const w1x = entry ? findClosest(entry.widths, width) : width;
const w2x = entry ? findClosest(entry.widths, width * 2) : width * 2;
---

{entry && basePath ? (
  <picture>
    <source
      srcset={`${basePath}-${w1x}w.avif 1x, ${basePath}-${w2x}w.avif 2x`}
      type="image/avif"
    />
    <source
      srcset={`${basePath}-${w1x}w.webp 1x, ${basePath}-${w2x}w.webp 2x`}
      type="image/webp"
    />
    <img
      src={`${basePath}-${w1x}w.jpg`}
      srcset={`${basePath}-${w1x}w.jpg 1x, ${basePath}-${w2x}w.jpg 2x`}
      alt={alt}
      width={width}
      height={finalHeight}
      class={className}
      loading={priority ? 'eager' : 'lazy'}
      decoding={priority ? undefined : 'async'}
    />
  </picture>
) : (
  <img
    src={typeof src === 'string' ? src : (src as ImageMetadata).src}
    alt={alt}
    width={width}
    height={finalHeight}
    class={className}
    loading={priority ? 'eager' : 'lazy'}
    decoding={priority ? undefined : 'async'}
  />
)}
