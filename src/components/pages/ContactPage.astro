---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE, CONTACT, LOCATIONS, COMPANY } from '../../lib/constants';
import { t, getLocaleFromUrl, getLocalizedUrl, type Locale } from '../../i18n/ui';
import { config } from '../../config/siteConfig';
import { contactPageSchema } from '../../config/schema';
import { getTurnstileSiteKey } from '../../lib/forms/turnstile';

// Get locale from URL
const locale = getLocaleFromUrl(Astro.url) as Locale;

// Localized privacy link
const privacyLink = locale === 'hu' ? '/adatvedelem' : `/${locale}/adatvedelem`;

// Page URL for schema
const pageUrl = `${SITE.url}${getLocalizedUrl(locale, '/kapcsolat')}`;

// Turnstile site key (from PUBLIC_TURNSTILE_SITE_KEY env var)
const turnstileSiteKey = getTurnstileSiteKey();
const sourceUrl = Astro.url.href;
---

<BaseLayout
  title={t(locale, 'contact.title')}
  description={t(locale, 'contact.subtitle')}
  hideDesktopWidget={true}
  schema={contactPageSchema(config, pageUrl)}
>
  <div id="main-content">

    <!-- Hero -->
    <section class="bg-gradient-to-b from-primary-50 via-primary-50/30 to-white py-8 lg:py-10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto">
          <div class="inline-flex items-center gap-2 bg-primary-100 text-primary-700 text-sm font-medium px-4 py-1.5 rounded-full mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            {COMPANY.name}
          </div>
          <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-2">
            {t(locale, 'contact.subtitle')}
          </h1>
        </div>
      </div>
    </section>

    <!-- Contact Grid -->
    <section class="py-10 lg:py-14 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">

          <!-- Contact Form -->
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6">
              {t(locale, 'contact.formTitle')}
            </h2>

            <form class="space-y-4" id="contact-form" novalidate>
              <!-- Hidden tracking / anti-spam fields -->
              <input type="hidden" name="sourceUrl" value={sourceUrl} />
              <input type="hidden" name="formStartTime" data-form-start />
              <input type="hidden" name="gdprTimestamp" data-gdpr-timestamp />
              <input type="hidden" name="utmSource" data-utm="utm_source" />
              <input type="hidden" name="utmMedium" data-utm="utm_medium" />
              <input type="hidden" name="utmCampaign" data-utm="utm_campaign" />

              <!-- Name -->
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
                  {t(locale, 'form.name')}
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
                  placeholder={t(locale, 'form.namePlaceholder')}
                />
              </div>

              <!-- Email -->
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
                  {t(locale, 'form.email')}
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
                  placeholder={t(locale, 'form.emailPlaceholder')}
                />
              </div>

              <!-- Phone -->
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">
                  {t(locale, 'form.phone')}
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
                  placeholder={t(locale, 'form.phonePlaceholder')}
                />
              </div>

              <!-- Subject -->
              <div>
                <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">
                  {t(locale, 'form.subject')}
                </label>
                <input
                  type="text"
                  id="subject"
                  name="subject"
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors"
                  placeholder={t(locale, 'form.subjectPlaceholder')}
                />
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-1">
                  {t(locale, 'form.message')}
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="3"
                  class="w-full px-4 py-2.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500 transition-colors resize-none"
                  placeholder={t(locale, 'form.messagePlaceholder')}
                ></textarea>
              </div>

              <!-- Honeypot (must remain empty — spam bots fill it) -->
              <div class="hidden" aria-hidden="true">
                <input type="text" name="honeypot" tabindex="-1" autocomplete="off" />
              </div>

              <!-- Turnstile CAPTCHA -->
              {turnstileSiteKey && (
                <div class="flex justify-center pt-2">
                  <div
                    class="cf-turnstile"
                    data-sitekey={turnstileSiteKey}
                    data-callback="onContactTurnstileSuccess"
                    data-error-callback="onContactTurnstileError"
                    data-theme="light"
                  ></div>
                </div>
              )}

              <!-- GDPR -->
              <div class="flex items-center gap-3">
                <input
                  type="checkbox"
                  id="gdpr"
                  name="gdprConsent"
                  value="true"
                  required
                  data-gdpr-checkbox
                  class="w-5 h-5 text-primary-600 border-gray-300 rounded focus:ring-primary-500"
                />
                <label for="gdpr" class="text-sm text-gray-600">
                  {t(locale, 'form.gdprConsentPrefix')}{' '}
                  <a href={privacyLink} target="_blank" class="text-primary-600 hover:underline">
                    {t(locale, 'form.gdprConsentLink')}
                  </a>.{' '}
                  <span class="text-red-500">*</span>
                </label>
              </div>

              <!-- Submit -->
              <button
                type="submit"
                id="contact-submit"
                class="w-full px-6 py-3 bg-primary-600 text-white font-semibold rounded-xl hover:bg-primary-700 transition-colors shadow-lg disabled:opacity-50 disabled:cursor-not-allowed"
              >
                <span data-button-text>{t(locale, 'contact.sendMessage')}</span>
              </button>

              <!-- Status messages -->
              <div class="hidden p-4 bg-green-50 border border-green-200 rounded-xl" data-success-message>
                <p class="font-medium text-green-800" data-success-text>Köszönjük! Hamarosan felvesszük Önnel a kapcsolatot.</p>
              </div>
              <div class="hidden p-4 bg-red-50 border border-red-200 rounded-xl" data-error-message>
                <p class="font-medium text-red-800">Hiba történt</p>
                <p class="text-sm text-red-600" data-error-text>Kérjük, próbálja újra.</p>
              </div>
            </form>

            <!-- Turnstile script -->
            <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
          </div>

          <!-- Contact Info -->
          <div class="space-y-6">

            <!-- Phone & Email — compact grid -->
            <div class="grid sm:grid-cols-2 gap-3">
              <a
                href={CONTACT.phoneTel}
                class="flex items-center gap-3 p-4 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors group"
              >
                <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center group-hover:bg-primary-200 transition-colors">
                  <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-gray-900 text-sm">{CONTACT.phoneDisplay}</div>
                  <div class="text-xs text-gray-500">{t(locale, 'ctaSection.callAnytime')}</div>
                </div>
              </a>

              <a
                href={`mailto:${CONTACT.email}`}
                class="flex items-center gap-3 p-4 bg-gray-50 rounded-xl hover:bg-gray-100 transition-colors group"
              >
                <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center group-hover:bg-primary-200 transition-colors">
                  <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <div class="font-semibold text-gray-900 text-sm">{CONTACT.email}</div>
                  <div class="text-xs text-gray-500">{t(locale, 'ctaSection.emailUs')}</div>
                </div>
              </a>
            </div>

            <!-- Map + Address side by side -->
            <div class="rounded-2xl overflow-hidden border border-gray-200">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2718!2d18.9253034!3d47.3784668!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4741e17c09bb0973%3A0xc161cd03bd09e10!2sskinlab!5e0!3m2!1shu!2shu!4v1"
                width="600"
                height="338"
                style="border:0; width:100%"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Skinlab Hungary - Google Maps"
                class="aspect-[16/9]"
              ></iframe>
              <div class="p-5 bg-white">
                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center shrink-0 mt-0.5">
                    <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                  </div>
                  <div class="flex-1">
                    <div class="font-semibold text-gray-900">{LOCATIONS.showroom.name}</div>
                    <div class="text-gray-600 text-sm">{LOCATIONS.showroom.fullAddress}</div>
                    <a
                      href={LOCATIONS.showroom.googleMapsUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center text-primary-600 font-medium hover:text-primary-700 text-sm mt-2"
                    >
                      {t(locale, 'contact.getDirections')}
                      <svg class="w-3.5 h-3.5 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>

            <!-- Info cards grid: Opening Hours, Directions, Company Details -->
            <div class="grid gap-4">

              <!-- Opening Hours -->
              <div class="bg-gray-50 rounded-xl p-5">
                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-gray-900 mb-1">{t(locale, 'contact.openingHours')}</h3>
                    <p class="text-sm text-gray-700">{t(locale, 'contact.openingHoursDetails')}</p>
                    <p class="text-xs text-gray-500 mt-1">{t(locale, 'contact.openingHoursNote')}</p>
                  </div>
                </div>
              </div>

              <!-- How to Reach -->
              <div class="bg-gray-50 rounded-xl p-5">
                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-gray-900 mb-1">{t(locale, 'contact.howToReach')}</h3>
                    <p class="text-sm text-gray-600">{t(locale, 'contact.howToReachDesc')}</p>
                  </div>
                </div>
              </div>

              <!-- Company Details -->
              <div class="bg-gray-50 rounded-xl p-5">
                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-gray-900 mb-2">{t(locale, 'contact.companyDetails')}</h3>
                    <dl class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-1 text-sm">
                      <dt class="text-gray-500">{t(locale, 'contact.headquarters')}</dt>
                      <dd class="text-gray-800">{LOCATIONS.headquarters.fullAddress}</dd>
                      <dt class="text-gray-500">{t(locale, 'contact.registrationNumber')}</dt>
                      <dd class="text-gray-800">{COMPANY.registrationNumber}</dd>
                      <dt class="text-gray-500">{t(locale, 'contact.taxId')}</dt>
                      <dd class="text-gray-800">{COMPANY.taxId}</dd>
                      <dt class="text-gray-500">{t(locale, 'contact.vatId')}</dt>
                      <dd class="text-gray-800">{COMPANY.vatId}</dd>
                    </dl>
                  </div>
                </div>
              </div>

            </div>

          </div>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<script>
  declare global {
    interface Window {
      onContactTurnstileSuccess: (token: string) => void;
      onContactTurnstileError: () => void;
    }
  }

  let turnstileToken = '';

  window.onContactTurnstileSuccess = (token: string) => {
    turnstileToken = token;
  };

  window.onContactTurnstileError = () => {
    turnstileToken = '';
  };

  const form = document.getElementById('contact-form') as HTMLFormElement | null;

  if (form) {
    // Stamp form-load time (used as anti-spam — schema requires >3s before submit)
    const startTimeInput = form.querySelector<HTMLInputElement>('[data-form-start]');
    if (startTimeInput) startTimeInput.value = Date.now().toString();

    // Capture UTM params from URL into hidden fields
    const urlParams = new URLSearchParams(window.location.search);
    form.querySelectorAll<HTMLInputElement>('[data-utm]').forEach((input) => {
      const utmParam = input.getAttribute('data-utm');
      if (utmParam) input.value = urlParams.get(utmParam) || '';
    });

    // Stamp GDPR-consent timestamp on checkbox tick
    const gdprCheckbox = form.querySelector<HTMLInputElement>('[data-gdpr-checkbox]');
    const gdprTimestamp = form.querySelector<HTMLInputElement>('[data-gdpr-timestamp]');
    gdprCheckbox?.addEventListener('change', () => {
      if (gdprCheckbox.checked && gdprTimestamp) {
        gdprTimestamp.value = new Date().toISOString();
      }
    });

    const submitBtn = form.querySelector<HTMLButtonElement>('#contact-submit');
    const buttonText = form.querySelector<HTMLSpanElement>('[data-button-text]');
    const successMessage = form.querySelector<HTMLElement>('[data-success-message]');
    const errorMessage = form.querySelector<HTMLElement>('[data-error-message]');
    const errorText = form.querySelector<HTMLElement>('[data-error-text]');
    const originalButtonText = buttonText?.textContent || 'Küldés';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      successMessage?.classList.add('hidden');
      errorMessage?.classList.add('hidden');

      if (submitBtn) submitBtn.disabled = true;
      if (buttonText) buttonText.textContent = 'Küldés...';

      try {
        const formData = new FormData(form);
        if (turnstileToken) formData.set('cf-turnstile-response', turnstileToken);

        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });

        const result = await response.json();

        if (result.success) {
          form.reset();
          successMessage?.classList.remove('hidden');
          // Reset Turnstile so the user can submit again
          if (typeof (window as unknown as { turnstile?: { reset: () => void } }).turnstile !== 'undefined') {
            (window as unknown as { turnstile: { reset: () => void } }).turnstile.reset();
          }
          turnstileToken = '';
        } else {
          console.error('[' + (result.code || 'FORM-SUBMIT-001') + '] contact:', result);
          errorMessage?.classList.remove('hidden');
          if (errorText) {
            const code = result.code ? '[' + result.code + '] ' : '';
            errorText.textContent = code + (result.error || 'Kérjük, próbálja újra.');
          }
        }
      } catch (error) {
        console.error('[NET-OFFLINE-001] contact network error:', error);
        errorMessage?.classList.remove('hidden');
        if (errorText) errorText.textContent = '[NET-OFFLINE-001] Hálózati hiba. Kérjük, próbálja újra.';
      } finally {
        if (submitBtn) submitBtn.disabled = false;
        if (buttonText) buttonText.textContent = originalButtonText;
      }
    });
  }
</script>
