---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CONTACT } from '../../lib/constants';
import { ContentImage, CardImage } from '../../components/images';
import TrainingSignupForm from '../../components/forms/TrainingSignupForm.astro';
import { t, getLocaleFromUrl, withTrailingSlash, type Locale } from '../../i18n/ui';

const trainingHero = '@assets/training-hero.jpg';
const kepzesGyakorlat = '@assets/kozmetikai-gepkezelo-kepzes-gyakorlat.jpg';
const kepzesUzleti = '@assets/kozmetikai-kepzes-uzleti-jogi-modul.jpg';
const kepzesSzalon = '@assets/kozmetikai-kepzes-szalonkornyezet.jpg';
const kepzesTanusitvany = '@assets/kozmetikai-kepzes-far-tanusitvany.jpg';

// Get locale from URL
const locale = getLocaleFromUrl(Astro.url) as Locale;

// Only this locale's trainings: hu canonical (no prefix) or `{locale}/…` translations.
const trainings = (await getCollection('trainings')).filter((training) =>
  locale === 'hu' ? !training.id.includes('/') : training.id.startsWith(`${locale}/`)
);

// Localized training detail URL prefix
const trainingUrlPrefix = locale === 'hu' ? '/kepzesek' : `/${locale}/kepzesek`;

// "Miért válassz minket?" pillérek - a bevezető bekezdés vizuális kibontása
const whyPillars = [
  {
    icon: 'health',
    title: 'Egészségügyi háttér',
    desc: 'Képzéseink valódi egészségügyi alapokra és háttérre épülnek.',
  },
  {
    icon: 'clinical',
    title: 'Klinikailag igazolt',
    desc: 'Klinikailag igazolt eredményekkel és protokollok mentén dolgozunk.',
  },
  {
    icon: 'shield',
    title: 'Biztonságos kivitelezés',
    desc: 'Hangsúlyt fektetünk a biztonságos, felelős és szakszerű kezelésekre.',
  },
];

const pillarIcons: Record<string, string> = {
  health: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />`,
  clinical: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />`,
  shield: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />`,
};
---

<BaseLayout
  title="Oktatások – Professzionális kozmetikai és esztétikai gépkezelő képzések | Skinlab"
  description="Professzionális kozmetikai gépkezelői képzések szakmai és egészségügyi háttérrel. FAR-jegyzett, B-számos tanúsítvány. Gépvásárlási kötelezettség nélkül."
  preloadImage="/images/opt/site/training-hero-828w.avif"
>
  <div>

    <!-- Hero Section -->
    <section class="bg-gradient-to-b from-gray-50 to-white">
      <div class="grid lg:grid-cols-2 items-stretch">
        <!-- Content (mobile: below image via order-2, desktop: left via order-1) -->
        <div class="flex items-center py-8 lg:py-20 px-6 sm:px-10 lg:px-16 xl:px-24 order-2 lg:order-1">
          <div>
            <div class="inline-flex items-center gap-2 bg-primary-100 text-primary-700 px-3 py-1 rounded-full text-sm font-medium mb-4">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
              FAR-jegyzett képzések
            </div>
            <h1 class="text-3xl lg:text-4xl xl:text-5xl font-bold text-gray-900 mb-4 leading-tight">
              Oktatások – Professzionális kozmetikai és esztétikai gépkezelő képzések
            </h1>
            <p class="text-lg text-gray-600 leading-relaxed mb-6">
              Professzionális kozmetikai gépkezelői képzések szakmai és egészségügyi háttérrel
            </p>
            <!-- Mobile: 3 stacked CTAs -->
            <div class="flex flex-col gap-3 lg:hidden">
              <a
                href="#jelentkezes"
                class="inline-flex items-center justify-center px-5 py-3.5 bg-primary-600 text-white font-semibold rounded-xl hover:bg-primary-700 transition-colors text-center"
              >
                Jelentkezem képzésre
              </a>
              <a
                href="#jelentkezes"
                class="inline-flex items-center justify-center px-5 py-3 bg-white text-gray-900 font-semibold rounded-xl border-2 border-gray-200 hover:border-primary-300 transition-colors text-center"
              >
                Ingyenes konzultáció
              </a>
              <a
                href={`tel:${CONTACT.phone}`}
                class="inline-flex items-center justify-center gap-2 px-5 py-3 bg-gray-100 text-gray-700 font-semibold rounded-xl hover:bg-gray-200 transition-colors text-center"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                Hívj minket: {CONTACT.phoneDisplay}
              </a>
            </div>
            <!-- Desktop: inline CTAs -->
            <div class="hidden lg:flex flex-wrap gap-4">
              <a
                href="#kepzesek"
                class="inline-flex items-center px-5 py-3 bg-primary-600 text-white font-semibold rounded-xl hover:bg-primary-700 transition-colors"
              >
                Képzések megtekintése
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              <a
                href={`tel:${CONTACT.phone}`}
                class="inline-flex items-center px-5 py-3 bg-white text-gray-700 font-semibold rounded-xl border-2 border-gray-200 hover:border-primary-300 transition-colors"
              >
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                {CONTACT.phoneDisplay}
              </a>
            </div>
          </div>
        </div>

        <!-- Hero Image (mobile: top via order-1, desktop: right via order-2) -->
        <div class="relative order-1 lg:order-2">
          <ContentImage
            src={trainingHero}
            alt="Professzionális kozmetikai gépkezelő képzés"
            class="w-full h-full object-cover"
          />
          <!-- Floating badge -->
          <div class="absolute bottom-4 left-4 bg-white rounded-xl shadow-xl p-4 hidden sm:block">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 bg-success-100 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-success-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                </svg>
              </div>
              <div>
                <div class="font-bold text-gray-900">B-számos tanúsítvány</div>
                <div class="text-sm text-gray-500">Hivatalos képzés</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Bevezető szöveg -->
    <section class="py-16 lg:py-24 bg-gradient-to-b from-primary-50/40 to-white">
      <div class="max-w-5xl mx-auto px-6 sm:px-8 lg:px-10">
        <!-- Lead -->
        <div class="max-w-3xl mx-auto text-center">
          <div class="inline-flex items-center gap-2 bg-primary-50 text-primary-600 px-4 py-1.5 rounded-full text-sm font-semibold mb-6 tracking-wide">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Miért válassz minket?
          </div>
          <p class="text-xl lg:text-2xl text-gray-700 leading-relaxed font-light">
            Oktatásainkat azok számára hoztuk létre, akik a kozmetikai és esztétikai gépek használatát nem csupán felületesen, hanem <strong class="font-semibold text-gray-900">valódi, szakmailag megalapozott tudással</strong> szeretnék elsajátítani.
          </p>
        </div>

        <!-- Pillérek: a szakmai háttér konkrét pontjai -->
        <div class="mt-12 lg:mt-16 grid gap-5 sm:grid-cols-3 lg:gap-6">
          {whyPillars.map((pillar) => (
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 lg:p-7 text-center sm:text-left transition-shadow hover:shadow-md">
              <div class="w-12 h-12 bg-gray-100 rounded-xl flex items-center justify-center mb-4 mx-auto sm:mx-0">
                <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={pillarIcons[pillar.icon]} />
              </div>
              <h3 class="font-bold text-gray-900 mb-1.5">{pillar.title}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{pillar.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Mély, átfogó tudás szekció -->
    <section class="bg-gray-50">
      <div class="grid lg:grid-cols-2 items-stretch">
        <div class="overflow-hidden">
          <ContentImage
            src={kepzesGyakorlat}
            alt="Kozmetikai gépkezelő képzés gyakorlati oktatás"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="flex items-center py-12 lg:py-16 px-6 sm:px-10 lg:px-16 xl:px-24">
          <div>
            <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-6">
              Nem egy gyors „összeszerelős" oktatás
            </h2>
            <p class="text-gray-600 leading-relaxed mb-4">
              Nálunk nem egy gyors, kapkodó, egyórás „összeszerelős" oktatást kapsz. Ahelyett, hogy csak megmutatnánk, hogyan kell elindítani a géped, mély, átfogó és gyakorlatorientált tudást adunk át.
            </p>
            <p class="text-gray-600 leading-relaxed">
              Megtanítunk helyesen kezelni, magabiztosan beállítani a paramétereket, felismerni a hibafaktorokat, és felkészítünk minden lehetséges – pozitív és negatív – eshetőségre, amellyel a vendégkezelések során találkozhatsz.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Jogi + marketing szekció (desktop: szöveg | kép, mobil: kép felül) -->
    <section class="bg-white">
      <div class="grid lg:grid-cols-2 items-stretch">
        <div class="flex items-center py-12 lg:py-16 px-6 sm:px-10 lg:px-16 xl:px-24 order-2 lg:order-1">
          <div>
            <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-6">
              Jogi szemlélet és üzleti tudás
            </h2>
            <p class="text-gray-600 leading-relaxed mb-4">
              Képzéseink jogi szemléletet is magukban hordoznak: részletesen átbeszéljük a géphasználat jogi kereteit, a vendégek tájékoztatásának kötelező elemeit, a dokumentációs követelményeket és azokat a protokollokat, amelyek a szakmai felelősséget és biztonságot szolgálják.
            </p>
            <p class="text-gray-600 leading-relaxed">
              Emellett marketing és üzleti modul is része minden oktatásnak, hogy segítsünk abban, hogyan építsd fel magabiztosan a szolgáltatásaidat, árazz, kommunikálj, és alakíts ki hosszú távon fenntartható vállalkozást.
            </p>
          </div>
        </div>
        <div class="overflow-hidden order-1 lg:order-2">
          <ContentImage
            src={kepzesUzleti}
            alt="Kozmetikai képzés jogi és üzleti modul"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </section>

    <!-- Nincs gépvásárlási kötelezettség -->
    <section class="bg-primary-50">
      <div class="grid lg:grid-cols-2 items-stretch">
        <div class="overflow-hidden">
          <ContentImage
            src={kepzesSzalon}
            alt="Kozmetikai képzés szalonkörnyezetben gépvásárlási kötelezettség nélkül"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="flex items-center py-12 lg:py-16 px-6 sm:px-10 lg:px-16 xl:px-24">
          <div>
            <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-6">
              Nincs gépvásárlási kötelezettség
            </h2>
            <p class="text-gray-600 leading-relaxed mb-4">
              Oktatásaink gépvásárlás nélkül is elérhetők, és nem helyezünk rád semmilyen nyomást a későbbi eszközbeszerzést illetően.
            </p>
            <p class="text-gray-600 leading-relaxed">
              A célunk nem az, hogy eladjunk neked egy gépet, hanem az, hogy valódi, gyakorlatban használható tudást adjunk át, és támogassuk szakmai fejlődésed – függetlenül attól, hogy nálunk vagy más forgalmazónál vásárolsz eszközöket.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Hivatalos tanúsítvány (desktop: szöveg | kép, mobil: kép felül) -->
    <section class="bg-white">
      <div class="grid lg:grid-cols-2 items-stretch">
        <div class="flex items-center py-12 lg:py-16 px-6 sm:px-10 lg:px-16 xl:px-24 order-2 lg:order-1">
          <div>
            <div class="inline-flex items-center gap-2 bg-primary-100 text-primary-700 px-3 py-1 rounded-full text-sm font-medium mb-4">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
              Hivatalos képzés
            </div>
            <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-6">
              Hivatalos, tanúsítványt adó képzések
            </h2>
            <p class="text-gray-600 leading-relaxed mb-4">
              Minden oktatásunk hivatalos keretek között zajlik, és a Felnőttképzési Adatrögzítési Rendszerben (FAR) jegyzett. A képzések sikeres elvégzése után B-számos tanúsítványt állítunk ki, amely igazolja szakmai kompetenciáidat és a tanult technológiák szakszerű alkalmazásának képességét.
            </p>
          </div>
        </div>
        <div class="overflow-hidden order-1 lg:order-2">
          <ContentImage
            src={kepzesTanusitvany}
            alt="FAR-jegyzett kozmetikai gépkezelő képzés hivatalos tanúsítvány"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </section>

    <!-- CTA sáv -->
    <section class="py-12 lg:py-16 bg-gradient-to-r from-primary-600 to-primary-700">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl lg:text-3xl font-bold text-white mb-4">
          Lépj szintet a szakmádban!
        </h2>
        <p class="text-primary-100 mb-8 max-w-2xl mx-auto text-lg leading-relaxed">
          Sajátítsd el az esztétikai technológiák biztonságos, professzionális használatát egy olyan képzési rendszerben, ahol a tudás, a biztonság és a hosszú távú szakmai támogatás az első.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="#kepzesek"
            class="inline-flex items-center justify-center px-6 py-3 bg-white text-primary-600 font-semibold rounded-xl hover:bg-gray-100 transition-colors"
          >
            Képzések megtekintése
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
          <a
            href={`tel:${CONTACT.phone}`}
            class="inline-flex items-center justify-center px-6 py-3 bg-primary-800 text-white font-semibold rounded-xl hover:bg-primary-900 transition-colors"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {CONTACT.phoneDisplay}
          </a>
        </div>
      </div>
    </section>

    <!-- Training List -->
    <section id="kepzesek" class="py-12 lg:py-16 bg-gray-50 scroll-mt-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-3">Elérhető képzéseink</h2>
          <p class="text-gray-600">Válaszd ki az érdeklődésednek megfelelő képzést</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {trainings.map((training) => {
            const detailUrl = withTrailingSlash(`${trainingUrlPrefix}/${training.id.split('/').pop()}`);
            return (
            <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-lg hover:border-primary-300 transition-all group flex flex-col">
              <!-- Training photo -->
              <a href={detailUrl} class="block aspect-[16/10] overflow-hidden bg-gray-100">
                <CardImage
                  src={training.data.image || '/images/placeholder.jpg'}
                  alt={training.data.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </a>

              <div class="p-6 flex flex-col flex-1">
                <a href={detailUrl}>
                  <h3 class="text-xl font-semibold text-gray-900 mb-2 group-hover:text-primary-600 transition-colors">
                    {training.data.name}
                  </h3>
                </a>
                <p class="text-gray-600 mb-4">{training.data.shortDescription}</p>

                <div class="space-y-2 mb-4">
                  <div class="flex items-center text-sm text-gray-600">
                    <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>Időtartam: {training.data.duration}</span>
                  </div>
                  <div class="flex items-center text-sm text-success-600 font-medium">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{training.data.priceFormatted || `${training.data.price?.toLocaleString('hu-HU')} Ft`}</span>
                  </div>
                  {training.data.certificate && (
                    <div class="flex items-center text-sm text-primary-600">
                      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                      </svg>
                      <span>{training.data.certificate}</span>
                    </div>
                  )}
                </div>

                <div class="mt-auto pt-4 border-t border-gray-100 flex items-center justify-between gap-3">
                  <a href={detailUrl} class="inline-flex items-center text-primary-600 font-medium hover:text-primary-700">
                    {t(locale, 'common.viewDetails')}
                    <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                  <a href="#jelentkezes" class="inline-flex items-center px-4 py-2 bg-cta text-white text-sm font-semibold rounded-xl hover:bg-cta-hover transition-colors shadow-sm">
                    Jelentkezés
                  </a>
                </div>
              </div>
            </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Signup Form Section - full width, CRO optimized -->
    <section id="jelentkezes" class="scroll-mt-20">
      <TrainingSignupForm />
    </section>


  </div>
</BaseLayout>
