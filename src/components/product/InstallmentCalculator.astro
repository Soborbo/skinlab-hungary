---
/**
 * InstallmentCalculator - Interactive installment estimator.
 *
 * Single source of truth: the tier logic in @/lib/installment.ts is reused
 * by the client script. Shows down payment (50%) + monthly per available term,
 * with a 1-unit / 2-unit (bundle) toggle that can unlock longer terms.
 *
 * Hungarian-only section (HUF financing). Rendered by ProductLayout when the
 * product price is above the installment minimum.
 */
import { getInstallmentInfo, INSTALLMENT_MIN } from '@/lib/installment';

interface Props {
  price: number;
  productName?: string;
}

const { price } = Astro.props;

const fmt = (n: number) => new Intl.NumberFormat('hu-HU').format(Math.round(n)) + ' Ft';

// Server-rendered initial state (single unit) for no-JS fallback.
const initial = getInstallmentInfo(price, false);
const defaultMonths = initial.months[initial.months.length - 1] ?? 0;

const rules = [
  '50% előleg vásárláskor, a fennmaradó összeg a választott futamidőre elosztva.',
  '100 000 Ft alatt nincs részletfizetés.',
  '100 000 Ft – 1 millió Ft között: 3 hónap.',
  '1–3 millió Ft között: 3 vagy 6 hónap.',
  '3 millió Ft felett: 3, 6 vagy 12 hónap.',
  'Több gép egyszerre (csomag): 3, 6 vagy 12 hónap – így alacsonyabb gépértéknél is elérhető a hosszabb futamidő.',
];
---

<section class="py-10 lg:py-12 bg-gray-50">
  <div class="calc-shell mx-auto px-2 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-6 lg:mb-8">
      <div class="inline-flex items-center gap-2 bg-primary-100 text-primary-700 text-sm font-semibold px-4 py-2 rounded-full mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
        </svg>
        Részletfizetés
      </div>
      <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-2">
        Mennyi lenne a havi részlet?
      </h2>
      <p class="text-gray-600 text-lg max-w-2xl mx-auto">
        Válaszd ki a futamidőt – megmutatjuk az előleget és a havi részletet.
      </p>
    </div>

    <!-- Calculator Card -->
    <div
      class="bg-white rounded-3xl shadow-2xl overflow-hidden"
      id="installment-calculator"
      data-price={price}
      data-min={INSTALLMENT_MIN}
    >
      <div class="grid lg:grid-cols-2">

        <!-- Input Side -->
        <div class="p-5 lg:p-8 space-y-6">
          <!-- Quantity -->
          <div>
            <span class="block text-sm font-bold text-gray-700 mb-2">Hány gépet veszel?</span>
            <div class="grid grid-cols-2 gap-2" role="group" aria-label="Mennyiség">
              <button type="button" class="qty-btn px-4 py-3 rounded-xl border-2 border-cta bg-cta-light text-cta-hover font-semibold transition-all" data-qty="1" aria-pressed="true">
                1 gép
              </button>
              <button type="button" class="qty-btn px-4 py-3 rounded-xl border-2 border-gray-200 text-gray-700 font-semibold transition-all hover:border-cta/40" data-qty="2" aria-pressed="false">
                2 gép (csomag)
              </button>
            </div>
          </div>

          <!-- Total price -->
          <div>
            <span class="block text-sm font-bold text-gray-700 mb-2">Vételár</span>
            <div class="px-4 py-3 bg-gray-50 rounded-xl text-xl font-bold text-gray-900 border border-gray-200">
              <span id="inst-total">{fmt(price)}</span>
            </div>
          </div>

          <!-- Term selector -->
          <div>
            <span class="block text-sm font-bold text-gray-700 mb-2">Futamidő</span>
            <div class="grid grid-cols-3 gap-2" id="term-buttons" role="group" aria-label="Futamidő">
              {[3, 6, 12].map((m) => (
                <button
                  type="button"
                  class="term-btn px-4 py-3 rounded-xl border-2 font-semibold transition-all disabled:opacity-40 disabled:cursor-not-allowed"
                  data-term={m}
                  aria-pressed={m === defaultMonths ? 'true' : 'false'}
                >
                  {m} hó
                </button>
              ))}
            </div>
            <p class="text-xs text-gray-400 mt-2">A választható futamidők a vételártól függnek.</p>
          </div>
        </div>

        <!-- Results Side -->
        <div class="bg-gradient-to-br from-cta to-cta-hover p-5 lg:p-8 text-white flex flex-col justify-center relative overflow-hidden">
          <div class="absolute top-0 right-0 w-56 h-56 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>

          <div class="relative z-10" id="inst-results">
            <!-- Monthly - hero -->
            <div class="text-center mb-8">
              <div class="text-sm font-semibold text-white/70 uppercase tracking-widest mb-2">Havi részlet</div>
              <div class="flex items-baseline justify-center gap-2">
                <span class="text-5xl lg:text-6xl font-black leading-none" id="inst-monthly">{initial.available ? fmt(initial.monthly[defaultMonths as 3|6|12]) : '–'}</span>
                <span class="text-xl font-semibold text-white/70">/ hó</span>
              </div>
              <div class="text-sm text-white/70 mt-1"><span id="inst-term-label">{defaultMonths}</span> hónapon át</div>
            </div>

            <div class="h-px bg-white/25 mb-8"></div>

            <div class="grid grid-cols-2 gap-4">
              <div class="bg-white/10 backdrop-blur rounded-xl p-4 text-center">
                <div class="text-xs font-semibold text-white/70 uppercase tracking-wide mb-1">Előleg (50%)</div>
                <div class="text-lg lg:text-xl font-bold" id="inst-down">{initial.available ? fmt(initial.downPayment) : '–'}</div>
              </div>
              <div class="bg-white/10 backdrop-blur rounded-xl p-4 text-center">
                <div class="text-xs font-semibold text-white/70 uppercase tracking-wide mb-1">Részletre osztva</div>
                <div class="text-lg lg:text-xl font-bold" id="inst-remaining">{initial.available ? fmt(initial.remaining) : '–'}</div>
              </div>
            </div>

            <p class="text-xs text-white/70 text-center mt-6">
              Tájékoztató kalkuláció – a pontos feltételeket konzultáción egyeztetjük.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Rules -->
    <div class="mt-6 bg-white rounded-2xl border border-gray-100 p-5 lg:p-6">
      <h3 class="font-bold text-gray-900 mb-3">Hogyan működik?</h3>
      <ul class="space-y-2">
        {rules.map((r) => (
          <li class="flex items-start gap-2.5 text-sm text-gray-600">
            <svg class="w-5 h-5 text-cta flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>{r}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<script>
  import { getInstallmentInfo, type InstallmentMonths } from '@/lib/installment';

  function initInstallmentCalculator() {
    const root = document.getElementById('installment-calculator');
    if (!root) return;

    const unitPrice = parseFloat(root.getAttribute('data-price') || '0') || 0;

    const fmt = (n: number) => new Intl.NumberFormat('hu-HU').format(Math.round(n)) + ' Ft';

    const qtyBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('.qty-btn'));
    const termBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('.term-btn'));
    const totalEl = root.querySelector('#inst-total');
    const monthlyEl = root.querySelector('#inst-monthly');
    const downEl = root.querySelector('#inst-down');
    const remainingEl = root.querySelector('#inst-remaining');
    const termLabelEl = root.querySelector('#inst-term-label');

    let qty = 1;
    let term: InstallmentMonths | 0 = 0;

    function activate(btn: HTMLButtonElement, on: boolean, accent: boolean) {
      btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      btn.classList.toggle('border-cta', on);
      btn.classList.toggle('bg-cta-light', on);
      btn.classList.toggle('text-cta-hover', on);
      btn.classList.toggle('border-gray-200', !on);
      btn.classList.toggle('text-gray-700', !on);
    }

    function render() {
      const info = getInstallmentInfo(unitPrice * qty, qty >= 2);

      if (totalEl) totalEl.textContent = fmt(unitPrice * qty);

      // Enable/disable term buttons by availability
      termBtns.forEach((b) => {
        const m = parseInt(b.dataset.term || '0', 10) as InstallmentMonths;
        const ok = info.months.includes(m);
        b.disabled = !ok;
        if (!ok && term === m) term = 0;
      });

      // Pick longest available term if none selected
      if (!term || !info.months.includes(term as InstallmentMonths)) {
        term = info.months[info.months.length - 1] ?? 0;
      }

      termBtns.forEach((b) => {
        const m = parseInt(b.dataset.term || '0', 10);
        activate(b, m === term, true);
      });

      if (info.available && term) {
        monthlyEl && (monthlyEl.textContent = fmt(info.monthly[term as InstallmentMonths]));
        downEl && (downEl.textContent = fmt(info.downPayment));
        remainingEl && (remainingEl.textContent = fmt(info.remaining));
        termLabelEl && (termLabelEl.textContent = String(term));
      } else {
        monthlyEl && (monthlyEl.textContent = '–');
        downEl && (downEl.textContent = '–');
        remainingEl && (remainingEl.textContent = '–');
      }
    }

    qtyBtns.forEach((b) => {
      b.addEventListener('click', () => {
        qty = parseInt(b.dataset.qty || '1', 10);
        qtyBtns.forEach((x) => activate(x, x === b, true));
        render();
      });
    });

    termBtns.forEach((b) => {
      b.addEventListener('click', () => {
        if (b.disabled) return;
        term = parseInt(b.dataset.term || '0', 10) as InstallmentMonths;
        render();
      });
    });

    render();
  }

  document.addEventListener('astro:page-load', initInstallmentCalculator);
  if (document.readyState !== 'loading') initInstallmentCalculator();
</script>

<style>
  /* Mobilon a kalkulátor közel teljes szélességű (csak ~8px oldalpadding),
     a 80vw-os korlát csak tablet/desktop méretben él. */
  .calc-shell {
    max-width: 100%;
  }
  @media (min-width: 640px) {
    .calc-shell {
      max-width: min(80vw, 64rem);
    }
  }
</style>
