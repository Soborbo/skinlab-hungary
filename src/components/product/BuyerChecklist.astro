---
/**
 * BuyerChecklist - Mire figyeljen vásárlás előtt?
 *
 * Props-based: content comes from the page level via loadProductContent.
 * No internal content maps.
 */

import type { Locale } from '@/i18n';
import { t } from '@/i18n';

interface Props {
  locale: Locale;
  headline?: string;
  subtitle?: string;
  items: string[];
}

const { locale, headline, subtitle, items } = Astro.props;
---

{items.length > 0 && (
  <section class="py-12 lg:py-16 bg-amber-50/60">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-2 bg-amber-100 text-amber-700 text-sm font-semibold px-4 py-2 rounded-full mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
          </svg>
          {t(locale, 'product.buyerChecklistBadge')}
        </div>
        <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-3">
          {headline || t(locale, 'product.buyerChecklistTitle')}
        </h2>
        {subtitle && (
          <p class="text-gray-600">{subtitle}</p>
        )}
      </div>

      <!-- Checklist Items -->
      <div class="bg-white rounded-2xl shadow-lg p-8">
        <ol class="space-y-4">
          {items.map((item, index) => (
            <li class="flex items-start gap-4">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center font-bold text-sm mt-0.5">
                {index + 1}
              </div>
              <p class="text-gray-700 leading-relaxed pt-1">{item}</p>
            </li>
          ))}
        </ol>

        <!-- Footer note -->
        <div class="mt-8 pt-6 border-t border-gray-100">
          <div class="flex items-start gap-3 text-sm text-gray-500">
            <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p>{t(locale, 'product.buyerChecklistNote')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
)}
