---
/**
 * ProductCTA - Reusable call-to-action banner for product pages
 *
 * Three visual variants:
 * - light: gray-50 bg, border-y, horizontal layout
 * - accent: primary-50 bg, centered stacked
 * - primary: primary-600 bg, white text, centered stacked
 */

import type { Locale } from '@/i18n';
import { t, getLocalizedUrl } from '@/i18n';
import { CONTACT } from '@/lib/constants';

interface Props {
  locale: Locale;
  productName: string;
  variant: 'light' | 'accent' | 'primary';
  headline?: string;
  subtitle?: string;
  buttonLabel?: string;
  phoneLabel?: string;
  showPhone?: boolean;
}

const {
  locale,
  productName,
  variant,
  headline,
  subtitle,
  buttonLabel,
  showPhone = true,
} = Astro.props;

const contactUrl = getLocalizedUrl(locale, '/kapcsolat');

// Resolve text: props first, then i18n defaults
const displayHeadline = headline || t(locale, 'cta.defaultHeadline', { productName });
const displaySubtitle = subtitle || t(locale, 'cta.defaultSubtitle', { productName });
const displayButton = buttonLabel || t(locale, 'cta.defaultButton');
const displayPhone = t(locale, 'cta.defaultPhone');
---

{variant === 'light' && (
  <div class="py-8 bg-gray-50 border-y border-gray-200">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-gray-700 font-medium text-center sm:text-left">{displayHeadline}</p>
      <div class="flex gap-3 shrink-0">
        <a href={contactUrl} class="inline-flex items-center px-5 py-2.5 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors text-sm">
          {displayButton}
        </a>
        {showPhone && (
          <a href={CONTACT.phoneTel} class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-gray-700 font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {displayPhone}
          </a>
        )}
      </div>
    </div>
  </div>
)}

{variant === 'accent' && (
  <div class="py-10 bg-primary-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-lg font-semibold text-gray-900 mb-2">{displayHeadline}</p>
      {displaySubtitle && <p class="text-gray-600 mb-6">{displaySubtitle}</p>}
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={contactUrl} class="inline-flex items-center justify-center px-6 py-3 bg-primary-600 text-white font-semibold rounded-xl hover:bg-primary-700 transition-colors">
          {displayButton}
        </a>
        {showPhone && (
          <a href={CONTACT.phoneTel} class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white text-gray-700 font-semibold rounded-xl border border-gray-300 hover:bg-gray-50 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {CONTACT.phoneDisplay}
          </a>
        )}
      </div>
    </div>
  </div>
)}

{variant === 'primary' && (
  <section class="py-16 bg-primary-600">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl lg:text-3xl font-bold text-white mb-4">
        {displayHeadline}
      </h2>
      <p class="text-lg text-primary-100 mb-8">
        {displaySubtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={contactUrl} class="inline-flex items-center justify-center px-8 py-4 bg-white text-primary-600 font-semibold rounded-xl hover:bg-primary-50 transition-colors">
          {displayButton}
        </a>
        {showPhone && (
          <a href={CONTACT.phoneTel} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-primary-500 text-white font-semibold rounded-xl hover:bg-primary-400 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {CONTACT.phoneDisplay}
          </a>
        )}
      </div>
    </div>
  </section>
)}
