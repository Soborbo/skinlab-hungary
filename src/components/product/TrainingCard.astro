---
/**
 * TrainingCard - Képzés szekció képpel és árkártyával
 *
 * Bal oldal: képzés tartalom lista
 * Jobb oldal: kép + árkártya CTA-val
 * Slug-alapú tartalom, kategória fallback.
 */

import { Image } from 'astro:assets';
import trainingImage from '../../assets/training-image.jpg';

interface TrainingContent {
  headline: string;
  badge: string;
  intro: string;
  priceLabel?: string;
  items: string[];
  closingParagraphs?: string[];
  price: string;
  originalPrice?: string;
  priceNote: string;
  freeText?: string;
  duration: string;
  ctaText: string;
}

interface Props {
  productName: string;
  productSlug?: string;
  category: string;
}

const { productName, productSlug, category } = Astro.props;

const productTraining: Record<string, TrainingContent> = {
  'hydrascan-pro': {
    headline: 'Gépkezelői oktatás – hivatalos felnőttképzés keretében',
    badge: 'Hivatalos tanúsítvánnyal',
    intro: 'A HYDRASCAN PRO készülékhez elérhető egy professzionális gépkezelői oktatás, amelyet hivatalosan bejelentett felnőttképzés keretein belül biztosítunk. Az oktatás célja, hogy a résztvevők teljes körű, elméleti és gyakorlati tudást szerezzenek a készülék szakszerű és biztonságos használatáról.',
    priceLabel: 'Képzés díja: 69.990 Ft',
    items: [
      'A HYDRASCAN PRO működési elve, technológiái és kezelőfejei',
      'Az intelligens bőranalízis rendszer értelmezése és gyakorlati alkalmazása',
      'Kezelési protokollok különböző bőrtípusokhoz és problémákhoz',
      'Vendégkommunikáció és kezelési napló vezetése',
      'Előtte–utána dokumentáció készítése',
      'Gyakorlati kezelések modelleken',
    ],
    closingParagraphs: [
      'Modellt természetesen hozhatsz a képzésre, így valós környezetben tudod elsajátítani a kezelési technikákat, biztonságos és felügyelt oktatási környezetben.',
      'A képzés elvégzése után hivatalos tanúsítványt állítunk ki, amely igazolja a HYDRASCAN PRO készülék szakszerű kezeléséhez szükséges kompetenciát.',
      'Ez a tudás nemcsak a mindennapi munkádban jelent óriási segítséget, hanem abban is, hogy még magabiztosabban, professzionális szinten nyújtsd szolgáltatásaidat vendégeid számára.',
      'Amennyiben érdekes lehet számodra a tanfolyami lehetőség, kérlek vedd fel velünk a kapcsolatot elérhetőségeink egyikén, időpont-egyeztetés céljából!',
    ],
    price: '69.990 Ft',
    priceNote: 'értékű képzés',
    freeText: 'INGYENES a gépvásárlás mellé!',
    duration: 'Egynapos intenzív képzés',
    ctaText: 'Érdekel a képzés',
  },
};

const categoryTraining: Record<string, TrainingContent> = {
  'hydrafacial': {
    headline: 'Professzionális gépkezelői képzés',
    badge: 'FAR tanúsítvánnyal',
    intro: 'Minden hydrofacial készülékünkhöz elérhető személyes betanítás és hivatalos gépkezelői képzés.',
    items: [
      'A készülék működési elve és technológiái',
      'Kezelési protokollok különböző bőrtípusokhoz',
      'Gyakorlati kezelések modelleken',
      'Vendégkommunikáció',
    ],
    price: 'Kérjen ajánlatot',
    priceNote: 'Hivatalos felnőttképzés',
    duration: 'Egynapos képzés',
    ctaText: 'Érdekel a képzés',
  },
};

const content = (productSlug && productTraining[productSlug]) || categoryTraining[category];
if (!content) return;
---

<section class="py-16 bg-gray-50" id="kepzes">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      <!-- Left: Training content -->
      <div>
        <div class="inline-flex items-center gap-2 bg-success-50 text-success-700 font-semibold px-4 py-2 rounded-lg text-sm mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />
          </svg>
          {content.badge}
        </div>

        <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-4 leading-tight">
          {content.headline}
        </h2>

        <p class="text-gray-600 mb-6 leading-relaxed">
          {content.intro}
        </p>

        {content.closingParagraphs && (
          <div class="space-y-4">
            {content.closingParagraphs.map((paragraph) => (
              <p class="text-gray-600 leading-relaxed">{paragraph}</p>
            ))}
          </div>
        )}
      </div>

      <!-- Right: Image + Price card -->
      <div class="space-y-6">
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <Image
            src={trainingImage}
            alt="SkinLab gépkezelői képzés"
            class="w-full h-auto object-cover aspect-[16/10]"
            widths={[400, 600]}
            sizes="(max-width: 1024px) 100vw, 50vw"
            loading="lazy"
          />
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-lg border border-gray-200 text-center">
          <h3 class="text-lg font-bold text-gray-900 mb-3">Gépkezelői képzés</h3>

          <div class="text-3xl font-extrabold text-gray-900 mb-1">
            {content.price}
          </div>
          <div class="text-sm text-gray-500 mb-3">
            {content.priceNote}
          </div>

          {content.freeText && (
            <div class="bg-success-50 text-success-700 font-bold text-base px-4 py-3 rounded-xl mb-5">
              {content.freeText}
            </div>
          )}

          <h4 class="text-left text-sm font-semibold text-gray-900 mb-3">A képzés tartalma:</h4>
          <ul class="text-left space-y-2 mb-6">
            {content.items.map((item) => (
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm text-gray-600">{item}</span>
              </li>
            ))}
          </ul>

          <a
            href="/kapcsolat"
            class="block w-full px-6 py-4 bg-primary-600 text-white font-semibold rounded-xl hover:bg-primary-700 transition-colors text-center"
          >
            {content.ctaText}
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
