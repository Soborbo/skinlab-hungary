---
/**
 * Breadcrumb - Product page breadcrumb navigation
 *
 * Props-based: locale for i18n. All labels use t(locale, ...).
 */
import type { Locale } from '@/i18n';
import { t, getLocalizedUrl } from '@/i18n';

interface Props {
  locale: Locale;
  categorySlug: string;
  categoryName: string;
  productName: string;
}

const { locale, categorySlug, categoryName, productName } = Astro.props;
---

<nav class="bg-gray-100 border-b" aria-label="Breadcrumb">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
    <ol class="flex items-center gap-2 text-sm">
      <li>
        <a href={getLocalizedUrl(locale, '/')} class="text-gray-500 hover:text-primary-600">{t(locale, 'breadcrumb.home')}</a>
      </li>
      <li class="text-gray-400">&rsaquo;</li>
      <li>
        <a href={getLocalizedUrl(locale, `/${categorySlug}`)} class="text-gray-500 hover:text-primary-600">{categoryName}</a>
      </li>
      <li class="text-gray-400">&rsaquo;</li>
      <li class="text-gray-900 font-medium truncate max-w-[200px]">{productName}</li>
    </ol>
  </div>
</nav>
