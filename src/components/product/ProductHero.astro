---
/**
 * ProductHero - Product hero section.
 *
 * Layout: image gallery on the LEFT, product info on the RIGHT (desktop).
 * On mobile the gallery stacks on top, info below.
 *
 * The hero gallery shows the main image plus all gallery images as a carousel
 * with thumbnails below it. Trust/USP badges live in the USPStrip, and
 * installment info in the InstallmentCalculator section.
 */
import ProductGallery from './ProductGallery.astro';
import AddToCartButton from '../cart/AddToCartButton.astro';
import { CONTACT } from '@/lib/constants';
import type { Locale } from '@/i18n';
import { t, getLocalizedUrl, formatPrice } from '@/i18n';

interface VariantImageSet {
  value: string;
  images: string[];
}

interface Variant {
  sku: string;
  name: string;
  value: string;
  price: number | null;
  image?: string;
  images?: string[];
}

interface Props {
  locale: Locale;
  slug: string;
  name: string;
  sku: string;
  shortDescription?: string;
  description?: string;
  price: number | null;
  salePrice?: number | null;
  image: string;
  gallery: string[];
  availability: 'in_stock' | 'preorder' | 'out_of_stock';
  hasVariants: boolean;
  variants: Variant[];
  featured?: boolean;
  categorySlug: string;
  variantImageSets?: VariantImageSet[];
}

const {
  locale,
  slug,
  name,
  sku,
  shortDescription,
  description,
  price,
  salePrice,
  image,
  gallery,
  hasVariants,
  variants,
  featured,
  categorySlug,
  variantImageSets,
} = Astro.props;

// Format price with locale
const displayPrice = (p: number | null) => {
  if (!p) return null;
  return formatPrice(p, locale);
};

// Hero gallery: main image + all gallery images (deduped) → carousel with
// thumbnails. Variant products keep per-variant switching via variantImageSets
// (ProductGallery ignores `images` in variant mode).
const heroImages = [...new Set([image, ...(gallery ?? [])])].filter(Boolean);
---

<section class="bg-white py-6 lg:py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 lg:items-start">

      <!-- Product Info (right on desktop, below on mobile) -->
      <div class="order-2">
        <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          {name}
        </h1>

        <p class="text-lg text-gray-600 mb-6">
          {shortDescription || description?.slice(0, 200)}
        </p>

        <!-- Variants (if any) -->
        {hasVariants && variants.length > 0 && (
          <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-2">
              {t(locale, 'product.selectVariant')}
            </label>
            <div class="flex flex-wrap gap-2">
              {variants.map((variant, i) => (
                <button
                  type="button"
                  class={`px-4 py-2 rounded-lg border-2 text-sm font-medium transition-all ${
                    i === 0
                      ? 'border-primary-600 bg-primary-50 text-primary-700'
                      : 'border-gray-200 hover:border-primary-300 text-gray-700'
                  }`}
                  data-variant={variant.sku}
                  data-variant-value={variant.value}
                  data-variant-image={variant.image}
                >
                  {variant.name}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Price -->
        <div class="mb-6">
          {price ? (
            <>
              {salePrice ? (
                <div class="flex items-baseline gap-3">
                  <div class="text-3xl font-bold text-red-600">{displayPrice(salePrice)}</div>
                  <div class="text-xl text-gray-400 line-through">{displayPrice(price)}</div>
                </div>
              ) : (
                <div class="text-3xl font-bold text-gray-900">{displayPrice(price)}</div>
              )}
              <div class="text-sm text-gray-500 mt-1">{t(locale, 'product.grossPrice')}</div>
            </>
          ) : (
            <div class="text-2xl font-bold text-primary-600">{t(locale, 'product.priceOnRequest')}</div>
          )}
        </div>

        <!-- Add to cart -->
        <div class="mb-4">
          <AddToCartButton
            locale={locale}
            slug={slug}
            sku={sku}
            name={name}
            categorySlug={categorySlug}
            image={image}
            price={salePrice ?? price}
            hasVariants={hasVariants}
            variants={variants}
          />
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={getLocalizedUrl(locale, '/konzultacio')}
            class="flex-1 inline-flex items-center justify-center px-6 py-4 bg-primary-50 text-primary-700 font-semibold rounded-xl hover:bg-primary-100 transition-colors"
          >
            {t(locale, 'product.freeConsultation')}
          </a>
          <a
            href={CONTACT.phoneTel}
            class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-4 bg-success-50 text-success-700 font-semibold rounded-xl hover:bg-success-100 transition-colors"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {t(locale, 'product.callNow')}
          </a>
        </div>

        <!-- SKU -->
        <div class="mt-6 text-xs text-gray-400">
          {t(locale, 'product.sku')}: {sku}
        </div>
      </div>

      <!-- Image gallery (left on desktop, top on mobile) -->
      <div class="order-1">
        <ProductGallery
          images={heroImages}
          productName={name}
          badges={{
            featured: featured,
            variantCount: hasVariants ? variants.length : undefined
          }}
          variantImageSets={variantImageSets}
        />
      </div>
    </div>
  </div>
</section>

<script>
  // Variant selection functionality
  document.querySelectorAll('[data-variant]').forEach(btn => {
    btn.addEventListener('click', () => {
      // Update active state
      document.querySelectorAll('[data-variant]').forEach(b => {
        b.classList.remove('border-primary-600', 'bg-primary-50', 'text-primary-700');
        b.classList.add('border-gray-200', 'text-gray-700');
      });
      btn.classList.remove('border-gray-200', 'text-gray-700');
      btn.classList.add('border-primary-600', 'bg-primary-50', 'text-primary-700');

      // Dispatch variant-change event for gallery switching
      const variantValue = (btn as HTMLElement).getAttribute('data-variant-value');
      if (variantValue) {
        document.dispatchEvent(new CustomEvent('variant-change', {
          detail: { value: variantValue }
        }));
      }
    });
  });
</script>
