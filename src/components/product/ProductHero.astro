---
/**
 * ProductHero - Product hero section with gallery and product info
 *
 * Composes: ProductGallery (left) + ProductInfo (right: availability, title,
 * description, variants, price, InstallmentBadge, trust badges, CTAs, SKU).
 *
 * Props-based: locale for i18n. All labels use t(locale, 'product.*').
 */
import ProductGallery from './ProductGallery.astro';
import InstallmentBadge from '../ui/InstallmentBadge.astro';
import { CONTACT } from '@/lib/constants';
import type { Locale } from '@/i18n';
import { t, getLocalizedUrl, formatPrice } from '@/i18n';

interface VariantImageSet {
  value: string;
  images: string[];
}

interface Variant {
  sku: string;
  name: string;
  value: string;
  price: number | null;
  image?: string;
  images?: string[];
}

interface Props {
  locale: Locale;
  name: string;
  sku: string;
  shortDescription?: string;
  description?: string;
  price: number | null;
  image: string;
  gallery: string[];
  availability: 'in_stock' | 'preorder' | 'out_of_stock';
  hasVariants: boolean;
  variants: Variant[];
  featured?: boolean;
  categorySlug: string;
  variantImageSets?: VariantImageSet[];
}

const {
  locale,
  name,
  sku,
  shortDescription,
  description,
  price,
  image,
  gallery,
  availability,
  hasVariants,
  variants,
  featured,
  categorySlug,
  variantImageSets,
} = Astro.props;

// Format price with locale
const displayPrice = (p: number | null) => {
  if (!p) return null;
  return formatPrice(p, locale);
};

// Availability info with i18n labels
const availabilityInfo: Record<string, { label: string; color: string; icon: string }> = {
  in_stock: { label: t(locale, 'product.inStock'), color: 'success', icon: 'check' },
  preorder: { label: t(locale, 'product.preorder'), color: 'amber', icon: 'clock' },
  out_of_stock: { label: t(locale, 'product.outOfStock'), color: 'gray', icon: 'x' },
};
const availStatus = availabilityInfo[availability];

// All images for gallery
const allImages = [image, ...gallery].filter(Boolean);

// Trust badges with i18n keys
const trustBadges = [
  { icon: 'shield-check', labelKey: 'trust.warranty' },
  { icon: 'truck', labelKey: 'trust.shipping' },
  { icon: 'graduation-cap', labelKey: 'trust.training' },
  { icon: 'wrench', labelKey: 'trust.service' },
];

// Trust badge icons
const icons: Record<string, string> = {
  'shield-check': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,
  'truck': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" />`,
  'graduation-cap': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />`,
  'wrench': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`,
};
---

<section class="bg-white py-6 lg:py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16">

      <!-- Media Gallery -->
      <ProductGallery
        images={allImages}
        productName={name}
        badges={{
          featured: featured,
          variantCount: hasVariants ? variants.length : undefined
        }}
        variantImageSets={variantImageSets}
      />

      <!-- Product Info -->
      <div>
        <!-- Availability Badge -->
        <div class={`inline-flex items-center gap-2 px-3 py-1 rounded-full text-sm font-medium mb-4 ${
          availStatus.color === 'success' ? 'bg-success-50 text-success-600' :
          availStatus.color === 'amber' ? 'bg-amber-50 text-amber-600' :
          'bg-gray-100 text-gray-600'
        }`}>
          {availStatus.icon === 'check' && (
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
          )}
          {availStatus.icon === 'clock' && (
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          )}
          {availStatus.label}
        </div>

        <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
          {name}
        </h1>

        <p class="text-lg text-gray-600 mb-6">
          {shortDescription || description?.slice(0, 200)}
        </p>

        <!-- Variants (if any) -->
        {hasVariants && variants.length > 0 && (
          <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-2">
              {t(locale, 'product.selectVariant')}
            </label>
            <div class="flex flex-wrap gap-2">
              {variants.map((variant, i) => (
                <button
                  type="button"
                  class={`px-4 py-2 rounded-lg border-2 text-sm font-medium transition-all ${
                    i === 0
                      ? 'border-primary-600 bg-primary-50 text-primary-700'
                      : 'border-gray-200 hover:border-primary-300 text-gray-700'
                  }`}
                  data-variant={variant.sku}
                  data-variant-value={variant.value}
                  data-variant-image={variant.image}
                >
                  {variant.name}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Price -->
        <div class="mb-6">
          {price ? (
            <>
              <div class="text-3xl font-bold text-gray-900">{displayPrice(price)}</div>
              <div class="text-sm text-gray-500 mt-1">{t(locale, 'product.grossPrice')}</div>
            </>
          ) : (
            <div class="text-2xl font-bold text-primary-600">{t(locale, 'product.priceOnRequest')}</div>
          )}
        </div>

        <!-- Installment Payment Info -->
        <InstallmentBadge price={price || 0} class="mb-6" />

        <!-- Trust badges mini -->
        <div class="grid grid-cols-2 gap-3 mb-8">
          {trustBadges.map((badge) => (
            <div class="flex items-center gap-2 text-sm">
              <svg class="w-5 h-5 text-primary-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={icons[badge.icon]} />
              <span class="text-gray-700">{t(locale, badge.labelKey)}</span>
            </div>
          ))}
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={getLocalizedUrl(locale, '/kapcsolat')}
            class="flex-1 inline-flex items-center justify-center px-6 py-4 bg-primary-600 text-white font-semibold rounded-xl hover:bg-primary-700 transition-colors shadow-lg"
          >
            {t(locale, 'product.freeConsultation')}
          </a>
          <a
            href={CONTACT.phoneTel}
            class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-4 bg-success-50 text-success-700 font-semibold rounded-xl hover:bg-success-100 transition-colors"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {t(locale, 'product.callNow')}
          </a>
        </div>

        <!-- SKU -->
        <div class="mt-6 text-xs text-gray-400">
          {t(locale, 'product.sku')}: {sku}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Variant selection functionality
  document.querySelectorAll('[data-variant]').forEach(btn => {
    btn.addEventListener('click', () => {
      // Update active state
      document.querySelectorAll('[data-variant]').forEach(b => {
        b.classList.remove('border-primary-600', 'bg-primary-50', 'text-primary-700');
        b.classList.add('border-gray-200', 'text-gray-700');
      });
      btn.classList.remove('border-gray-200', 'text-gray-700');
      btn.classList.add('border-primary-600', 'bg-primary-50', 'text-primary-700');

      // Dispatch variant-change event for gallery switching
      const variantValue = (btn as HTMLElement).getAttribute('data-variant-value');
      if (variantValue) {
        document.dispatchEvent(new CustomEvent('variant-change', {
          detail: { value: variantValue }
        }));
      }
    });
  });
</script>
