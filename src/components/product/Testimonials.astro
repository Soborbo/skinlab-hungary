---
/**
 * Testimonials - Vásárlói vélemények szekció
 *
 * Props-based: content comes from the page level via loadProductContent.
 * No internal content maps.
 */

import type { Locale } from '@/i18n';
import { t } from '@/i18n';
import type { ProductContentTestimonial } from '@/lib/types/product-content';

interface Props {
  locale: Locale;
  testimonials: ProductContentTestimonial[];
  productName: string;
}

const { locale, testimonials, productName } = Astro.props;

// Star rating component
const renderStars = (rating: number = 5) => {
  return Array(5).fill(0).map((_, i) => i < rating ? 'filled' : 'empty');
};
---

{testimonials.length > 0 && (
  <section class="py-12 lg:py-16 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-10">
        <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-3">
          {t(locale, 'product.testimonialsTitle')}
        </h2>
        <p class="text-gray-600">
          {t(locale, 'product.testimonialsSubtitle', { productName })}
        </p>
      </div>

      <!-- Testimonials Grid -->
      <div class:list={[
        "grid gap-6",
        testimonials.length === 1 ? "max-w-xl mx-auto" : testimonials.length === 2 ? "md:grid-cols-2 max-w-4xl mx-auto" : "md:grid-cols-2 lg:grid-cols-3"
      ]}>
        {testimonials.slice(0, 3).map((testimonial) => (
          <div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow border border-gray-100 flex flex-col h-full">
            <!-- Stars + Date -->
            <div class="flex items-center justify-between mb-4">
              <div class="flex gap-1">
                {renderStars(testimonial.rating).map((star) => (
                  <svg
                    class={`w-5 h-5 ${star === 'filled' ? 'text-yellow-400' : 'text-gray-200'}`}
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
              {testimonial.date && (
                <span class="text-xs text-gray-400">{testimonial.date}</span>
              )}
            </div>

            <!-- Quote -->
            <blockquote class="text-gray-700 leading-relaxed flex-grow review-quote" set:html={`"${testimonial.text}"`} />

            <!-- Author - always at bottom -->
            <div class="flex items-center gap-3 mt-6 pt-4 border-t border-gray-100">
              {testimonial.image ? (
                <img
                  src={testimonial.image}
                  alt={testimonial.name}
                  class="w-12 h-12 rounded-full object-cover"
                />
              ) : (
                <div class="w-12 h-12 rounded-full bg-primary-100 flex items-center justify-center shrink-0">
                  <span class="text-primary-600 font-semibold text-lg">
                    {testimonial.name.charAt(0)}
                  </span>
                </div>
              )}
              <div>
                <div class="font-semibold text-gray-900">{testimonial.name}</div>
                {(testimonial.role || testimonial.location) && (
                  <div class="text-sm text-gray-500">
                    {testimonial.role}{testimonial.location && `, ${testimonial.location}`}
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>
)}
