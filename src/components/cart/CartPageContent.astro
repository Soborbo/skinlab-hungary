---
/**
 * CartPageContent - a /kosar oldal tartalma.
 *
 * A `locale` prop alapján fordít; a tételeket a kliens script tölti a
 * localStorage-alapú kosár store-ból. A root (`kosar.astro`) és a
 * `[locale]/kosar.astro` is csak egy vékony wrapper e komponens köré.
 */
import { t, getLocalizedUrl, type Locale } from '@/i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const checkoutUrl = getLocalizedUrl(locale, '/megrendeles');
const productsUrl = getLocalizedUrl(locale, '/termekek');
---

<section class="bg-gray-50 min-h-[60vh] py-10 lg:py-14">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-8">{t(locale, 'cart.title')}</h1>

    <!-- Üres állapot -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm py-16 px-6 text-center" style="display:none" data-cart-empty>
      <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-gray-100 flex items-center justify-center">
        <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
        </svg>
      </div>
      <h2 class="text-xl font-semibold text-gray-900 mb-2">{t(locale, 'cart.empty')}</h2>
      <p class="text-gray-600 mb-8">{t(locale, 'cart.emptyDesc')}</p>
      <a
        href={productsUrl}
        class="inline-flex items-center px-6 py-3 bg-[#ce2252] text-white font-semibold rounded-xl hover:bg-[#a01c42] transition-colors shadow-md"
      >
        {t(locale, 'cart.browseProducts')}
      </a>
    </div>

    <!-- Kosár tartalom -->
    <div class="grid lg:grid-cols-3 gap-8 items-start" style="display:none" data-cart-content>

      <!-- Bal: tételek -->
      <div class="lg:col-span-2 space-y-4" data-cart-items></div>

      <!-- Jobb: összesítő -->
      <aside class="lg:sticky lg:top-24 bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
        <h2 class="text-lg font-bold text-gray-900 mb-4">{t(locale, 'cart.title')}</h2>
        <div class="flex items-center justify-between py-2 border-b border-gray-100">
          <span class="text-gray-600">{t(locale, 'cart.subtotal')}</span>
          <span class="font-semibold text-gray-900" data-cart-subtotal>0</span>
        </div>
        <div class="flex items-center justify-between py-3 mb-1">
          <span class="text-base font-bold text-gray-900">{t(locale, 'cart.total')}</span>
          <span class="text-xl font-bold text-gray-900" data-cart-total>0</span>
        </div>
        <p class="text-xs text-gray-400 mb-5">{t(locale, 'cart.priceNote')}</p>
        <a
          href={checkoutUrl}
          class="block w-full text-center px-6 py-3.5 bg-[#ce2252] text-white font-semibold rounded-xl hover:bg-[#a01c42] transition-colors shadow-md"
        >
          {t(locale, 'cart.checkout')}
        </a>
        <a
          href={productsUrl}
          class="block w-full text-center px-6 py-2.5 mt-2 text-[#ce2252] font-medium text-sm hover:underline"
        >
          {t(locale, 'cart.continueShopping')}
        </a>
      </aside>
    </div>
  </div>
</section>

<script
  type="application/json"
  data-cart-page-i18n
  set:html={JSON.stringify({
    locale,
    unitPrice: t(locale, 'cart.unitPrice'),
    lineTotal: t(locale, 'cart.lineTotal'),
    remove: t(locale, 'cart.remove'),
    priceOnRequest: t(locale, 'cart.priceOnRequest'),
    quantity: t(locale, 'cart.quantity'),
  })}
></script>

<script>
  import {
    getCartSummary,
    removeFromCart,
    updateQty,
    formatPrice,
    CART_EVENTS,
    type CartItem,
  } from '@/lib/cart/store';

  function initCartPage() {
    const emptyEl = document.querySelector<HTMLElement>('[data-cart-empty]');
    const contentEl = document.querySelector<HTMLElement>('[data-cart-content]');
    const itemsEl = document.querySelector<HTMLElement>('[data-cart-items]');
    const subtotalEl = document.querySelector<HTMLElement>('[data-cart-subtotal]');
    const totalEl = document.querySelector<HTMLElement>('[data-cart-total]');
    if (!emptyEl || !contentEl || !itemsEl) return;

    const i18nEl = document.querySelector('[data-cart-page-i18n]');
    const i18n = i18nEl ? JSON.parse(i18nEl.textContent || '{}') : {};
    const locale: string = i18n.locale || 'hu';

    function escapeHtml(str: string): string {
      return str.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] || c));
    }

    function itemCard(item: CartItem): string {
      const hasPrice = typeof item.price === 'number';
      const unit = hasPrice ? formatPrice(item.price as number, locale) : (i18n.priceOnRequest || '');
      const line = hasPrice ? formatPrice((item.price as number) * item.qty, locale) : (i18n.priceOnRequest || '');
      const variant = item.variantName
        ? `<p class="text-sm text-gray-400">${escapeHtml(item.variantName)}</p>`
        : '';
      const img = item.image
        ? `<img src="${escapeHtml(item.image)}" alt="${escapeHtml(item.name)}" width="96" height="96" loading="lazy" decoding="async" class="w-20 h-20 sm:w-24 sm:h-24 object-cover rounded-xl border border-gray-100 bg-gray-50 shrink-0" />`
        : `<div class="w-20 h-20 sm:w-24 sm:h-24 rounded-xl bg-gray-100 shrink-0" aria-hidden="true"></div>`;
      return `
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 sm:p-5 flex gap-4" data-cart-row="${item.id}">
          ${img}
          <div class="flex-1 min-w-0 flex flex-col">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <h3 class="font-semibold text-gray-900 leading-tight">${escapeHtml(item.name)}</h3>
                ${variant}
                <p class="text-sm text-gray-500 mt-1">${i18n.unitPrice || ''}: <span class="font-medium text-gray-700">${unit}</span></p>
              </div>
              <button type="button" class="p-1.5 -mt-1 -mr-1 text-gray-300 hover:text-red-500 transition-colors shrink-0" data-row-remove="${item.id}" aria-label="${escapeHtml(i18n.remove || '')}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>
            <div class="flex items-end justify-between mt-auto pt-3">
              <div class="inline-flex items-center border-2 border-gray-200 rounded-xl overflow-hidden">
                <button type="button" class="w-9 h-9 flex items-center justify-center text-gray-500 hover:text-[#ce2252] hover:bg-gray-50 text-lg font-bold" data-row-minus="${item.id}" aria-label="−">−</button>
                <span class="w-10 text-center text-sm font-bold text-gray-900" data-row-qty="${item.id}">${item.qty}</span>
                <button type="button" class="w-9 h-9 flex items-center justify-center text-gray-500 hover:text-[#ce2252] hover:bg-gray-50 text-lg font-bold" data-row-plus="${item.id}" aria-label="+">+</button>
              </div>
              <span class="text-lg font-bold text-gray-900 whitespace-nowrap">${line}</span>
            </div>
          </div>
        </div>`;
    }

    function render() {
      const summary = getCartSummary();
      if (summary.items.length === 0) {
        emptyEl!.style.display = '';
        contentEl!.style.display = 'none';
        return;
      }
      emptyEl!.style.display = 'none';
      contentEl!.style.display = 'grid';

      itemsEl!.innerHTML = summary.items.map(itemCard).join('');

      const totalText =
        summary.subtotal > 0
          ? formatPrice(summary.subtotal, locale) + (summary.hasPriceOnRequest ? ' +' : '')
          : (i18n.priceOnRequest || '');
      if (subtotalEl) subtotalEl.textContent = totalText;
      if (totalEl) totalEl.textContent = totalText;
    }

    itemsEl.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const minus = target.closest<HTMLElement>('[data-row-minus]');
      const plus = target.closest<HTMLElement>('[data-row-plus]');
      const remove = target.closest<HTMLElement>('[data-row-remove]');
      if (minus) {
        const id = minus.dataset.rowMinus!;
        const item = getCartSummary().items.find((i) => i.id === id);
        if (item && item.qty > 1) updateQty(id, item.qty - 1);
      } else if (plus) {
        const id = plus.dataset.rowPlus!;
        const item = getCartSummary().items.find((i) => i.id === id);
        if (item) updateQty(id, item.qty + 1);
      } else if (remove) {
        removeFromCart(remove.dataset.rowRemove!);
      }
    });

    window.addEventListener(CART_EVENTS.updated, render);
    render();
  }

  initCartPage();
  document.addEventListener('astro:page-load', initCartPage);
</script>
