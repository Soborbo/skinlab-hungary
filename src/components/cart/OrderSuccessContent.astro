---
/**
 * OrderSuccessContent — a /rendeles-koszonjuk oldal tartalma.
 *
 * A sikeres megrendelés után jelenik meg. A rendelésszámot az `?id=`
 * URL paraméterből olvassa ki a kliens script. Nincs kártyás fizetés:
 * a vásárlót visszahívjuk, majd e-mailben küldjük a fizetési linket.
 */
import { t, getLocalizedUrl, type Locale } from '@/i18n/ui';
import { CONTACT } from '@/lib/constants';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const homeUrl = getLocalizedUrl(locale, '/');
const productsUrl = getLocalizedUrl(locale, '/termekek');
---

<section class="bg-gray-50 min-h-[60vh] py-12 lg:py-20">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-7 sm:p-10 text-center">

      <!-- Pipa ikon -->
      <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-success-50 flex items-center justify-center">
        <svg class="w-9 h-9 text-success-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-3">{t(locale, 'checkout.success.heading')}</h1>
      <p class="text-gray-600 leading-relaxed mb-6">{t(locale, 'checkout.success.message')}</p>

      <!-- Rendelésszám -->
      <div class="bg-gray-50 border border-gray-200 rounded-xl px-5 py-3 mb-8 inline-flex items-center gap-3" style="display:none" data-order-id-box>
        <span class="text-sm text-gray-500">{t(locale, 'checkout.success.orderNumber')}:</span>
        <span class="font-mono font-bold text-[#9b6b6b]" data-order-id></span>
      </div>

      <!-- Mi történik most -->
      <div class="text-left bg-gray-50 rounded-xl p-5 sm:p-6 mb-8">
        <h2 class="text-base font-bold text-gray-900 mb-4">{t(locale, 'checkout.success.whatNext')}</h2>
        <ol class="space-y-4">
          {[1, 2, 3].map((n) => (
            <li class="flex gap-3">
              <span class="w-7 h-7 rounded-full bg-[#9b6b6b] text-white text-sm font-bold flex items-center justify-center shrink-0">{n}</span>
              <div>
                <p class="text-sm font-semibold text-gray-900">{t(locale, `checkout.success.step${n}Title`)}</p>
                <p class="text-sm text-gray-600 mt-0.5">{t(locale, `checkout.success.step${n}Desc`)}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>

      <p class="text-sm text-gray-500 mb-1">{t(locale, 'checkout.success.emailNote')}</p>
      <p class="text-sm text-gray-500 mb-8">
        {t(locale, 'checkout.email.questions')}{' '}
        <a href={CONTACT.phoneTel} class="text-[#9b6b6b] font-semibold hover:underline whitespace-nowrap">{CONTACT.phoneDisplay}</a>
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href={productsUrl}
          class="inline-flex items-center justify-center px-6 py-3 bg-[#9b6b6b] text-white font-semibold rounded-xl hover:bg-[#8a5c5c] transition-colors shadow-md"
        >
          {t(locale, 'checkout.success.browseProducts')}
        </a>
        <a
          href={homeUrl}
          class="inline-flex items-center justify-center px-6 py-3 border border-gray-300 text-gray-700 font-semibold rounded-xl hover:bg-gray-50 transition-colors"
        >
          {t(locale, 'checkout.success.backToHome')}
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  function initOrderSuccess() {
    const box = document.querySelector<HTMLElement>('[data-order-id-box]');
    const idEl = document.querySelector<HTMLElement>('[data-order-id]');
    if (!box || !idEl) return;

    const params = new URLSearchParams(window.location.search);
    const id = params.get('id');
    if (id) {
      // Csak biztonságos karakterek
      idEl.textContent = id.replace(/[^A-Za-z0-9-]/g, '').slice(0, 40);
      box.style.display = 'inline-flex';
    }

    // Friss kosár-állapot a fejléc badge-hez (a checkout már kiürítette)
    window.dispatchEvent(new CustomEvent('cart:updated'));
  }

  initOrderSuccess();
  document.addEventListener('astro:page-load', initOrderSuccess);
</script>
