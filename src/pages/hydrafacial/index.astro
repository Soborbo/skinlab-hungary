---
import CategoryLayout from '../../layouts/CategoryLayout.astro';
import { getCollection } from 'astro:content';

const category = {
  name: 'Hidrodermabrázió és multifunkcionális gépek',
  nameShort: 'Hydrafacial gépek',
  slug: 'hydrafacial',
  description: 'Hidrodermabráziós és kombinált kozmetikai kezelőgépek.',
  heroDescription: 'Bőrmegújítás, mélytisztítás, anti-aging kezelések egy készülékben. AI bőrdiagnosztikával, azonnali látványos eredmény.',
  badge: 'AI diagnosztika',
  color: 'hydrafacial',
};

const products = await getCollection('products', ({ data }) => {
  return data.categorySlug === 'hydrafacial' && !data.draft;
});

const benefits = [
  {
    icon: 'sparkles',
    title: 'Azonnali eredmény',
    description: 'Már az első kezelés után látványosan szebb, ragyogóbb bőr. Vendégeid azonnal érzik a különbséget.',
  },
  {
    icon: 'microscope',
    title: 'AI bőrdiagnosztika',
    description: 'Személyre szabott kezelési tervek. Lenyűgöző high-tech élmény a vendégeknek.',
  },
  {
    icon: 'target',
    title: 'Sokoldalú kezelések',
    description: 'Tisztítás, hidratálás, anti-aging, pigmentfolt kezelés – egy géppel mindent megoldhatsz.',
  },
  {
    icon: 'coins',
    title: 'Magas kezelési árak',
    description: 'Hydrafacial kezelésekért 15-30.000 Ft-ot is elkérhetnek a szalonok. Gyors megtérülés.',
  },
];

const faq = [
  {
    question: 'Mi a különbség a hagyományos arctisztítás és a hydrafacial között?',
    answer: 'A hydrafacial vákuumos technológiával dolgozik, ami a mélytisztítás mellett szérum-infúziót is biztosít. Fájdalommentes, nincs kipirulás, a vendég azonnal mehet tovább. A hagyományos tisztítás után sokszor napokig piros az arc.',
  },
  {
    question: 'Milyen gyakran lehet hydrafacial kezelést végezni?',
    answer: 'Általában 4-6 hetente ajánlott a fenntartó kezelés. Kúraszerűen hetente is végezhető a bőrállapot javítására. Nagyon kíméletes eljárás.',
  },
  {
    question: 'Minden bőrtípusra alkalmas?',
    answer: 'Igen! A hydrafacial az egyik legkíméletesebb arckezelés, érzékeny bőrre, rozáceára is alkalmazható. Egyedül aktív gyulladásos aknénál nem javasolt.',
  },
];

const comparison = {
  features: ['Ár', 'Funkciók száma', 'AI bőranalízis', 'Kijelző', 'Ajánlott'],
  products: [
    {
      name: 'HydraMax',
      tag: 'Belépő szint',
      tagColor: 'purple',
      link: '/hydrafacial/hydramax-professzionalis-hydrofacial-keszulek-833',
      specs: {
        'Ár': '399 990 Ft',
        'Funkciók száma': '8',
        'AI bőranalízis': '✗',
        'Kijelző': 'Érintőképernyő',
        'Ajánlott': 'Kezdő hidrofaciális kabin',
      },
    },
    {
      name: 'HydraScan PRO',
      tag: 'AI bőranalízis',
      tagColor: 'blue',
      link: '/hydrafacial/hydrascan-pro',
      specs: {
        'Ár': '599 990 Ft',
        'Funkciók száma': '8+1',
        'AI bőranalízis': '✓',
        'Kijelző': '10,1" érintő',
        'Ajánlott': 'Közepes szalonok',
      },
    },
    {
      name: 'HydraScan PRO+ 2026',
      tag: 'Új generáció',
      tagColor: 'orange',
      highlighted: true,
      link: '/hydrafacial/hydrascan-pro-plus',
      specs: {
        'Ár': '850 887 Ft',
        'Funkciók száma': '8+1',
        'AI bőranalízis': '✓ 4K három-spektrumú',
        'Kijelző': '10,1" érintő',
        'Ajánlott': 'Profi szalon, klinika',
      },
    },
    {
      name: 'HydraCrown Expert',
      tag: 'Prémium 10in1',
      tagColor: 'red',
      link: '/hydrafacial/hydracrownexpert',
      specs: {
        'Ár': '1 299 990 Ft',
        'Funkciók száma': '10',
        'AI bőranalízis': '✓',
        'Kijelző': 'Android nagy érintő',
        'Ajánlott': 'Klinikák, prémium szalonok',
      },
    },
  ],
};
---

<CategoryLayout category={category} products={products} benefits={benefits} faq={faq} comparison={comparison} />
