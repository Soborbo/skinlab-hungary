---
/**
 * Dedikált HydraSCAN Pro termékoldal
 *
 * Statikus route — felülírja a [slug].astro dinamikus route-ot.
 * Új szekció-sorrend a referencia template alapján:
 * Hero → Stats → ROI → Video → FeatureRows → Training → Testimonials →
 * Expert → TechSpecs + FunctionCards → WhatsIncluded → FAQ → Warranty → CTA → Related
 *
 * Nem használ: ComparisonTable, ProblemSolution, Description szekció
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductGallery from '../../components/product/ProductGallery.astro';
import StatsBar from '../../components/product/StatsBar.astro';
import ROICalculator from '../../components/product/ROICalculator.astro';
import FeatureRows from '../../components/product/FeatureRows.astro';
import TrainingCard from '../../components/product/TrainingCard.astro';
import Testimonials from '../../components/product/Testimonials.astro';
import ExpertQuote from '../../components/product/ExpertQuote.astro';
import FunctionCards from '../../components/product/FunctionCards.astro';
import WhatsIncluded from '../../components/product/WhatsIncluded.astro';
import ProductFAQ from '../../components/product/ProductFAQ.astro';
import WarrantyService from '../../components/product/WarrantyService.astro';
import RelatedProducts from '../../components/product/RelatedProducts.astro';
import InstallmentBadge from '../../components/ui/InstallmentBadge.astro';
import BreadcrumbSchema from '../../components/schema/BreadcrumbSchema.astro';
import FAQSchema from '../../components/schema/FAQSchema.astro';
import { getCollection } from 'astro:content';
import { SITE, CONTACT, TRUST_BADGES, CATEGORIES } from '../../lib/constants';

// Fetch product data
const products = await getCollection('products', ({ data }) => {
  return data.slug === 'hydrascan-pro';
});

if (!products.length) {
  return Astro.redirect('/hydrafacial');
}

const productEntry = products[0];
const product = {
  name: productEntry.data.name,
  sku: productEntry.data.sku,
  slug: productEntry.data.slug,
  categorySlug: productEntry.data.categorySlug,
  description: productEntry.data.description,
  shortDescription: productEntry.data.shortDescription,
  price: productEntry.data.price,
  image: productEntry.data.image,
  gallery: productEntry.data.images || productEntry.data.gallery || [],
  youtubeVideos: productEntry.data.youtubeVideos,
  availability: productEntry.data.availability,
  hasVariants: productEntry.data.hasVariants,
  variants: productEntry.data.variants,
  featured: productEntry.data.featured,
  metaTitle: productEntry.data.metaTitle,
  metaDescription: productEntry.data.metaDescription,
  stats: productEntry.data.stats,
  faq: productEntry.data.faq,
  whatsIncluded: productEntry.data.whatsIncluded,
  specs: productEntry.data.specs,
};

// Category info
const category = CATEGORIES.find(c => c.slug === product.categorySlug);
const categoryName = category?.nameShort || product.categorySlug;

// Format price
const formatPrice = (price: number | null) => {
  if (!price) return null;
  return new Intl.NumberFormat('hu-HU').format(price) + ' Ft';
};

// Availability
const availabilityInfo = {
  in_stock: { label: 'Raktáron', color: 'success', icon: 'check' },
  preorder: { label: 'Előrendelhető', color: 'amber', icon: 'clock' },
  out_of_stock: { label: 'Nem elérhető', color: 'gray', icon: 'x' },
};
const availability = availabilityInfo[product.availability];

// URLs
const pageUrl = `${SITE.url}/${product.categorySlug}/${product.slug}`;

// Breadcrumb
const breadcrumbItems = [
  { name: 'Főoldal', url: SITE.url },
  { name: categoryName, url: `${SITE.url}/${product.categorySlug}` },
  { name: product.name }
];

// Extract first YouTube video ID for the description section
const firstVideoUrl = product.youtubeVideos?.[0] || '';
const videoIdMatch = firstVideoUrl.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]{11})/);
const firstVideoId = videoIdMatch?.[1] || (firstVideoUrl.length === 11 ? firstVideoUrl : null);

// FAQ schema
const faqQuestions = product.faq?.map(item => ({
  question: item.question,
  answer: item.answer
})) || [];

// Product schema
const productSchema = product.price ? {
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": `${pageUrl}#product`,
  "name": product.name,
  "description": product.shortDescription || product.description?.slice(0, 200),
  "sku": product.sku,
  "brand": { "@type": "Brand", "name": "SkinLab" },
  "image": product.image ? [`${SITE.url}/${product.image.replace('@assets/', 'assets/')}`] : [],
  "offers": {
    "@type": "Offer",
    "url": pageUrl,
    "priceCurrency": "HUF",
    "price": String(product.price),
    "availability": product.availability === 'in_stock'
      ? "https://schema.org/InStock"
      : product.availability === 'preorder'
        ? "https://schema.org/PreOrder"
        : "https://schema.org/OutOfStock",
    "seller": { "@type": "Organization", "@id": `${SITE.url}#organization`, "name": "SkinLab Hungary" },
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 14,
      "returnMethod": "https://schema.org/ReturnByMail"
    },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingRate": { "@type": "MonetaryAmount", "value": "0", "currency": "HUF" },
      "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "HU" },
      "deliveryTime": {
        "@type": "ShippingDeliveryTime",
        "handlingTime": { "@type": "QuantitativeValue", "minValue": 1, "maxValue": 3, "unitCode": "DAY" },
        "transitTime": { "@type": "QuantitativeValue", "minValue": 10, "maxValue": 20, "unitCode": "DAY" }
      }
    }
  }
} : null;

// Trust badge icons
const icons: Record<string, string> = {
  'shield-check': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,
  'truck': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" />`,
  'graduation-cap': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />`,
  'wrench': `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`,
};

// All images for gallery
const allImages = [product.image, ...product.gallery].filter(Boolean);
---

<BaseLayout
  title={product.metaTitle || product.name}
  description={product.metaDescription || product.shortDescription || product.description?.slice(0, 160)}
  schema={productSchema}
>
  <!-- Schema.org -->
  <BreadcrumbSchema items={breadcrumbItems} currentUrl={pageUrl} />
  {faqQuestions.length > 0 && <FAQSchema url={pageUrl} questions={faqQuestions} />}

  <div id="main-content">

    <!-- BREADCRUMB -->
    <nav class="bg-gray-100 border-b" aria-label="Breadcrumb">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
        <ol class="flex items-center gap-2 text-sm">
          <li><a href="/" class="text-gray-500 hover:text-primary-600">Főoldal</a></li>
          <li class="text-gray-400">›</li>
          <li><a href={`/${product.categorySlug}`} class="text-gray-500 hover:text-primary-600">{categoryName}</a></li>
          <li class="text-gray-400">›</li>
          <li class="text-gray-900 font-medium truncate max-w-[200px]">{product.name}</li>
        </ol>
      </div>
    </nav>

    <!-- 1. HERO -->
    <section class="bg-white py-8 lg:py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-10 lg:gap-16">

          <ProductGallery
            images={allImages}
            productName={product.name}
            badges={{ featured: product.featured, variantCount: product.hasVariants ? product.variants.length : undefined }}
          />

          <div>
            <!-- Availability -->
            <div class={`inline-flex items-center gap-2 px-3 py-1 rounded-full text-sm font-medium mb-4 ${
              availability.color === 'success' ? 'bg-success-50 text-success-600' :
              availability.color === 'amber' ? 'bg-amber-50 text-amber-600' :
              'bg-gray-100 text-gray-600'
            }`}>
              {availability.icon === 'check' && (
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
              )}
              {availability.icon === 'clock' && (
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              )}
              {availability.label}
            </div>

            <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">
              {product.name}
            </h1>

            <p class="text-lg text-gray-600 mb-6">
              {product.shortDescription}
            </p>

            <!-- Price -->
            <div class="mb-6">
              {product.price ? (
                <>
                  <div class="text-3xl font-bold text-gray-900">{formatPrice(product.price)}</div>
                  <div class="text-sm text-gray-500 mt-1">Bruttó ár (ÁFA-val)</div>
                </>
              ) : (
                <div class="text-2xl font-bold text-primary-600">Kérjen egyedi ajánlatot!</div>
              )}
            </div>

            <InstallmentBadge price={product.price || 0} class="mb-6" />

            <!-- Trust badges mini -->
            <div class="grid grid-cols-2 gap-3 mb-8">
              {TRUST_BADGES.map((badge) => (
                <div class="flex items-center gap-2 text-sm">
                  <svg class="w-5 h-5 text-primary-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={icons[badge.icon]} />
                  <span class="text-gray-700">{badge.title}</span>
                </div>
              ))}
            </div>

            <!-- CTAs -->
            <div class="flex flex-col sm:flex-row gap-3">
              <a href="/kapcsolat" class="flex-1 inline-flex items-center justify-center px-6 py-4 bg-primary-600 text-white font-semibold rounded-xl hover:bg-primary-700 transition-colors shadow-lg">
                Ingyenes konzultáció
              </a>
              <a href={CONTACT.phoneTel} class="flex-1 inline-flex items-center justify-center gap-2 px-6 py-4 bg-success-50 text-success-700 font-semibold rounded-xl hover:bg-success-100 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                Hívás most
              </a>
            </div>

            <div class="mt-6 text-xs text-gray-400">Cikkszám: {product.sku}</div>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. STATS BAR -->
    <StatsBar stats={product.stats} category={product.categorySlug} />

    <!-- 3. ROI CALCULATOR -->
    <ROICalculator productPrice={product.price} productName={product.name} category={product.categorySlug} />

    <!-- 4. VIDEO + DESCRIPTION -->
    <section class="py-12 lg:py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
          <!-- Left: Video -->
          <div class="relative rounded-2xl overflow-hidden shadow-lg bg-gray-900 aspect-video">
            {firstVideoId ? (
              <div
                class="video-facade relative w-full h-full cursor-pointer group"
                data-video-id={firstVideoId}
                data-video-title={`${product.name} bemutató`}
                role="button"
                tabindex="0"
                aria-label={`Videó lejátszása: ${product.name} bemutató`}
              >
                <img
                  src={`https://i.ytimg.com/vi/${firstVideoId}/maxresdefault.jpg`}
                  alt={`${product.name} bemutató videó`}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-black/30 group-hover:bg-black/40 transition-colors" />
                <div class="absolute inset-0 flex items-center justify-center">
                  <div class="w-16 h-16 lg:w-20 lg:h-20 rounded-full bg-red-600 flex items-center justify-center shadow-xl transform transition-all duration-300 group-hover:scale-110 group-hover:bg-red-700">
                    <svg class="w-8 h-8 lg:w-10 lg:h-10 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </div>
                </div>
              </div>
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-primary-100 to-primary-200 flex items-center justify-center">
                <div class="text-center p-8">
                  <svg class="w-16 h-16 text-primary-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                  <p class="text-sm text-primary-400">Bemutató videó hamarosan</p>
                </div>
              </div>
            )}
          </div>

          <!-- Right: Description -->
          <div>
            <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-6">
              A HYDRASCAN PRO nem csupán egy gép – hanem egy intelligens bőrdiagnosztikai rendszer
            </h2>
            <div class="space-y-4 text-gray-600 leading-relaxed">
              <p>
                A készülék különlegessége, hogy a hagyományos arckezelési technológiákat mesterséges intelligenciával kombinálja, ezáltal a kezelések nemcsak hatékonyabbak, hanem személyre szabottabbak is.
              </p>
              <p>
                A beépített AI-alapú bőranalízis rendszer valós idejű diagnózist biztosít: pórusméret, ráncok mélysége, pigmentáció, hidratáltság, faggyútermelés, rugalmasság, gyulladt területek és UV-sérülések – mindezt automatikusan elemzi és kezelési javaslatot ad.
              </p>
              <p>
                A vendég állapotáról előtte-utána képek és grafikonok készíthetők, a rendszer kezelési naplót vezet, így minden változás dokumentálható.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA: after video -->
    <div class="py-8 bg-gray-50 border-y border-gray-200">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-gray-700 font-medium text-center sm:text-left">Kérdésed van a géppel kapcsolatban? Szívesen segítünk!</p>
        <div class="flex gap-3 shrink-0">
          <a href="/kapcsolat" class="inline-flex items-center px-5 py-2.5 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition-colors text-sm">
            Konzultáció kérése
          </a>
          <a href={CONTACT.phoneTel} class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-gray-700 font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Hívj minket
          </a>
        </div>
      </div>
    </div>

    <!-- 5. FEATURE ROWS (replaces ProblemSolution) -->
    <FeatureRows
      productName={product.name}
      productSlug={product.slug}
      category={product.categorySlug}
    />

    <!-- CTA: after features -->
    <div class="py-10 bg-primary-50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-lg font-semibold text-gray-900 mb-2">Szeretnéd élőben látni a {product.name}-t?</p>
        <p class="text-gray-600 mb-6">Gyere el showroom-unkna Érdre, és próbáld ki személyesen!</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/kapcsolat" class="inline-flex items-center justify-center px-6 py-3 bg-primary-600 text-white font-semibold rounded-xl hover:bg-primary-700 transition-colors">
            Időpont foglalás
          </a>
          <a href={CONTACT.phoneTel} class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white text-gray-700 font-semibold rounded-xl border border-gray-300 hover:bg-gray-50 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {CONTACT.phoneDisplay}
          </a>
        </div>
      </div>
    </div>

    <!-- 6. TRAINING SECTION -->
    <TrainingCard
      productName={product.name}
      productSlug={product.slug}
      category={product.categorySlug}
    />

    <!-- 7. TESTIMONIALS -->
    <Testimonials productName={product.name} productSlug={product.slug} category={product.categorySlug} />

    <!-- 8. EXPERT QUOTE -->
    <ExpertQuote productName={product.name} category={product.categorySlug} />

    <!-- 9. TECH SPECS + FUNCTION CARDS -->
    <section class="py-12 lg:py-16 bg-gray-50 border-t border-b border-gray-200">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Specs Header -->
        <div class="text-center mb-10">
          <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-3">
            Műszaki adatok
          </h2>
          <p class="text-gray-600">
            A {product.name} részletes műszaki adatai
          </p>
        </div>

        <!-- Specs Table (inline, same as TechSpecs component) -->
        {product.specs && Object.keys(product.specs).length > 0 && (
          <div class="bg-white rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
            <dl class="divide-y divide-gray-200">
              {Object.entries(product.specs).map(([key, value], index) => (
                <div class:list={[
                  "flex flex-col sm:flex-row sm:items-center px-6 py-4",
                  index % 2 === 0 ? "bg-white" : "bg-gray-50"
                ]}>
                  <dt class="text-sm font-semibold text-gray-900 sm:w-1/3 mb-1 sm:mb-0">{key}</dt>
                  <dd class="text-sm text-gray-600 sm:w-2/3">{value}</dd>
                </div>
              ))}
            </dl>
          </div>
        )}

        <!-- Download CTA -->
        <div class="mt-8 text-center">
          <a href="/kapcsolat" class="inline-flex items-center gap-2 px-6 py-3 bg-primary-600 text-white font-semibold rounded-xl hover:bg-primary-700 transition-colors shadow-sm">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            A gyári adatlap letöltése
          </a>
        </div>

        <!-- Function Cards -->
        <FunctionCards
          productName={product.name}
          productSlug={product.slug}
          category={product.categorySlug}
        />
      </div>
    </section>

    <!-- 10. FAQ (white bg) -->
    <ProductFAQ faq={product.faq} productName={product.name} category={product.categorySlug} />

    <!-- 11. WHATS INCLUDED (gray bg) -->
    <WhatsIncluded items={product.whatsIncluded} productName={product.name} category={product.categorySlug} />

    <!-- 12. WARRANTY (gray→white gradient, flows from WhatsIncluded) -->
    <WarrantyService productName={product.name} />

    <!-- 13. CTA SECTION -->
    <section class="py-16 bg-primary-600">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl lg:text-3xl font-bold text-white mb-4">
          Érdekel a {product.name}?
        </h2>
