---
/**
 * Consultation thank-you page
 * /konzultacio-koszonjuk?lead=SLO-XXXXX
 *
 * Single-screen split layout: founder photo on the left, personal thank-you
 * + next-steps + urgent phone on the right. The conversion is fired at
 * form-submit time via the tracking-kit (`lead_submit` dataLayer event +
 * /api/track beacon) — see src/lib/tracking.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CONTACT, FOUNDERS } from '@/lib/constants';

const leadId = Astro.url.searchParams.get('lead') || '';
const laszlo = FOUNDERS.find((f) => f.name === 'Horváth László')!;
---

<BaseLayout
  title="Köszönjük érdeklődését"
  description="Megkaptuk konzultáció kérését, hamarosan személyesen felvesszük Önnel a kapcsolatot."
  noIndex={true}
  hideDesktopWidget={true}
>
  <section class="min-h-screen flex items-center bg-gradient-to-br from-primary-50/60 via-white to-primary-50/30 px-4 py-6 md:py-8">
    <div class="max-w-3xl w-full mx-auto">
      <!-- Header centered -->
      <div class="text-center mb-8">
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-bold text-gray-900 mb-3 leading-tight">
          Köszönjük, megkaptuk érdeklődését!
        </h1>
        <p class="text-base md:text-lg text-gray-600">
          Hamarosan személyesen veszem fel Önnel a kapcsolatot.
        </p>
      </div>

      <!-- Content (text-first, image last) -->
      <div class="flex flex-col gap-8">
        <!-- Text content -->
        <div>
          <!-- Next steps -->
          <div class="mb-5">
            <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wide mb-3">Mi történik most?</h2>
            <ol class="space-y-2.5">
              <li class="flex gap-3">
                <span class="flex-shrink-0 w-7 h-7 rounded-full bg-primary-100 text-primary-700 font-semibold text-sm flex items-center justify-center">1</span>
                <span class="text-gray-700 pt-0.5 text-sm md:text-base">Átnézzük az igényeit.</span>
              </li>
              <li class="flex gap-3">
                <span class="flex-shrink-0 w-7 h-7 rounded-full bg-primary-100 text-primary-700 font-semibold text-sm flex items-center justify-center">2</span>
                <span class="text-gray-700 pt-0.5 text-sm md:text-base">Egy munkanapon belül felhívjuk.</span>
              </li>
              <li class="flex gap-3">
                <span class="flex-shrink-0 w-7 h-7 rounded-full bg-primary-100 text-primary-700 font-semibold text-sm flex items-center justify-center">3</span>
                <span class="text-gray-700 pt-0.5 text-sm md:text-base">Az igényei alapján részletes, személyre szabott árajánlatot küldünk.</span>
              </li>
            </ol>
          </div>

          <!-- Urgent phone CTA -->
          <div class="bg-white border border-primary-100 rounded-2xl px-4 py-3 shadow-sm">
            <p class="text-xs text-gray-600 mb-1">Sürgős esetben hívjon bennünket nyitvatartási időben az alábbi telefonszámon:</p>
            <a
              href={`tel:${CONTACT.phone}`}
              class="inline-flex items-center gap-2 text-lg md:text-xl font-bold text-primary-700 hover:text-primary-800 transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {CONTACT.phoneDisplay}
            </a>
            <p class="text-xs text-gray-500 mt-1.5">Nyitvatartás: Hétfő–Péntek 9:00–17:00</p>
          </div>

          <!-- Lead reference (footer-style, low priority) -->
          {leadId && (
            <p class="mt-4 text-xs text-gray-400 text-center">
              Azonosító: <span class="font-mono">{leadId}</span>
            </p>
          )}
        </div>

        <!-- Founder photo (small, centered, below content) -->
        <div class="flex justify-center">
          <div class="relative w-40 md:w-48">
            <picture>
              <source srcset={`${laszlo.image}.avif`} type="image/avif" />
              <source srcset={`${laszlo.image}.webp`} type="image/webp" />
              <img
                src={`${laszlo.image}.jpg`}
                alt={laszlo.name}
                width="192"
                height="192"
                class="w-full aspect-square object-cover rounded-2xl shadow-lg"
                loading="lazy"
              />
            </picture>
            <div class="mt-2 text-center">
              <p class="text-sm font-semibold text-gray-900">{laszlo.name}</p>
              <p class="text-xs text-gray-500">Skinlab Hungary alapító</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
