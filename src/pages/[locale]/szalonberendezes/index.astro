---
/**
 * A "szalonberendezes" már nem önálló kategória — átirányítás a
 * termékek oldalra (a magyar /szalonberendezes ugyanígy redirectel).
 */
import { locales, defaultLocale, getLocalizedUrl, type Locale } from '../../../i18n/ui';

export function getStaticPaths() {
  return locales
    .filter((l) => l !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params as { locale: Locale };
return Astro.redirect(getLocalizedUrl(locale, '/termekek'), 301);
---
