---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ThankYouContent from '../../components/pages/ThankYouContent.astro';
import { locales, defaultLocale, getLocaleFromUrl, type Locale } from '../../i18n/ui';
import { t } from '../../i18n/ui';

export function getStaticPaths() {
  return locales
    .filter((l) => l !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const locale = getLocaleFromUrl(Astro.url) as Locale;
const leadId = Astro.url.searchParams.get('lead') || '';
---

<BaseLayout
  title={t(locale, 'thankYou.title')}
  description={t(locale, 'thankYou.metaDescription')}
  noIndex={true}
>
  <ThankYouContent locale={locale} leadId={leadId} />
</BaseLayout>
