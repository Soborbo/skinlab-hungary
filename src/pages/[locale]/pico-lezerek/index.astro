---
import CategoryLayout from '../../../layouts/CategoryLayout.astro';
import { getCollection } from 'astro:content';
import { locales, defaultLocale } from '../../../i18n/ui';
import { getCategoryTranslation } from '../../../data/category-translations';

export function getStaticPaths() {
  return locales
    .filter((l) => l !== defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
const category = getCategoryTranslation(locale!, 'pico-lezerek');

const products = await getCollection('products', ({ data }) => {
  return data.categorySlug === 'pico-lezerek' && !data.draft;
});
---

<CategoryLayout category={category} products={products} />
