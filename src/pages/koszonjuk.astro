---
/**
 * Contact form thank-you page (Hungarian)
 * /koszonjuk?lead=SL-XXXXX
 *
 * Reached after a successful /api/contact submission. The conversion is fired
 * at form-submit time via the tracking-kit (`lead_submit` / `contact_submit`
 * dataLayer events + /api/track beacon) - see src/lib/tracking.
 *
 * Layout: founder photos (László + Szimonetta) → personal thank-you → opening
 * hours → urgent phone CTA. Single-screen friendly.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CONTACT, FOUNDERS } from '@/lib/constants';

const leadId = Astro.url.searchParams.get('lead') || '';
const laszlo = FOUNDERS.find((f) => f.name === 'Horváth László')!;
const simonetta = FOUNDERS.find((f) => f.name === 'Gaszler Szimonetta')!;
---

<BaseLayout
  title="Köszönjük a megkeresésed"
  description="Köszönjük, hogy felvetted velünk a kapcsolatot. Nyitvatartási időben a lehető leggyorsabban válaszolunk."
  noIndex={true}
  hideDesktopWidget={true}
>
  <section class="min-h-screen flex items-center justify-center bg-gradient-to-b from-primary-50/40 to-white px-4 py-10">
    <div class="max-w-2xl w-full">
      <!-- Founder duo photos -->
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="text-center">
          <div class="relative inline-block">
            <picture>
              <source srcset={`${laszlo.image}.avif`} type="image/avif" />
              <source srcset={`${laszlo.image}.webp`} type="image/webp" />
              <img
                src={`${laszlo.image}.jpg`}
                alt={laszlo.name}
                width="112"
                height="112"
                class="w-24 h-24 sm:w-28 sm:h-28 rounded-full object-cover border-4 border-primary-100 shadow-lg"
                loading="eager"
              />
            </picture>
          </div>
          <p class="mt-2 text-xs font-medium text-gray-700">{laszlo.name}</p>
        </div>
        <div class="text-center">
          <div class="relative inline-block">
            <picture>
              <source srcset={`${simonetta.image}.avif`} type="image/avif" />
              <source srcset={`${simonetta.image}.webp`} type="image/webp" />
              <img
                src={`${simonetta.image}.jpg`}
                alt={simonetta.name}
                width="112"
                height="112"
                class="w-24 h-24 sm:w-28 sm:h-28 rounded-full object-cover border-4 border-primary-100 shadow-lg"
                loading="eager"
              />
            </picture>
            <div class="absolute -bottom-1 -right-1 w-9 h-9 rounded-full bg-green-500 border-2 border-white flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
          </div>
          <p class="mt-2 text-xs font-medium text-gray-700">{simonetta.name}</p>
        </div>
      </div>

      <!-- Heading -->
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 text-center mb-3">
        Köszönjük, megkaptuk az üzenetét!
      </h1>

      <p class="text-base md:text-lg text-gray-600 text-center mb-6">
        Nyitvatartási időben a lehető leggyorsabban válaszolunk.
      </p>

      <!-- Lead reference -->
      {leadId && (
        <div class="text-center mb-6">
          <span class="inline-flex items-center gap-2 bg-white border border-gray-200 rounded-full px-4 py-1.5 text-xs">
            <span class="text-gray-500">Azonosító:</span>
            <span class="font-mono font-semibold text-gray-700">{leadId}</span>
          </span>
        </div>
      )}

      <!-- Opening hours + urgent phone -->
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="bg-white rounded-2xl border border-gray-200 p-5 shadow-sm">
          <div class="flex items-center gap-2 text-primary-700 mb-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h2 class="font-semibold text-sm uppercase tracking-wide">Nyitvatartás</h2>
          </div>
          <p class="text-sm text-gray-700 font-medium">Hétfő – Péntek: 10:00 – 18:00</p>
          <p class="text-sm text-gray-700">Szombat: 10:00 – 14:00</p>
          <p class="text-xs text-gray-500 mt-2">A showroom látogatása előzetes egyeztetést igényel.</p>
        </div>

        <div class="bg-primary-600 text-white rounded-2xl p-5 shadow-md">
          <p class="text-xs uppercase tracking-wide opacity-80 mb-2">Sürgős kérdésed van?</p>
          <a
            href={`tel:${CONTACT.phone}`}
            class="flex items-center gap-2 text-xl md:text-2xl font-bold hover:opacity-90 transition-opacity"
          >
            <svg class="w-6 h-6 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {CONTACT.phoneDisplay}
          </a>
          <p class="text-xs opacity-80 mt-2">Hívj minket bizalommal nyitvatartási időben.</p>
        </div>
      </div>

      <!-- Back to home -->
      <div class="text-center mt-6">
        <a
          href="/"
          class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-primary-600 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Vissza a főoldalra
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
