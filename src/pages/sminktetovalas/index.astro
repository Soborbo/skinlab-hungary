---
import CategoryLayout from '../../layouts/CategoryLayout.astro';
import { getCollection } from 'astro:content';

const category = {
  name: 'MAST sminktetováló eszközök',
  nameShort: 'Sminktetováló gépek',
  slug: 'sminktetovalas',
  description: 'Vezetékes és vezeték nélküli sminktetováló gépek és tartozékok.',
  heroDescription: 'Professzionális PMU gépek szemöldök, ajak és szemhéj tetováláshoz. Precíz vonalvezetés, csendes motor, ergonomikus kialakítás.',
  badge: 'PMU szakértő választása',
  color: 'sminktetovalas',
};

const products = await getCollection('products', ({ data }) => {
  return data.categorySlug === 'sminktetovalas' && !data.draft;
});

const benefits = [
  {
    icon: 'pencil',
    title: 'Precíz vonalvezetés',
    description: 'Japán motor technológia, minimális vibráció. Tökéletes microblading, powder brows és ajak pigmentálás.',
  },
  {
    icon: 'battery',
    title: 'Vezeték nélküli szabadság',
    description: 'Akkumulátoros modellek akár 8 óra üzemidővel. Nincs zavaró kábel, teljes mozgásszabadság.',
  },
  {
    icon: 'mute',
    title: 'Csendes működés',
    description: 'Modern brushless motor, minimális zajszint. Vendégeid relaxálhatnak a kezelés alatt.',
  },
  {
    icon: 'coins',
    title: 'Megfizethető árak',
    description: 'Professzionális minőség belépő szintű árakon. Kezdőknek és profik számára egyaránt ideális.',
  },
];

const faq = [
  {
    question: 'Mi a különbség a vezetékes és vezeték nélküli gépek között?',
    answer: 'A vezeték nélküli gépek nagyobb mozgásszabadságot biztosítanak, nincs zavaró kábel. A vezetékes gépek viszont folyamatos teljesítményt adnak és nem kell tölteni. Mindkettőnek megvan az előnye – a választás személyes preferencia kérdése.',
  },
  {
    question: 'Kezdőként melyik gépet válasszam?',
    answer: 'Kezdőknek a közepes árfekvésű, egyszerű kezelésű gépeket ajánljuk. A MAST alapmodellek kiváló választás: megbízhatók, könnyen használhatók és tartósak. Később frissíthetsz prémium modellre.',
  },
  {
    question: 'Milyen tűket használhatok?',
    answer: 'A MAST gépek univerzális cartridge rendszerrel működnek, kompatibilisek a legtöbb gyártó tűivel. Mi minőségi, steril, egyszer használatos cartridge-eket ajánlunk biztonságos munkához.',
  },
];

const comparison = {
  features: ['Ár', 'Típus', 'Lökethossz', 'Üzemidő', 'Súly', 'Ajánlott'],
  products: [
    {
      name: 'MAST Nano 2.0',
      tag: 'Ultrakönnyű',
      tagColor: 'purple',
      link: '/sminktetovalas/mast-nano-2',
      specs: {
        'Ár': '59 990 Ft',
        'Típus': 'Vezeték nélküli, coreless',
        'Lökethossz': 'Fix',
        'Üzemidő': 'Akkus',
        'Súly': '66 g',
        'Ajánlott': 'Szemhéj, precíz munka',
      },
    },
    {
      name: 'MAST P60',
      tag: 'Állítható lökethossz',
      tagColor: 'orange',
      highlighted: true,
      link: '/sminktetovalas/mast-p60-premium-sminktetovalo-gep-allithato-lokethosszal',
      specs: {
        'Ár': '79 990 Ft',
        'Típus': 'Vezeték nélküli',
        'Lökethossz': '5 fokozat (2,2–3,2 mm)',
        'Üzemidő': '3+ óra',
        'Súly': '121 g',
        'Ajánlott': 'Mindennapi PMU munka',
      },
    },
    {
      name: 'MAST P60 3in1',
      tag: 'Komplett szett',
      tagColor: 'blue',
      link: '/sminktetovalas/mast-p60-sminktetovalo-gep',
      specs: {
        'Ár': '119 990 Ft',
        'Típus': 'Vezeték nélküli + RCA',
        'Lökethossz': '5 fokozat (2,2–3,2 mm)',
        'Üzemidő': '3+ óra + pót akku',
        'Súly': '121 g',
        'Ajánlott': 'Profi PMU stúdió, hosszú munkanap',
      },
    },
  ],
};
---

<CategoryLayout category={category} products={products} benefits={benefits} faq={faq} comparison={comparison} />
