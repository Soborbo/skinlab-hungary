---
/**
 * Consultation Request Page
 * /konzultacio
 *
 * Multi-step consultation wizard for lead generation
 * Clean, conversion-optimized design
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import ConsultationWizard from '@/components/forms/ConsultationWizard.astro';
import { CONTACT } from '@/lib/constants';

// Get pre-selected product from URL
const product = Astro.url.searchParams.get('product') || '';
---

<BaseLayout
  title="Ingyenes konzultáció kérése"
  description="Kérjen ingyenes, személyre szabott konzultációt professzionális kozmetikai berendezésekről. Szakértő tanácsadás, 2 év garancia, betanítás."
>
  <section class="bg-gradient-to-b from-primary-50/50 to-white py-3 md:py-4">
    <div class="container mx-auto px-4">
      <!-- Wizard -->
      <ConsultationWizard product={product} />

      <!-- Alternative contact -->
      <div class="mt-8 text-center">
        <p class="text-gray-500 text-sm">Inkább telefonon? <a
          href={`tel:${CONTACT.phone}`}
          class="font-semibold text-primary-600 hover:text-primary-700 transition-colors"
        >{CONTACT.phoneDisplay}</a></p>
      </div>
    </div>
  </section>
</BaseLayout>
