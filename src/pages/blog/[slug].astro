---
import BlogPostLayout from '../../components/pages/BlogPostLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // Hungarian (default locale) canonical posts only — ids without a locale
  // prefix. Localized translations (`{locale}/{slug}`) are served by
  // /[locale]/blog/[slug].
  return posts
    .filter((post) => !post.id.includes('/'))
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
---

<BlogPostLayout post={post} />
