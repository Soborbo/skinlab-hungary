---
import TrainingDetailLayout from '../../components/pages/TrainingDetailLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const trainings = await getCollection('trainings');
  // Hungarian (default locale) canonical trainings only — ids without a locale
  // prefix. Localized translations (`{locale}/{slug}`) are served by
  // /[locale]/kepzesek/[slug].
  return trainings
    .filter((training) => !training.id.includes('/'))
    .map((training) => ({
      params: { slug: training.id },
      props: { training },
    }));
}

const { training } = Astro.props;
---

<TrainingDetailLayout training={training} />
