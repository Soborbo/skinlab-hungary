---
import CategoryLayout from '../../layouts/CategoryLayout.astro';
import { getCollection } from 'astro:content';
import { getCategoryTranslation } from '../../data/category-translations';

const category = getCategoryTranslation('hu', 'testkezeles');

const products = await getCollection('products', ({ data }) => {
  return data.categorySlug === 'testkezeles' && !data.draft;
});
---

<CategoryLayout category={category} products={products} />
