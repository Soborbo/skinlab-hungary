  products: [
    {
      name: 'Q-Switch Basic',        // 🔴 DUMMY
      tag: 'Belépő szint',
      tagColor: 'purple',
      link: '/nd-yag-lezerek/qswitch-basic',  // 🔴 DUMMY LINK
      specs: {
        'Ár': '1.5M Ft',             // 🔴 DUMMY
        'Hullámhosszak': '1064nm',    // 🔴 DUMMY
