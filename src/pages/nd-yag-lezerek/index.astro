---
import CategoryLayout from '../../layouts/CategoryLayout.astro';
import { getCollection } from 'astro:content';

const category = {
  name: 'Q-kapcsolt ND:YAG lézerkészülékek',
  nameShort: 'ND:YAG lézerek',
  slug: 'nd-yag-lezerek',
  description: 'Tetoválás és pigmentfolt eltávolító lézerek.',
  heroDescription: 'Tetoválás eltávolítás, carbon peeling, pigmentfolt kezelés. Professzionális Q-kapcsolt technológia, minimális fájdalom.',
  badge: 'Prémium technológia',
  color: 'nd-yag-lezerek',
};

const products = await getCollection('products', ({ data }) => {
  return data.categorySlug === 'nd-yag-lezerek' && !data.draft;
});

const benefits = [
  {
    icon: 'palette',
    title: 'Minden szín eltávolítható',
    description: 'A Q-kapcsolt ND:YAG lézer minden színű tetoválást képes eltávolítani, beleértve a nehéz zöldet és kéket is.',
  },
  {
    icon: 'sparkles',
    title: 'Carbon peeling',
    description: 'Hollywood facial néven is ismert kezelés. Azonnali ragyogás, pórusok összehúzása, zsíros bőr kezelése.',
  },
  {
    icon: 'microscope',
    title: 'Pigmentfolt kezelés',
    description: 'Napfolt, öregségi folt, melasma kezelése hatékonyan és biztonságosan.',
  },
  {
    icon: 'coins',
    title: 'Magas árrés',
    description: 'Tetoválás eltávolítás: 15-50.000 Ft/alkalom. Carbon peeling: 8-15.000 Ft. Gyorsan megtérülő befektetés.',
  },
];

const faq = [
  {
    question: 'Hány alkalom kell egy tetoválás teljes eltávolításához?',
    answer: 'Függ a tetoválás méretétől, színétől és régiségétől. Átlagosan 6-12 kezelés szükséges, 6-8 hetes szünetekkel. A fekete és sötét színek gyorsabban tűnnek el.',
  },
  {
    question: 'Fájdalmas a tetoválás eltávolítás?',
    answer: 'Modern hűtőrendszerrel rendelkező gépeknél a fájdalom minimális. Sokan a tetoválás készítéséhez hasonlítják – kellemetlen, de elviselhető. Érzéstelenítő krém is használható.',
  },
  {
    question: 'Mi a carbon peeling és kinek ajánlott?',
    answer: 'A carbon peeling során szénmaszkot viszünk fel az arcra, amit lézerrel eltávolítunk. Kiváló zsíros, pattanásos bőrre, tág pórusokra. Azonnali, látványos eredmény, nincs regenerációs idő.',
  },
];

const comparison = {
  features: ['Ár', 'Hullámhosszak', 'Kijelző', 'Kezelőfej-hűtés', 'Ajánlott'],
  products: [
    {
      name: 'PIXEL',
      tag: '2025 lengyel díjnyertes',
      tagColor: 'blue',
      link: '/nd-yag-lezerek/pixelcarbonlezer',
      specs: {
        'Ár': '999 990 Ft',
        'Hullámhosszak': '3 (1064 + 532 + ~585/650nm)',
        'Kijelző': '4,3" érintő',
        'Kezelőfej-hűtés': 'Kontakt hűtés',
        'Ajánlott': 'Kompakt belépő, piros pigment is',
      },
    },
    {
      name: 'FRAME',
      tag: 'Android okos',
      tagColor: 'orange',
      highlighted: true,
      link: '/nd-yag-lezerek/frame',
      specs: {
        'Ár': '1 549 990 Ft',
        'Hullámhosszak': '4',
        'Kijelző': '13,3" Android érintő',
        'Kezelőfej-hűtés': 'Beépített kezelőfej-hűtés',
        'Ajánlott': 'Tetoválás + pigmentfolt + carbon',
      },
    },
  ],
};
---

<CategoryLayout category={category} products={products} benefits={benefits} faq={faq} comparison={comparison} />
