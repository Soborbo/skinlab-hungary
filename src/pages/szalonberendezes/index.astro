---
import CategoryLayout from '../../layouts/CategoryLayout.astro';
import { getCollection } from 'astro:content';

const category = {
  name: 'Szalonberendezés',
  nameShort: 'Szalonberendezés',
  slug: 'szalonberendezes',
  description: 'Professzionális szalonbútorok, trolley-k és kiegészítők.',
  heroDescription: 'Minőségi szalonbútorok, kozmetikai ágyak, trolley-k és kiegészítők. Tervezd meg álmaid szalonját velünk!',
  badge: 'Komplett berendezés',
  color: 'green',
};

const products = await getCollection('products', ({ data }) => {
  return data.categorySlug === 'szalonberendezes';
});

const benefits = [
  {
    icon: 'palette',
    title: 'Modern design',
    description: 'Elegáns, kortárs stílusú bútorok, amelyek feldobják a szalonod megjelenését és vonzzák az ügyfeleket.',
  },
  {
    icon: 'wrench',
    title: 'Tartós minőség',
    description: 'Professzionális, ipari minőségű anyagok. Napi intenzív használatra tervezve, évekig szolgálnak.',
  },
  {
    icon: 'package',
    title: 'Gyors szállítás',
    description: 'Raktáron lévő termékek 1-2 héten belül kiszállítva. Összeszerelési útmutató mellékelve.',
  },
  {
    icon: 'coins',
    title: 'Kedvező árak',
    description: 'Gyártói kapcsolatainknak köszönhetően versenyképes árakon kínáljuk a berendezéseket.',
  },
];

const faq = [
  {
    question: 'Milyen szalonberendezéseket kínáltok?',
    answer: 'Kozmetikai ágyak, kezelőszékek, trolley-k (görgős szekrények), nagyítós lámpák, sterilizáló eszközök, várótermi bútorok és egyéb kiegészítők. Komplett szalonberendezés egy helyről.',
  },
  {
    question: 'Van összeszerelési segítség?',
    answer: 'Minden termékhez részletes összeszerelési útmutatót adunk. Egyszerűbb bútorokat te is összerakhatsz, nagyobb berendezéseknél igény esetén szerelési szolgáltatást is biztosítunk.',
  },
  {
    question: 'Tudtok egyedi méretben gyártani?',
    answer: 'Bizonyos termékek esetén igen. Kérj egyedi ajánlatot, és megvizsgáljuk a lehetőségeket. Nagyobb megrendelésnél (pl. új szalon berendezése) kedvezményt is adunk.',
  },
];

// ============================================================
// 🔴 DUMMY ADATOK - CSERÉLD KI VALÓS TERMÉKADATOKRA!
// ============================================================
const comparison = {
  features: ['Ár', 'Típus', 'Anyag', 'Teherbírás', 'Színek', 'Ajánlott'],
  products: [
    {
      name: 'Trolley Basic',            // 🔴 DUMMY
      tag: 'Belépő szint',
      tagColor: 'purple',
      link: '/szalonberendezes/trolley-basic',  // 🔴 DUMMY LINK
      specs: {
        'Ár': '39.000 Ft',              // 🔴 DUMMY
        'Típus': '3 fiókos',             // 🔴 DUMMY
        'Anyag': 'Műanyag',              // 🔴 DUMMY
        'Teherbírás': '15 kg',           // 🔴 DUMMY
        'Színek': 'Fehér, fekete',
        'Ajánlott': 'Kisszalonok',
      },
    },
    {
      name: 'Trolley Pro Steel',        // 🔴 DUMMY
      tag: 'Bestseller',
      tagColor: 'red',
      highlighted: true,
      link: '/szalonberendezes/trolley-pro-steel',  // 🔴 DUMMY LINK
      specs: {
        'Ár': '79.000 Ft',              // 🔴 DUMMY
        'Típus': '5 fiókos + tartó',     // 🔴 DUMMY
        'Anyag': 'Fém váz',              // 🔴 DUMMY
        'Teherbírás': '30 kg',           // 🔴 DUMMY
        'Színek': 'Fehér, rózsaszín, fekete',
        'Ajánlott': 'Profik választása',
      },
    },
    {
      name: 'Kozmetikai ágy Lux',       // 🔴 DUMMY
      tag: 'Prémium',
      tagColor: 'blue',
      link: '/szalonberendezes/kozmetikai-agy-lux',  // 🔴 DUMMY LINK
      specs: {
        'Ár': '189.000 Ft',             // 🔴 DUMMY
        'Típus': 'Elektromos 3 motoros', // 🔴 DUMMY
        'Anyag': 'Műbőr + acél',         // 🔴 DUMMY
        'Teherbírás': '180 kg',          // 🔴 DUMMY
