---
import CategoryLayout from '../../layouts/CategoryLayout.astro';
import { getCollection } from 'astro:content';
import diodalezerKezeles from '../../assets/diodalezer-kezeles.jpg';

const category = {
  name: 'Professzionális diódalézerek',
  nameShort: 'Diódalézerek',
  slug: 'diodalezerek',
  description: 'Professzionális 4 hullámhosszas diódalézerek tartós szőrtelenítéshez.',
  heroDescription: 'Tartós szőrtelenítés 4 hullámhosszú technológiával. Minden bőrtípusra, minden szőrtípusra. Gyors megtérülés, elégedett vendégek.',
  badge: 'Tartós szőrtelenítés',
  color: 'diodalezerek',
};

// Phase 1 CRO+SEO redesign - opt-in props (csak a dióda lézer oldalon aktív)
// Forrás: docs/CATEGORY-PAGE-HANDBOOK.md §3, §5, §6
const expert = {
  name: 'Horváth László',
  role: 'Skinlab alapító · technikai szakértő',
  image: '/about/horvath-laszlo-skinlab-alapito.jpg',
  imageAlt: 'Horváth László, Skinlab alapító',
  quote: 'Segítek megtalálni a szalonjához illő diódalézert - 600W-tól 1600W-ig.',
};

// Specifikus trust badge-ek (vague helyett SLA + szám)
// Forrás: docs/CATEGORY-PAGE-HANDBOOK.md §6.2 (Cialdini specificity principle)
const trustBadges = [
  { title: '2 év teljes körű garancia', subtitle: 'minden új gépre' },
  { title: '8 órás helyszíni betanítás', subtitle: '+ 6 hónap follow-up' },
  { title: '100% magyar szerviz', subtitle: 'cseregép-háttérrel' },
  { title: '0% THM, 24 hónap', subtitle: 'előleg nélkül' },
];

const consultationCtaHref = '/konzultacio?cat=diodalezerek';
const consultationSocialProof = '150+ szalon választott minket 2024 óta';

// Egysoros "melyik nekem" orientáció a decision-fold hero bal oszlopában
const heroChooser = [
  { label: 'Kezdő / kiegészítő szolgáltatás?', target: 'ATHENA' },
  { label: 'Tempó kontrollal?', target: 'OLYMPIA' },
  { label: 'Klinika, nagy forgalom?', target: 'HELIOS' },
];

const products = await getCollection('products', ({ data }) => {
  return data.categorySlug === 'diodalezerek' && !data.draft;
});

const benefits = [
  {
    icon: 'trend-up',
    title: '3-4 hónap megtérülés',
    description: 'Napi 5 vendéggel átlag 12.000 Ft/kezelés áron havonta 1.3M Ft bevétel. A gép 3-4 hónap alatt kitermeli magát.',
  },
  {
    icon: 'users',
    title: 'Visszatérő vendégek',
    description: 'A vendégek 6-8 alkalmas kúrát vesznek, aztán évente fenntartó kezelésre járnak. Stabil bevétel.',
  },
  {
    icon: 'zap',
    title: 'IPL-nél hatékonyabb',
    description: 'A diódalézer célzottabb, mélyebbre hatol, kevesebb kezelés kell. Vendégeid gyorsabban látják az eredményt.',
  },
  {
    icon: 'target',
    title: 'Minden bőrtípusra',
    description: 'A 4 hullámhosszú rendszerek világos és sötét bőrön, vékony és vastag szőrön egyaránt hatékonyak.',
  },
];

const faq = [
  {
    question: 'Mi a különbség az 1, 3 és 4 hullámhosszú gépeknél?',
    answer: '<strong>1 hullámhossz (808nm):</strong> A klasszikus, legelterjedtebb. Világos-közepes bőrre, átlag szőrre ideális. Belépő szintű gépek.<br><br><strong>3 hullámhossz (755+808+1064nm):</strong> Már sötétebb bőrt és finomabb szőrt is kezel. Sokoldalúbb.<br><br><strong>4 hullámhossz (755+808+940+1064nm):</strong> A legsokoldalúbb. Minden bőr- és szőrtípusra, a melanin-szegény szőrre (szőke, vörös) is hatékonyabb. Profik választása.',
  },
  {
    question: 'Miért fontos a teljesítmény (watt)?',
    answer: 'Nagyobb teljesítmény = gyorsabb kezelés. Egy 1200W-os gép akár 2x gyorsabb lehet mint egy 600W-os. Ez több vendéget jelent naponta, gyorsabb megtérülést. Nagy forgalmú szalonnak mindenképp 1000W+ ajánlott.',
  },
  {
    question: 'Fáj a vendégnek a diódalézeres kezelés?',
    answer: 'A modern diódalézerek hűtőrendszerrel rendelkeznek. A -5°C-os zafír hűtés szinte fájdalommentessé teszi a kezelést. A legtöbb vendég csak enyhe melegséget érez. Ez az egyik fő oka, hogy a vendégek visszajönnek!',
  },
  {
    question: 'Mennyi idő egy kezelés?',
    answer: 'Függ a testterülettől és a gép teljesítményétől. Hónalj: 5-10 perc. Láb: 20-40 perc. Teljes test: 60-90 perc. Az 1200W-os gépekkel 30-50%-kal rövidebb a kezelés mint az alacsonyabb teljesítményűekkel.',
  },
];

const comparison = {
  features: ['Ár', 'Hullámhosszak', 'Teljesítmény', 'Spotméret', 'Hűtés', 'Ajánlott'],
  products: [
    {
      name: 'ATHENA',
      tag: 'Kontroll & precizitás',
      tagColor: 'purple',
      link: '/diodalezerek/athena',
      specs: {
        'Ár': '1 999 990 Ft',
        'Hullámhosszak': '4 (755+808+940+1064nm)',
        'Teljesítmény': '1000W',
        'Spotméret': 'Fix zafír kontakt',
        'Hűtés': 'TEC + víz + levegő',
        'Ajánlott': 'Stabil belépő pro, kiegészítő szolgáltatás',
      },
    },
    {
      name: 'OLYMPIA',
      tag: 'Ár-érték bajnok',
      tagColor: 'orange',
      highlighted: true,
      link: '/diodalezerek/olympia',
      specs: {
        'Ár': '2 499 990 Ft',
        'Hullámhosszak': '4 (755+808+940+1064nm)',
        'Teljesítmény': '1200W',
        'Spotméret': '5 állítható méret',
        'Hűtés': 'TEC + víz + levegő',
        'Ajánlott': 'Tempó + kontroll, rugalmas szalonmunka',
      },
    },
    {
      name: 'HELIOS',
      tag: 'Felső kategória',
      tagColor: 'blue',
      link: '/diodalezerek/helios',
      specs: {
        'Ár': '2 999 990 Ft',
        'Hullámhosszak': '4 (755+808+940+1064nm)',
        'Teljesítmény': '1600W',
        'Spotméret': '5 állítható méret',
        'Hűtés': 'TEC + víz + levegő, ~ -16°C zafír',
        'Ajánlott': 'Klinikák, nagy forgalmú szalonok',
      },
    },
  ],
};

const choicesIntro = 'Nem három gép. Három különböző szemlélet. Mindhárom ugyanarra készült: valódi, reális és észlelhető eredményt adni - válaszd azt az erőt, ami hozzád illik.';

const choicesClosing = 'Mi a közös bennük? Mindhárom valódi, nyomon követhető teljesítmény - nem üres marketing. Nem egy gépet választasz, hanem egy szemléletet.';

const choices = [
  {
    name: 'ATHENA',
    subtitle: 'a kontroll és precizitás',
    tagline: 'A tudásból születő erő.',
    image: '@assets/products/athena-1.png',
    imageAlt: 'ATHENA 1000W diódalézer',
    intro: 'Athena nem a nyers erő istennője volt, hanem a stratégia, a pontosság és a tudatos működés jelképe. Az ATHENA diódalézer ezt képviseli - és bölcsességére is számíthatsz: okos szoftvere automatikusan segít megállapítani, melyik bőr- és szőrtípus milyen beállításon kezelhető. Athena ott van melletted, és segít.',
    pillars: [
      'stabil működés',
      'kiszámítható eredmények',
      'minden helyzetben kontroll',
    ],
    whenTitle: 'Mikor válaszd az ATHENA-t?',
    when: [
      {
        title: 'Ha fontos a költséghatékonyság',
        description: 'Egy olyan gépet keresel, ami nem túlzás, hanem okosan felépített befektetés.',
      },
      {
        title: 'Ha más szolgáltatás mellé építenéd be',
        description: 'Kozmetikusként, bőrápolási kezelések mellett egy stabil, megbízható kiegészítő szolgáltatást szeretnél.',
      },
      {
        title: 'Ha biztonsági játékos vagy',
        description: 'Nem kísérletezni akarsz, hanem egy kiszámíthatóan működő rendszert, ami hozza, amit kell.',
      },
    ],
    notes: [
      'Akkor is jó választás, ha erre építenéd a vállalkozásod? Igen. Az 1000W kimeneti teljesítmény bőven elegendő a professzionális szintű munkavégzéshez és látványos eredményekhez.',
      'Az átlag diódalézerek többsége 600W körül működik - a 1000W gyorsabb munkavégzést, nagyobb hatékonyságot, stabilabb működést és kényelmesebb kezeléseket jelent.',
    ],
    closing: 'ATHENA. A nőies erő és precizitás harmóniája.',
    link: '/diodalezerek/athena',
    ctaLabel: 'ATHENA részletei',
  },
  {
    name: 'OLYMPIA',
    subtitle: 'a győztes teljesítmény',
    tagline: 'Ahol a teljesítmény győz.',
    image: '@assets/products/olympia-1.png',
    imageAlt: 'OLYMPIA 1200W diódalézer',
    intro: 'Olympia az a hely volt, ahol csak a legjobbak számítottak - nem az, ki honnan jött, hanem hogy mit tud valójában. Nem voltak kifogások, csak eredmények. A 1200W kimeneti teljesítmény már nem átlag: ez az a szint, ahol a kezelések felgyorsulnak, és az eredmények kiszámíthatóvá válnak. Az 5 állítható spotméret pedig valódi kuriózum - precíz munka kisebb területeken, gyors haladás nagy felületeken.',
    pillars: [
      'gyorsabb kezelések',
      'hatékonyabb munkavégzés',
      'rugalmas alkalmazkodás minden vendéghez',
    ],
    whenTitle: 'Mikor válaszd az OLYMPIA-t?',
    when: [
      {
        title: 'Ha erős gépet keresel reális áron',
        description: 'A 1200W már az a szint, ahol nem kell „okoskodni" a kezeléseknél - egyszerűen működik, gyorsan és hatékonyan.',
      },
      {
        title: 'Ha tempót akarsz, de kontrollal',
        description: 'Nem csak haladni szeretnél, hanem jól dolgozni. Az 5 spotméret precizitás + sebesség egyben - és az okos kezelőrendszer melletted áll.',
      },
      {
        title: 'Ha fejlődni akarsz, de tudatosan',
        description: 'Nem a legdrágább gépet keresed, hanem azt, ami valóban megtérül, miközben minőségi és megbízható társ a kezelések terén.',
      },
      {
        title: 'Ha fontos a rugalmasság',
        description: 'Különböző vendégek, különböző területek - az OLYMPIA minden helyzethez alkalmazkodik.',
      },
    ],
    notes: [
      'Az OLYMPIA nagyon erős, mégis elérhető - okos rendszerrel, kiváló európai ár-érték aránnyal.',
    ],
    closing: '„Μολὼν λαβέ" - Gyere és vedd el! /Leonidász/',
    link: '/diodalezerek/olympia',
    ctaLabel: 'OLYMPIA részletei',
  },
  {
    name: 'HELIOS',
    subtitle: 'a fény valódi ereje',
    tagline: 'Erő, fény és könyörtelen pontosság.',
    image: '@assets/products/helios-1.png',
    imageAlt: 'HELIOS 1600W diódalézer',
    intro: 'Helios a görög mitológiában a Nap istene. Ő az, aki minden nap fényt hoz, mindent lát, és semmi nem marad rejtve előle. Egy 1600W-os kimeneti teljesítménynél nincs szükség magyarázkodásra - ahogy Helios sem kérdezte soha, elég fényt hoz-e a világba. Minden hajnalban elindult aranyszekerén, csendesen, mégis megállíthatatlanul.',
    pillars: [
      'mélyebbre hat a szőrtüszőben',
      'hatékonyabb energialeadás',
      'rövidebb kezelési idők',
    ],
    whenTitle: 'Kinek való igazán?',
    when: [
      {
        title: 'Ha már nem kezdő szinten gondolkodsz',
        description: 'Olyan rendszert akarsz, ami nem lassít, hanem visz előre - és nem kell hozzá alkalmazkodnod.',
      },
      {
        title: 'Ha tempót és bevételt akarsz növelni',
        description: 'A nagyobb teljesítmény gyorsabb látványos eredményt ad, gyakran kevesebb ismétléssel - a vendég hamarabb elégedett.',
      },
      {
        title: 'Ha mást is csinálsz mellette',
        description: 'Arckezelések, testkezelések, komplex kozmetika? A nagy teljesítmény és az állítható spotok miatt rövidebb a kezelési idő, így könnyen beilleszthető a napodba.',
      },
      {
        title: 'Ha a felső kategóriát keresed',
        description: '600–800W = belépő/átlag, 1000–1200W = erős, 1600W = felső kategória. A HELIOS prémium klinikai szintű rendszer.',
      },
    ],
    closing: 'A HELIOS azoknak való, akik nem kapaszkodnak a határokba, hanem átlépik őket.',
    link: '/diodalezerek/helios',
    ctaLabel: 'HELIOS részletei',
  },
];
---

<CategoryLayout
  category={category}
  products={products}
  benefits={benefits}
  benefitsImage={diodalezerKezeles}
  benefitsImageAlt="Diódalézeres tartós szőrtelenítés egy Skinlab készülékkel a szalonban"
  faq={faq}
  comparison={comparison}
  choices={choices}
  choicesIntro={choicesIntro}
  choicesClosing={choicesClosing}
  expert={expert}
  trustBadges={trustBadges}
  consultationCtaHref={consultationCtaHref}
  consultationSocialProof={consultationSocialProof}
  heroChooser={heroChooser}
/>
