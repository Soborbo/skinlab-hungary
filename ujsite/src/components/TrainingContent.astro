---
import { getLocalizedUrl, type Lang } from "../i18n/config";

interface Props {
  t: Record<string, any>;
  lang: Lang;
}

const { t, lang } = Astro.props;
const contactLink = getLocalizedUrl("contact", lang);
const tr = t.training;
---

<section class="py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">{tr.heading}</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">{tr.intro}</p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 mb-12">
      <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
        <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">{t.whyUs?.training || "Training"}</h3>
        <p class="text-gray-600 mb-4">{t.whyUs?.trainingDesc || ""}</p>
        <ul class="space-y-2 text-sm text-gray-600">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            {t.trust?.training || "FAR certificate"}
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            {t.trust?.warranty || "2 year warranty"}
          </li>
        </ul>
      </div>

      <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
        <div class="w-14 h-14 bg-purple-100 rounded-xl flex items-center justify-center mb-4">
          <svg class="w-7 h-7 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">{t.whyUs?.consulting || "Consulting"}</h3>
        <p class="text-gray-600 mb-4">{t.whyUs?.consultingDesc || ""}</p>
        <ul class="space-y-2 text-sm text-gray-600">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            {t.finalCta?.roiCalculation || "ROI calculation"}
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            {t.finalCta?.noObligation || "No obligation"}
          </li>
        </ul>
      </div>
    </div>

    <div class="text-center">
      <a href={contactLink} class="inline-flex items-center px-6 py-3 bg-primary-600 text-white font-semibold rounded-xl hover:bg-primary-700 transition-colors">
        {tr.cta}
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
