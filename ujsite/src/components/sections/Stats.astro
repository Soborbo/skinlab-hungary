---
interface Props {
  t: Record<string, any>;
}

const { t } = Astro.props;

const stats = [
  { value: "150+", labelKey: "soldUnits" },
  { value: "2", labelKey: "warranty", suffixKey: "yearsSuffix" },
  { value: "2", labelKey: "deliveryTime", suffixKey: "weeksSuffix" },
  { value: "100%", labelKey: "legalImport" },
];
---

<section class="py-16 lg:py-20 bg-primary-600">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-4xl lg:text-5xl font-bold text-white mb-2">
            {stat.value}{stat.suffixKey ? ` ${t.stats[stat.suffixKey]}` : ""}
          </div>
          <div class="text-primary-100 font-medium">
            {t.stats[stat.labelKey]}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
