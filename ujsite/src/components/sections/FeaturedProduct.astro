---
import { Image } from "astro:assets";
import { CONTACT } from "../../lib/constants";
import { getLocalizedUrl, type Lang } from "../../i18n/config";
import productImage from "../../assets/products/prestige4wavemain.webp";

interface Props {
  t: Record<string, any>;
  lang: Lang;
}

const { t, lang } = Astro.props;
const contactLink = getLocalizedUrl("contact", lang);
const fp = t.featuredProduct;

const specs = [
  { value: "4", label: fp.wavelength },
  { value: "1200W", label: fp.power },
  { value: "-5°C", label: fp.cooling },
  { value: fp.warrantyValue, label: fp.warranty },
];
---

<section class="bg-gradient-to-r from-primary-600 to-indigo-700 py-16 lg:py-20 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-1/2 h-full bg-white/5" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-12 items-center">
      <!-- Product image -->
      <div class="bg-white/10 backdrop-blur rounded-2xl aspect-square flex items-center justify-center order-2 lg:order-1 overflow-hidden">
        <Image
          src={productImage}
          alt={fp.name}
          class="w-full h-full object-contain p-4"
          widths={[480, 768]}
          sizes="(max-width: 1024px) 100vw, 50vw"
        />
      </div>

      <!-- Product info -->
      <div class="text-white order-1 lg:order-2">
        <div class="inline-flex items-center gap-2 bg-white/20 backdrop-blur px-3 py-1 rounded-full text-sm mb-4">
          <svg class="w-4 h-4 text-yellow-300" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          {fp.badge}
        </div>

        <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold mb-3">{fp.name}</h2>
        <p class="text-lg lg:text-xl text-blue-100 mb-6">{fp.tagline}</p>

        <div class="grid grid-cols-2 gap-3 mb-6">
          {specs.map((spec) => (
            <div class="bg-white/10 backdrop-blur rounded-xl p-3 lg:p-4">
              <div class="text-xl lg:text-2xl font-bold">{spec.value}</div>
              <div class="text-blue-200 text-sm">{spec.label}</div>
            </div>
          ))}
        </div>

        <div class="flex items-end gap-4 mb-6">
          <div>
            <div class="text-blue-200 text-sm">{fp.grossPrice}</div>
            <div class="text-3xl lg:text-4xl font-bold">{fp.priceOnRequest}</div>
          </div>
          <div class="text-blue-200">
            {fp.orMonthly} {fp.monthlyPrice}
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href={contactLink}
            class="bg-white text-primary-600 font-bold py-3 lg:py-4 px-6 lg:px-8 rounded-xl text-center hover:bg-blue-50 transition-colors"
          >
            {fp.viewDetails}
          </a>
          <a
            href={contactLink}
            class="bg-primary-500 hover:bg-primary-400 text-white font-bold py-3 lg:py-4 px-6 lg:px-8 rounded-xl text-center transition-colors"
          >
            {fp.requestDemo}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
