---
interface Props {
  t: Record<string, any>;
}

const { t } = Astro.props;

const testimonials = [
  { quoteKey: "quote1", nameKey: "name1", businessKey: "business1", locationKey: "location1", rating: 5, color: "bg-purple-200" },
  { quoteKey: "quote2", nameKey: "name2", businessKey: "business2", locationKey: "location2", rating: 5, color: "bg-pink-200" },
  { quoteKey: "quote3", nameKey: "name3", businessKey: "business3", locationKey: "location3", rating: 4, color: "bg-blue-200" },
];
---

<section class="py-16 lg:py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 lg:mb-14">
      <h2 class="text-2xl lg:text-3xl font-bold text-gray-900 mb-3">
        {t.testimonials.title}
      </h2>
      <p class="text-gray-600">
        {t.testimonials.subtitle}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      {testimonials.map((testimonial) => (
        <div class="bg-white rounded-2xl p-6 lg:p-8 shadow-sm border border-gray-100">
          <div class="flex gap-0.5 mb-4 text-yellow-400 text-lg">
            {Array.from({ length: 5 }).map((_, i) => (
              <span class={i < testimonial.rating ? "" : "text-gray-300"}>
                {i < testimonial.rating ? "\u2605" : "\u2606"}
              </span>
            ))}
          </div>
          <p class="text-gray-700 mb-6" set:html={`"${t.testimonials[testimonial.quoteKey]}"`} />
          <div class="flex items-center gap-3">
            <div class={`w-12 h-12 ${testimonial.color} rounded-full flex items-center justify-center text-xl`}>
              <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div>
              <div class="font-bold text-gray-900">{t.testimonials[testimonial.nameKey]}</div>
              <div class="text-sm text-gray-500">{t.testimonials[testimonial.businessKey]} &bull; {t.testimonials[testimonial.locationKey]}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
