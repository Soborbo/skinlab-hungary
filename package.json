{
  "name": "skinlab-hungary",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/patch-wrangler-config.cjs",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "deploy": "wrangler deploy --config dist/server/wrangler.json --keep-vars",
    "deploy:dry": "wrangler deploy --config dist/server/wrangler.json --keep-vars --dry-run",
    "generate:images": "node scripts/generate-optimized-images.cjs",
    "validate:content": "npx tsx scripts/validate-content.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.0",
    "fuse.js": "^7.3.0",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^25.9.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "wrangler": "^4.92.0",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "vite": "^8.0.0",
    "@emnapi/runtime": "^1.10.0",
    "@emnapi/core": "^1.10.0"
  }
}
