# Billingo díjbekérő API (v3)
# Letrehozas: app.billingo.hu -> Beallitasok -> API kulcsok
# block_id: Beallitasok -> Bizonylattomb (új SkinLab tömb létrehozása ajánlott)
# bank_account_id: Beallitasok -> Bankszamlak
BILLINGO_API_KEY=
BILLINGO_BLOCK_ID=
BILLINGO_BANK_ACCOUNT_ID=
# BILLINGO_API_URL=https://api.billingo.hu/v3  # opcionális override

# CookieYes consent banner (BUILD-time env - a prerenderelt HTML-be kerül).
# A client_data ID az app.cookieyes.com -> Advanced Settings -> Get Code
# script URL-jeből olvasható ki. Enélkül nincs consent banner az oldalon!
PUBLIC_COOKIEYES_ID=
